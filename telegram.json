d\u0438\u043c \u0456\u0437 \u0432\u0430\u0436\u043b\u0438\u0432\u0438\u0445 \u043d\u0430\u043f\u0440\u044f\u043c\u043a\u0456\u0432, \u043d\u0430\u0434 \u044f\u043a\u0438\u043c \u044f \u0437\u0430\u0440\u0430\u0437 \u043f\u0440\u0430\u0446\u044e\u044e, \u0454 \u0437\u0430\u0445\u0438\u0441\u0442 \u00ab\u0423\u043a\u0440\u0437\u0430\u043b\u0456\u0437\u043d\u0438\u0446\u0456\u00bb \u0437\u0430\u0441\u043e\u0431\u0430\u043c\u0438 \u0420\u0415\u0411. \u042f\u043a\u0449\u043e \u0456\u0437 \u0437\u0430\u0445\u0438\u0441\u0442\u043e\u043c \u0441\u0442\u0430\u0446\u0456\u043e\u043d\u0430\u0440\u043d\u0438\u0445 \u043e\u0431\u2019\u0454\u043a\u0442\u0456\u0432 \u0437\u0430\u0441\u043e\u0431\u0430\u043c\u0438 \u0420\u0415\u0411 \u0432\u0441\u0435 \u0431\u0456\u043b\u044c\u0448-\u043c\u0435\u043d\u0448 \u0437\u0440\u043e\u0437\u0443\u043c\u0456\u043b\u043e \u0456 \u043f\u0438\u0442\u0430\u043d\u043d\u044f \u043f\u043e\u043b\u044f\u0433\u0430\u0454 \u043b\u0438\u0448\u0435 \u0443 \u0444\u0456\u043d\u0430\u043d\u0441\u0430\u0445, \u0442\u043e \u0456\u0437 \u0437\u0430\u0445\u0438\u0441\u0442\u043e\u043c \u043f\u043e\u0457\u0437\u0434\u0456\u0432 \u0432\u0441\u0435 \u043d\u0435 \u0442\u0430\u043a \u043f\u0440\u043e\u0441\u0442\u043e. \u041f\u0438\u0442\u0430\u043d\u043d\u044f \u0437\u0430\u0445\u0438\u0441\u0442\u0443 \u0420\u0415\u0411 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044e\u0454 \u0433\u043e\u043b\u043e\u0432\u0430 \u043f\u0440\u0430\u0432\u043b\u0456\u043d\u043d\u044f \u0410\u0422 \u00ab\u0423\u043a\u0440\u0437\u0430\u043b\u0456\u0437\u043d\u0438\u0446\u044f\u00bb \u041e\u043b\u0435\u043a\u0441\u0430\u043d\u0434\u0440 \u041f\u0435\u0440\u0446\u043e\u0432\u0441\u044c\u043a\u0438\u0439, \u0437 \u044f\u043a\u0438\u043c \u043c\u0438 \u043f\u043e\u0441\u0442\u0456\u0439\u043d\u043e \u043d\u0430 \u0437\u0432'\u044f\u0437\u043a\u0443. \u0417\u0430\u043b\u0443\u0447\u0435\u043d\u043e \u0431\u0430\u0433\u0430\u0442\u043e \u0444\u0430\u0445\u0456\u0432\u0446\u0456\u0432, \u044f\u043a \u0432\u0456\u0439\u0441\u044c\u043a", "link": "https://t.me/serhii_flash/7172", "pubDate": "2026-03-24T12:33:28+00:00"}, {"channel": "serhii_flash", "snippet": "\u042f \u043d\u0435 \u0437\u043d\u0430\u044e, \u0447\u0438 \u0446\u0435 \u043d\u0430\u0448\u0435 \u0432\u0456\u0434\u0435\u043e, \u0447\u0438 \u0432\u043e\u0440\u043e\u0436\u0435. \u041c\u0438 \u043f\u043e\u0447\u0430\u043b\u0438 \u0441\u043f\u0435\u0440\u0435\u0447\u0430\u0442\u0438\u0441\u044f \u0437 \u043a\u043e\u043b\u0435\u0433\u0430\u043c\u0438, \u0456 \u0434\u0443\u043c\u043a\u0438 \u0440\u043e\u0437\u0456\u0439\u0448\u043b\u0438\u0441\u044f. \u042f \u0432\u0432\u0430\u0436\u0430\u044e, \u0449\u043e \u043d\u043e\u0441\u0456\u0439 FPV \u2014 \u0446\u0435 \u00ab\u0456\u0434\u0435\u044f \u043d\u0430 \u043c\u0456\u043b\u044c\u0439\u043e\u043d\u00bb \u0434\u043b\u044f \u043a\u0440\u0438\u043b\u0430\u0442\u0438\u0445 \u0411\u041f\u041b\u0410, \u0434\u043b\u044f \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u043a\u0430\u0442\u0435\u0440\u0456\u0432. \u0410\u043b\u0435 \u044f \u043d\u0435 \u0440\u043e\u0437\u0443\u043c\u0456\u044e, \u043d\u0430\u0432\u0456\u0449\u043e \u0446\u0435 \u043d\u0430 \u0440\u0430\u0434\u0456\u043e \u043a\u0435\u0440\u0443\u0432\u0430\u043d\u043d\u044f \u0424\u041f\u0412 \u043d\u0430 \u043d\u0430\u0437\u0435\u043c\u043d\u0438\u0445 \u0440\u043e\u0431\u043e\u0442\u0430\u0445. \u041f\u0456\u0434\u0432\u0435\u0437\u0442\u0438 \u0431\u043b\u0438\u0436\u0447\u0435 \u0434\u043e \u0444\u0440\u043e\u043d\u0442\u0443? \u0422\u0430\u043a \u041d\u0420\u041a \u0457\u0445\u0430\u0442\u0438\u043c\u0435 \u0433\u043e\u0434\u0438\u043d\u0443 \u0437 \u0440\u0438\u0437\u0438\u043a\u043e\u043c \u0442\u0443\u0434\u0438, \u043a\u0443\u0434\u0438 FPV \u0434\u043e\u043b\u0435\u0442\u0438\u0442\u044c \u0437\u0430 \u0437\u0430\u0439\u0432\u0443 \u00ab\u0445\u0432\u0438\u043b\u0438\u043d\u0443\u00bb. \u041d\u0420\u041a \u0431\u0443\u0434\u0435 \u0440\u0435\u0442\u0440\u0438\u043a\u043e\u043c \u0434\u043b