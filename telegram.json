\u043e\u043b\u043e\u0433\u0456\u0457. \u0417\u0430\u043f\u0443\u0441\u043a \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u0411\u041f\u041b\u0410 \u043d\u0430 \u043f\u043e\u0432\u0456\u0442\u0440\u044f\u043d\u0438\u0445 \u043a\u0443\u043b\u044f\u0445 \u0443\u0433\u043b\u0438\u0431 \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0457 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u0412\u0438 \u043d\u0430\u0434\u0441\u0438\u043b\u0430\u0454\u0442\u0435 \u043c\u0435\u043d\u0456 \u0437\u0430\u043f\u0438\u0442\u0430\u043d\u043d\u044f, \u0430\u043b\u0435 \u044f \u043d\u0435 \u0445\u043e\u0447\u0443 \u043f\u0443\u0431\u043b\u0456\u0447\u043d\u043e \u0446\u0435 \u043a\u043e\u043c\u0435\u043d\u0442\u0443\u0432\u0430\u0442\u0438. \u0421\u043a\u0430\u0436\u0443 \u043b\u0438\u0448\u0435, \u0449\u043e \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0432\u0456\u043b\u044c\u043d\u043e \u0434\u0440\u0435\u0439\u0444\u0443\u044e\u0447\u0438\u0445 \u043a\u0443\u043b\u044c \u0443 \u0446\u0456\u0439 \u0432\u0456\u0439\u043d\u0456 \u0434\u043b\u044f \u0440\u0456\u0437\u043d\u0438\u0445 \u0437\u0430\u0432\u0434\u0430\u043d\u044c \u043d\u0435 \u0454 \u0447\u0438\u043c\u043e\u0441\u044c \u043d\u043e\u0432\u0438\u043c. \u041c\u0438 \u0442\u0430 \u0432\u043e\u0440\u043e\u0433 \u0432\u0436\u0435 \u0434\u0430\u0432\u043d\u043e \u0432\u0438\u043f\u0440\u043e\u0431\u0443\u0432\u0430\u043b\u0438 \u0440\u0456\u0437\u043d\u0456 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0438.", "snippet_en": "\u041d\u0430\u0448 \u0432\u043e\u0440\u043e\u0433 \u0443 \u0441\u0432\u043e\u0457\u0445 \u043a\u0430\u043d\u0430\u043b\u0430\u0445 \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u043e\u0431\u0433\u043e\u0432\u043e\u0440\u044e\u0454 \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u0432\u0430\u043d\u043d\u044f \u043d\u0430\u043c\u0438 \u043d\u043e\u0432\u043e\u0457 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0456\u0457. \u0417\u0430\u043f\u0443\u0441\u043a \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u0411\u041f\u041b\u0410 \u043d\u0430 \u043f\u043e\u0432\u0456\u0442\u0440\u044f\u043d\u0438\u0445 \u043a\u0443\u043b\u044f\u0445 \u0443\u0433\u043b\u0438\u0431 \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0457 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u0412\u0438 \u043d\u0430\u0434\u0441\u0438\u043b\u0430\u0454\u0442\u0435 \u043c\u0435\u043d\u0456 \u0437\u0430\u043f\u0438\u0442\u0430\u043d\u043d\u044f, \u0430\u043b\u0435 \u044f \u043d\u0435 \u0445\u043e\u0447\u0443 \u043f\u0443\u0431\u043b\u0456\u0447\u043d\u043e \u0446\u0435 \u043a\u043e\u043c\u0435\u043d\u0442\u0443\u0432\u0430\u0442\u0438. \u0421\u043a\u0430\u0436\u0443 \u043b\u0438\u0448\u0435, \u0449\u043e \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0432\u0456\u043b\u044c\u043d\u043e \u0434\u0440\u0435\u0439\u0444\u0443\u044e\u0447\u0438\u0445 \u043a\u0443\u043b\u044c \u0443 \u0446\u0456\u0439 \u0432\u0456\u0439\u043d\u0456 \u0434\u043b\u044f \u0440\u0456\u0437\u043d\u0438\u0445 \u0437\u0430\u0432\u0434\u0430\u043d\u044c \u043d\u0435 \u0454 \u0447\u0438\u043c\u043e\u0441\u044c \u043d\u043e\u0432\u0438\u043c. \u041c\u0438 \u0442\u0430 \u0432\u043e\u0440\u043e\u0433 \u0432\u0436\u0435 \u0434\u0430\u0432\u043d\u043e \u0432\u0438\u043f\u0440\u043e\u0431\u0443\u0432\u0430\u043b\u0438 \u0440\u0456\u0437\u043d\u0456 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0438.", "link": "https://t.me/serhii_flash/7438", "pubDate": "2026-05-29T08:38:07+00:00"}, {"channel": "lost_armour", "snippet": "\ud83d\udd34 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0434\u0435\u043d\u044c \u0437\u0430 \u0434\u043d\u0435\u043c&#33; \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0437\u0430 29 \u043c\u0430\u044f 2026 \u0433\u043e\u0434\u0430 \u2022 \u0414\u043e\u043d\u0431\u0430\u0441