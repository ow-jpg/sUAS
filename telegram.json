6 \u042f.\u041c. \u0421\u0432\u0435\u0440\u0434\u043b\u043e\u0432\u0430 (\u0414\u0437\u0435\u0440\u0436\u0438\u043d\u0441\u044c\u043a, \u041d\u0438\u0436\u0435\u0433\u043e\u0440\u043e\u0434\u0441\u044c\u043a\u0430 \u043e\u0431\u043b.) \u0414\u0432\u043e\u043c\u0430 \u0411\u041f\u041b\u0410 \u0410\u041d-196 \"\u041b\u044e\u0442\u0438\u0439\" \u0443\u0440\u0430\u0436\u0435\u043d\u043e \u0434\u0432\u0430 \u0446\u0435\u0445\u0438 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u0430 \u0432\u0438\u0431\u0443\u0445\u0456\u0432\u043a\u0438 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f. \u0417\u0430\u0432\u043e\u0434 \u0456\u043c\u0435\u043d\u0456 \u0421\u0432\u0435\u0440\u0434\u043b\u043e\u0432\u0430 - \u043e\u0434\u043d\u0435 \u0437 \u043d\u0430\u0439\u0431\u0456\u043b\u044c\u0448\u0438\u0445 \u043f\u0456\u0434\u043f\u0440\u0438\u0454\u043c\u0441\u0442\u0432 \u0440\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u043e\u0433\u043e \u0412\u041f\u041a \u0443 \u0441\u0435\u0433\u043c\u0435\u043d\u0442\u0456 \u043f\u0440\u043e\u043c\u0438\u0441\u043b\u043e\u0432\u0438\u0445 \u0456 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u0438\u0445 \u0432\u0438\u0431\u0443\u0445\u043e\u0432\u0438\u0445 \u0440\u0435\u0447\u043e\u0432\u0438\u043d. \u0412\u0438\u0440\u043e\u0431\u043b\u044f\u0454 \u0442\u0440\u043e\u0442\u0438\u043b, \u0433\u0435\u043a\u0441\u043e\u0433\u0435\u043d, \u043e\u043a\u0442\u043e\u0433\u0435\u043d \u0442\u0430 \u0441\u043f\u043e\u0440\u044f\u0434\u0436\u0430\u0454 \u0431\u043e\u0454\u043f\u0440\u0438\u043f\u0430\u0441\u0438 \u0434\u043b\u044f \u043f\u043e\u0442\u0440\u0435\u0431 \u0430\u0440\u043c\u0456\u0457. \u0424\u0430\u043a\u0442\u0438\u0447\u043d\u043e - \u0432\u0443\u0437\u043b\u043e\u0432\u0438\u0439 \u043f\u043e\u0441\u0442", "snippet_en": "\u26a1\ufe0f 30.04.2026, \u0443\u0434\u0430\u0440 \u043f\u043e \u0437\u0430\u0432\u043e\u0434\u0443 \u0456\u043c\u0435\u043d\u0456 \u042f.\u041c. \u0421\u0432\u0435\u0440\u0434\u043b\u043e\u0432\u0430 (\u0414\u0437\u0435\u0440\u0436\u0438\u043d\u0441\u044c\u043a, \u041d\u0438\u0436\u0435\u0433\u043e\u0440\u043e\u0434\u0441\u044c\u043a\u0430 \u043e\u0431\u043b.) \u0414\u0432\u043e\u043c\u0430 \u0411\u041f\u041b\u0410 \u0410\u041d-196 \"\u041b\u044e\u0442\u0438\u0439\" \u0443\u0440\u0430\u0436\u0435\u043d\u043e \u0434\u0432\u0430 \u0446\u0435\u0445\u0438 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u0430 \u0432\u0438\u0431\u0443\u0445\u0456\u0432\u043a\u0438 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f. \u0417\u0430\u0432\u043e\u0434 \u0456\u043c\u0435\u043d\u0456 \u0421\u0432\u0435\u0440\u0434\u043b\u043e\u0432\u0430 - \u043e\u0434\u043d\u0435 \u0437 \u043d\u0430\u0439\u0431\u0456\u043b\u044c\u0448\u0438\u0445 \u043f\u0456\u0434\u043f\u0440\u0438\u0454\u043c\u0441\u0442\u0432 \u0440\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u043e\u0433\u043e \u0412\u041f\u041a \u0443 \u0441\u0435\u0433\u043c\u0435\u043d\u0442\u0456 \u043f\u0440\u043e\u043c\u0438\u0441\u043b\u043e\u0432\u0438\u0445 \u0456 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u0438\u0445 \u0432\u0438\u0431\u0443\u0445\u043e\u0432\u0438\u0445 \u0440\u0435\u0447\u043e\u0432\u0438\u043d. \u0412\u0438\u0440\u043e\u0431\u043b\u044f\u0454 \u0442\u0440\u043e\u0442\u0438\u043b, \u0433\u0435\u043a\u0441\u043e\u0433\u0435\u043d, \u043e\u043a\u0442\u043e\u0433\u0435\u043d \u0442\u0430 \u0441\u043f\u043e\u0440\u044f\u0434\u0436\u0430\u0454 \u0431\u043e\u0454\u043f\u0440\u0438\u043f\u0430\u0441\u0438 \u0434\u043b\u044f \u043f\u043e\u0442\u0440\u0435\u0431 \u0430\u0440\u043c\u0456\u0457. \u0424\u0430\u043a\u0442\u0438\u0447\u043d\u043e - \u0432\u0443\u0437\u043b\u043e\u0432\u0438\u0439 \u043f\u043e\u0441\u0442", "link": "https://t.me/VictoryDrones2023/26790", "pubDate": "2026-05-05T12:31:36+00:00"}, {"channel": "lost_armour", "snippet": "\ud83d\udd34 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0434\u0435\u043d\u044c \u0437\u0430 \u0434\u043d\u0435\u043c&#33; \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0437\u0430 5 \u043c\u0430\u044f 2026 \u0433\u043e\u0434\u0430 \u2022 \u0414\u043e\u043d\u0431\u0430\u0441\u0441 \u2022 \u041a\u0440\u0430\u0441\u043d\u043e\u043b\u0438\u043c\u0430\u043d\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0421\u0443\u043c\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0411\u0435\u043b\u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0436\u0438\u0432\u043e\u0439 \u0441\u0438\u043b\u044b \u0412\u0421\u0423 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423 \u2022 \u0414\u0430\u043b\u044c\u043d\u0438\u0435 \u0443\u0434\u0430\u0440\u044b \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u043f\u043e \u0446\u0435\u043b\u044f\u043c \u0412\u0421\u0423 \u2022 \u0412\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0441 \u0412\u041a\u0421 \u0420\u0424 \u043f\u043e \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u044e \u041f\u0423 \u0411\u041f\u041b\u0410 \u0412\u0421\u0423 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u043e \u0446\u0435\u043b\u0435\u0439: 256 - \u0432\u043d\u0443\u0442\u0440\u0438\u0434\u043d\u0435\u0432\u043d\u043e\u0439 \u0440\u0435\u043a\u043e\u0440\u0434&#33; \ud83d\udd34 Rutube \ud83d\udc4a \u0421\u0442\u0430\u0442\u0438", "snippet_en": "\ud83d\udd34 \"\u0420