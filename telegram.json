\u043b\u0435\u0436\u0438\u0442\u044c \u0436\u0438\u0442\u0442\u044f \u043f\u0456\u0445\u043e\u0442\u0438\u00bb \u041f\u0440\u0438\u043a\u0440\u0438\u0432\u0430\u0442\u0438 \u043f\u0456\u0445\u043e\u0442\u0443, \u0440\u043e\u0437\u043d\u043e\u0441\u0438\u0442\u0438 \u0432\u043e\u0440\u043e\u0436\u0443 \u0442\u0435\u0445\u043d\u0456\u043a\u0443, \u0443\u043a\u0440\u0438\u0442\u0442\u044f \u0456 \u043a\u043e\u0441\u0438\u0442\u0438 \u0436\u0438\u0432\u0443 \u0441\u0438\u043b\u0443 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u2014 \u0437\u0430\u0432\u0434\u0430\u043d\u043d\u044f \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0456\u0432 \u0434\u0440\u043e\u043d\u0456\u0432 \u0422\u0440\u0456\u0439\u043a\u0438. \u041e\u0433\u043b\u044f\u0434 \u043d\u0430 \u043f\u0440\u043e\u0444\u0435\u0441\u0456\u044e \u00ab\u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440 FPV\u00bb \u0440\u043e\u0431\u0438\u0442\u044c \u0434\u0440\u0443\u0433 \u0411\u0454\u0441, \u043a\u043e\u043c\u0430\u043d\u0434\u0438\u0440 \u0435\u043a\u0456\u043f\u0430\u0436\u0443 FPV \u00abPNK group\u00bb \u0440\u043e\u0442\u0438 \u00abChaos company\u00bb 2-\u0433\u043e \u043c\u0435\u0445\u0431\u0430\u0442\u0443 \u0422\u0440\u0435\u0442\u044c\u043e\u0457 \u0448\u0442\u0443\u0440\u043c\u043e\u0432\u043e\u0457 \u043d\u0430 \u0440\u0430\u0445\u0443\u043d\u043a\u0443 \u044f\u043a\u043e\u0433\u043e \u0432\u0436\u0435 \u043f\u043e\u043d\u0430\u0434 \u0441\u043e\u0442\u043d\u044f \u043b\u0456\u043a\u0432\u0456\u0434\u043e\u0432\u0430\u043d\u0438\u0445 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432. \u041f\u0440\u043e \u043d\u0430\u0432\u0447\u0430\u043d\u043d\u044f \u0442\u0430 \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u0443\u0432\u0430\u043d\u043d\u044f \u0434\u043e\u0441\u0432\u0456\u0434\u0443, \u0440\u043e\u0431\u043e\u0442\u0443 \u0432 \u043f\u043e\u0433\u0430\u043d\u0443 \u043f", "snippet_en": "\u00ab\u0412\u0456\u0434 \u043d\u0430\u0441 \u0437\u0430\u043b\u0435\u0436\u0438\u0442\u044c 