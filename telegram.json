3e\u043c\u0443 \u0434\u0435\u0441\u044f\u0442\u043a\u0438 \u0442\u0430\u043a\u0438\u0445 \u0411\u041f\u041b\u0410 \u043a\u0440\u0443\u0436\u043b\u044f\u043b\u0438 \u043d\u0430\u0434 \u043d\u0430\u0448\u043e\u044e \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0454\u044e. \u0412\u0438\u0433\u043b\u044f\u0434\u0430\u0454 \u0446\u0435, \u044f\u043a \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u043e \u043d\u0430 ", "snippet_en": "\u0412\u0447\u043e\u0440\u0430\u0448\u043d\u044f \u0430\u0442\u0430\u043a\u0430 \u0411\u041f\u041b\u0410 \u043d\u0430 \u041a\u0438\u0457\u0432\u0441\u044c\u043a\u0443 \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u0432\u0456\u0434\u0440\u0456\u0437\u043d\u044f\u043b\u0430\u0441\u044f \u0432\u0456\u0434 \u0437\u0432\u0438\u0447\u0430\u0439\u043d\u0438\u0445. \u0423 \u043a\u0456\u043b\u044c\u043a\u043e\u0445 \u0440\u0430\u0439\u043e\u043d\u0430\u0445 \u043b\u044e\u0434\u0438 \u0437\u0432\u0435\u0440\u043d\u0443\u043b\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u043d\u0435 \u0442\u0438\u043f\u043e\u0432\u0438\u0439 \u0432\u0438\u0433\u043b\u044f\u0434 \u0411\u041f\u041b\u0410. \u041f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a, \u043f\u0456\u0441\u043b\u044f \u0442\u0440\u0438\u0432\u0430\u043b\u043e\u0457 \u043f\u0435\u0440\u0435\u0440\u0432\u0438 \u0432 \u043a\u0456\u043b\u044c\u043a\u0430 \u043c\u0456\u0441\u044f\u0446\u0456\u0432, \u043c\u0430\u0441\u043e\u0432\u043e \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u0432\u0430\u0432 \u0411\u041f\u041b\u0410 \u0456\u043c\u0456\u0442\u0430\u0442\u043e\u0440\u0438 \u00ab\u041f\u0430\u0440\u043e\u0434\u0456\u044f\u00bb. \u0421\u0430\u043c\u0435 \u0439\u043e\u0433\u043e \u0439 \u0431\u0430\u0447\u0438\u043b\u0438 \u043c\u0435\u0448\u043a\u0430\u043d\u0446\u0456 \u043a\u0440\u0430\u0457\u043d\u0438. \u0417\u0430\u0432\u0434\u0430\u043d\u043d\u044f \u0442\u0430\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u2014 \u0432\u0456\u0434\u0432\u043e\u043b\u0456\u043a\u0430\u0442\u0438 \u0443\u0432\u