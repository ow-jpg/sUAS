0440\u0430\u0441\u0446\u0432\u0435\u0442\u043a\u0435 \u043a\u0430\u043c\u0443\u0444\u043b\u044f\u0436\u0430. \u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u0441\u043a\u0438\u043c \u0423\u043a\u0430\u0437\u043e\u043c \u043d\u0430 \u0434\u043e\u043b\u0436\u043d\u043e\u0441\u0442\u044c \u0437\u0430\u043c\u0433\u043b\u0430\u0432\u044b \u043e\u0431\u043e\u0440\u043e\u043d\u043d\u043e\u0433\u043e \u0432\u0435\u0434\u043e\u043c\u0441\u0442\u0432\u0430 \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d \u0414\u043c\u0438\u0442\u0440\u0438\u0439 \u0429\u0435\u0440\u0431\u0438\u043d\u0438\u043d, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u0432\u0435\u0447\u0430\u0442\u044c \u0437\u0430 \u0446\u0438\u0444\u0440\u043e\u0432\u0443\u044e \u0442\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u0432\u0435\u0434\u043e\u043c\u0441\u0442\u0432\u0430. \u0418 \u0433\u043b\u0430\u0432\u043d\u043e\u0435 \u2014 \u0437\u0430 \u0435\u0434\u0438\u043d\u0443\u044e \u0446\u0438\u0444\u0440\u043e\u0432\u0443\u044e \u0441\u0440\u0435\u0434\u0443. \u0418 \u043f\u0435\u0440\u0432\u0430\u044f \u043c\u044b\u0441\u043b\u044c \u2014 \u043d\u0430\u043a\u043e\u043d\u0435\u0446-\u0442\u043e&#33; \u042d\u0442\u043e \u0432\u0435\u0434\u044c \u0442\u043e, \u0447\u0435\u0433\u043e \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u043b\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0438\u0442\u044c \u0438 \u0443\u043c\u044b, \u0438 \u0440\u0435\u0441\u0443\u0440\u0441\u044b, \u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438, \u043a\u043e\u0442\u043e\u0440", "snippet_en": "\u0412 \u041c\u0438\u043d\u043e\u0431\u043e\u0440\u043e\u043d\u044b \u043f\u043e\u044f\u0432\u0438\u043b\u0441\u044f \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u043f\u043e \u00ab\u0446\u0438\u0444\u0440\u0435\u00bb \u0418 \u0440\u0435\u0447\u044c, \u043a\u043e\u043d\u0435\u0447\u043d\u043e, \u043d\u0435 \u043e \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u043a\u0435 \u043a\u0430\u043c\u0443\u0444\u043b\u044f\u0436\u0430. \u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u0441\u043a\u0438\u043c \u0423\u043a\u0430\u0437\u043e\u043c \u043d\u0430 \u0434\u043e\u043b\u0436\u043d\u043e\u0441\u0442\u044c \u0437\u0430\u043c\u0433\u043b\u0430\u0432\u044b \u043e\u0431\u043e\u0440\u043e\u043d\u043d\u043e\u0433\u043e \u0432\u0435\u0434\u043e\u043c\u0441\u0442\u0432\u0430 \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d \u0414\u043c\u0438\u0442\u0440\u0438\u0439 \u0429\u0435\u0440\u0431\u0438\u043d\u0438\u043d, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u0432\u0435\u0447\u0430\u0442\u044c \u0437\u0430 \u0446\u0438\u0444\u0440\u043e\u0432\u0443\u044e \u0442\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u0432\u0435\u0434\u043e\u043c\u0441\u0442\u0432\u0430. \u0418 \u0433\u043b\u0430\u0432\u043d\u043e\u0435 \u2014 \u0437\u0430 \u0435\u0434\u0438\u043d\u0443\u044e \u0446\u0438\u0444\u0440\u043e\u0432\u0443\u044e \u0441\u0440\u0435\u0434\u0443. \u0418 \u043f\u0435\u0440\u0432\u0430\u044f \u043c\u044b\u0441\u043b\u044c \u2014 \u043d\u0430\u043a\u043e\u043d\u0435\u0446-\u0442\u043e&#33; \u042d\u0442\u043e \u0432\u0435\u0434\u044c \u0442\u043e, \u0447\u0435\u0433\u043e \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u043b\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0438\u0442\u044c \u0438 \u0443\u043c\u044b, \u0438 \u0440\u0435\u0441\u0443\u0440\u0441\u044b, \u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438, \u043a\u043e\u0442\u043e\u0440", "link": "https://t.me/VictoryDrones/55490", "pubDate": "2026-05-08T21:30:45+00:00"}, {"channel": "VictoryDrones2023", "snippet": "\ud83d\ude2c \u0421\u0411\u0421 \u0437\u043d\u0438\u0449\u0438\u043b\u0438 \u0440\u043e\u0441\u0456\u0439\u0441\u0