u0434\u0438\u043d \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440 \u2014 \u043e\u0434\u0438\u043d \u0434\u0440\u043e\u043d\u201d \u2192 \u0434\u043e \u201c\u043e\u0434\u0438\u043d \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440 \u2014 \u0434\u0435\u0441\u044f\u0442\u043a\u0438/\u0441\u043e\u0442\u043d\u0456\u201d \u0417\u0430\u0440\u0430\u0437 \u043a\u0435\u0440\u0443\u0432\u0430\u043d\u043d\u044f \u0434\u0440\u043e\u043d\u0430\u043c\u0438 \u0432\u0438\u043c\u0430\u0433\u0430\u0454 \u0431\u0430\u0433\u0430\u0442\u043e \u043b\u044e\u0434\u0435\u0439 \u0420\u043e\u0457 \u0434\u043e\u0437\u0432\u043e\u043b\u044f\u044e\u0442\u044c \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u0443\u0432\u0430\u0442\u0438 \u0441\u0438\u043b\u0443 \u0431\u0435\u0437 \u0437\u0431\u0456\u043b\u044c\u0448\u0435\u043d\u043d\u044f \u043f\u0435\u0440", "snippet_en": "\u0421\u0442\u0430\u0442\u0442\u044f \u0432 The Economist \u2014 \u043a\u043e\u0440\u043e\u0442\u043a\u043e, \u0430\u043b\u0435 \u043f\u043e \u0441\u0443\u0442\u0456: \ud83e\udde0 \u0413\u043e\u043b\u043e\u0432\u043d\u0430 \u0456\u0434\u0435\u044f \u0410\u0432\u0442\u043e\u043d\u043e\u043c\u043d\u0456 \u0440\u043e\u0457 \u0434\u0440\u043e\u043d\u0456\u0432 \u2014 \u0446\u0435 \u043d\u0430\u0441\u0442\u0443\u043f\u043d\u0438\u0439 \u0435\u0442\u0430\u043f \u0432\u0456\u0439\u043d\u0438. \u041d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u0431\u0430\u0433\u0430\u0442\u043e \u0411\u041f\u041b\u0410, \u0430 \u0441\u0438\u0441\u0442\u0435\u043c\u0438, \u044f\u043a\u0456 \u0441\u0430\u043c\u0456 \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0443\u044e\u0442\u044c\u0441\u044f, \u043e\u0431\u043c\u0456\u043d\u044e\u044e\u0442\u044c\u0441\u044f \u0434\u0430\u043d\u0438\u043c\u0438 \u0456 \u0440\u0430\u0437\u043e\u043c \u0430\u0442\u0430\u043a\u0443\u044e\u0442\u044c \u0446\u0456\u043b\u044c. \u2699\ufe0f \u0429\u043e \u0441\u0430\u043c\u0435 \u0437\u043c\u0456\u043d\u044e\u0454\u0442\u044c\u0441\u044f 1. \u0412\u0456\u0434 \u201c\u043e\u0434\