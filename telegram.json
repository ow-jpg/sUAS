e\u0433\u043e FPV-\u0434\u0440\u043e\u043d\u0430 \"\u041a\u0412\u041d\" \u043c\u0435\u0442\u043e\u0434\u0438\u0447\u043d\u043e \u0432\u044b\u0432\u043e\u0434\u0438\u0442 \u0438\u0437 \u0441\u0442\u0440\u043e\u044f \u0442\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0442\u043e\u0440 35 \u043a\u0412 \u043d\u0430 \u041f\u0421 \"\u041a\u0430\u043c\u044b\u0448\u0435\u0432\u0430\u0445\u0430\" \u0432 \u0417\u0430\u043f\u043e\u0440\u043e\u0436\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438, \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u044e\u0449\u0438\u0439 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u0441\u043d\u0430\u0431\u0436\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u043d\u0430 \u041e\u0440\u0435\u0445\u043e\u0432\u0441\u043a\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438. \u041f\u0435\u0440\u0432\u044b\u043c \u0443\u0434\u0430\u0440\u043e\u043c \u043f\u0438\u043b\u043e\u0442 \u0441\u043d\u0438\u043c\u0430\u0435\u0442 \u0437\u0430\u0449\u0438\u0442\u043d\u0443\u044e \u0441\u0435\u0442\u043a\u0443, \u0432\u0442\u043e\u0440\u044b\u043c - \u043f\u043e\u0440\u0430\u0436\u0430\u0435\u0442 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \ud83d\udccd\u0413\u0435\u043e\u043f\u0440\u0438\u0432\u044f\u0437\u043a\u0430 \ud83d\udd39\u041c\u044b \u0432 MAX", "snippet_en": "\u0420\u0430\u0437\u0434\u0435\u043b\u0430\u043b\u0438 \u043f\u043e\u0434 \u043e\u0440\u0435\u0445 \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440 \u043e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u043e\u0433\u043e FPV-\u0434\u0440\u043e\u043d\u0430 \"\u041a\u0412\u041d\" \u043c\u0435\u0442\u043e\u0434\u0438\u0447\u043d\u043e \u0432\u044b\u0432\u043e\u0434\u0438\u0442 \u0438\u0437 \u0441\u0442\u0440\u043e\u044f \u0442\u0440\u0430\u043d\u0441\u