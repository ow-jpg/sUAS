39 \u0440\u0456\u0432\u0435\u043d\u044c \u2014 \u0446\u0435 \u0431\u0430\u0437\u043e\u0432\u0456 \u043f\u043e\u043b\u044c\u043e\u0442\u0438 \u0443 \u0441\u0438\u043c\u0443\u043b\u044f\u0442\u043e\u0440\u0456 LiftOff. \u041d\u0430\u0441\u0442\u0443\u043f\u043d\u0438\u0439 \u043a\u0440\u043e\u043a \u2014 \u0441\u043f\u0435\u0446\u0456\u0430\u043b\u0456\u0437\u043e\u0432\u0430\u043d\u0456 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u0456 \u0441\u0438\u043c\u0443\u043b\u044f\u0442\u043e\u0440\u0438 UFDS \u0442\u0430 \u00ab\u041e\u0431\u0440\u0456\u0439\u00bb, \u044f\u043a\u0456 \u0432\u0438\u043a", "snippet_en": "\u041d\u0430\u0432\u0447\u0430\u043b\u044c\u043d\u0438\u0439 \u0446\u0435\u043d\u0442\u0440 WeTrueGun \u0440\u043e\u0437\u0440\u043e\u0431\u0438\u0432 \u0434\u043b\u044f \u0432\u043b\u0430\u0441\u043d\u0438\u0445 \u043f\u043e\u0442\u0440\u0435\u0431 \u0441\u043f\u0435\u0446\u0456\u0430\u043b\u044c\u043d\u0443 \u0432\u0435\u0440\u0441\u0456\u044e FPV-\u0441\u0438\u043c\u0443\u043b\u044f\u0442\u043e\u0440\u0430 \u0437 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0430\u043c\u0438 \u0431\u043e\u0439\u043e\u0432\u043e\u0433\u043e \u0441\u0435\u0440\u0435\u0434\u043e\u0432\u0438\u0449\u0430. \u041f\u0440\u043e\u0454\u043a\u0442 \u043e\u0442\u0440\u0438\u043c\u0430\u0432 \u043d\u0430\u0437\u0432\u0443 Seek & Destroy. https://www.youtube.com/watch?v=x8FjKPmIiCQ \u0417\u0430\u0437\u0432\u0438\u0447\u0430\u0439 \u043a\u0443\u0440\u0441\u0430\u043d\u0442\u0438 WeTrueGun \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442\u044c \u043a\u0456\u043b\u044c\u043a\u0430 \u0435\u0442\u0430\u043f\u0456\u0432 \u043f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438. \u041f\u0435\u0440\u0448\u0438\u0439 \u0440\u0456\u0432\u0435\u043d\u044c \u2014 \u0446\u0435 \u0431\u0430\u0437\u043e\u0432\u0456 \u043f\u043e\u043b\u044c\u043e\u0442\u0438 \u0443 \u0441\u0438\u043c\u0443\u043b\u044f\u0442\u043e\u0440\u0456 LiftOff. \u041d\u0430\u0441\u0442\u0443\u043f\u043d\u0438\u0439 \u043a\u04