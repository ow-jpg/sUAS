4\u0456\u043e\u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0457 \u0431\u043e\u0440\u043e\u0442\u044c\u0431\u0438 \u043d\u0430 \u0432\u0435\u0440\u0442\u043e\u043b\u044c\u043e\u0442\u0438 \u043f\u0440\u043e\u0442\u0438 FPV. \u0426\u044f \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u0430 \u044f\u043a \u0434\u043b\u044f \u043d\u0430\u0441, \u0442\u0430\u043a \u0456 \u0434\u043b\u044f \u0432\u043e\u0440\u043e\u0433\u0430. \u0414\u043e\u0432\u0433\u0438\u0439 \u0447\u0430\u0441 \u0443 \u043d\u0430\u0441 \u0446\u0435 \u043f\u0438\u0442\u0430\u043d\u043d\u044f \u0431\u0443\u043b\u043e \u0444\u0430\u043a\u0442\u0438\u0447\u043d\u043e \u0431\u0435\u0437 \u0440\u0456\u0448\u0435\u043d\u043d\u044f, \u043e\u0441\u043a\u0456\u043b\u044c\u043a\u0438 \u0432\u0435\u0440\u0442\u043e\u043b\u0456\u0442 \u0446\u0435 \u043d\u0435 \u0411\u0422\u0420, \u0456 \u043d\u0430 \u043d\u044c\u043e\u0433\u043e \u043d\u0435 \u043c\u043e\u0436\u043d\u0430 \u0431\u0443\u043b\u043e \u0448\u0432\u0438\u0434\u043a\u043e \u0449\u043e\u0441\u044c \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0438 \u0447\u0435\u0440\u0435\u0437 \u0442\u0440\u0438\u0432\u0430\u043b\u0438\u0439 \u0446\u0438\u043a\u043b \u0443\u0437\u0433\u043e\u0434\u0436\u0435\u043d\u044c.", "snippet_en": "\u041a\u0430\u0436\u0443\u0442\u044c, \u0449\u043e \u0432 \u0420\u0424 \u043f\u043e\u0447\u0430\u043b\u0438 \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u044e\u0432\u0430\u0442\u0438 \u0437\u0430\u0441\u043e\u0431\u0438 \u0440\u0430\u0434\u0456\u043e\u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0457 \u0431\u043e\u0440\u043e\u0442\u044c\u0431\u0438 \u043d\u0430 \u0432\u0435\u0440\u0442\u043e\u043b\u044c\u043e\u0442\u0438 \u043f\u0440\u043e\u0442\u0438 FPV. \u0426\u044f \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u0430 \u044f\u043a \u0434\u043b\u044f \u043d\u0430\u0441, \u0442\u0430\u043a \u0456 \u0434\u043b\u044f \u0432\u043e\u0440\u043e\u0433\u0430. \u0414\u043e\u0432\u0433\u0438\u0439 \u0447\u0430\u0441 \u0443 \u043d\u0430\u0441 \u0446\u0435 \u043f\u0438\u0442\u0430\u043d\u043d\u044f \u0431\u0443\u043b\u043e \u0444\u0430\u043a\u0442\u0438\u0447\u043d\u043e \u0431\u0435\u0437 \u0440\u0456\u0448\u0435\u043d\u043d\u044f, \u043e\u0441\u043a\u0456\u043b\u044c\u043a\u0438 \u0432\u0435\u0440\u0442\u043e\u043b\u0456\u0442 \u0446\u0435 \u043d\u0435 \u0411\u0422\u0420, \u0456 \u043d\u0430 \u043d\u044c\u043e\u0433\u043e \u043d\u0435 \u043c\u043e\u0436\u043d\u0430 \u0431\u0443\u043b\u043e \u0448\u0432\u0438\u0434\u043a\u043e \u0449\u043e\u0441\u044c \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0438 \u0447\u0435\u0440\u0435\u0437 \u0442\u0440\u0438\u0432\u0430\u043b\u0438\u0439 \u0446\u0438\u043a\u043b \u0443\u0437\u0433\u043e\u0434\u0436\u0435\u043d\u044c.", "link": "https://t.me/serhii_flash/7502", "pubDate": "2026-06-20T14:11:37+00:00"}, {"channel": "combat_ftg2", "snippet": "The Russians managed to destroy an entire bridge using ordinary FPV drones. Enemy drone operators used 43 FPV drones to destroy the concrete supports of a bridge over the Nitrius River in the Kharkiv region.", "snippet_en": "The Russians managed to destroy an entire bridge using ordinary FPV drones. Enemy drone operators used 43 FPV drones to destroy the concrete supports of a bridge over the Nitrius River in the Kharkiv region.", "link": "https://t.me/combat_ftg2/3611", "pubDate": "2026-06-17T06:40:20+00:00"}, {"channel": "serhii_flash", "snippet": "\u041d\u0430 \u043f\u0456\u0432\u0434\u043d\u0456 \u043a\u0440\u0430\u0457\u043d\u0438 \u0444\u0456\u043a\u0441\u0443\u0454\u043c\u043e \u043f\u043e\u044f\u0432\u0443 \u0441\u0435\u0440\u0456\u0439\u043d\u043e\u0433\u043e \u043d\u043e\u0432\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u043d\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0456\u044f \u0411\u041f\u041b\u0410 \u2014 \u0434\u0435\u0448\u0435\u0432\u0438\u0439 \u043f\u0440\u0438\u043c\u0438\u0442\u0438\u0432\u043d\u044b\u0439 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0439 \u0434\u0440\u043e\u043d. \u0410\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0435 \u0432\u0456\u0434\u0435\u043e \u043d\u0430 \u0447\u0430\u0441\u0442\u043e\u0442\u0456 3,3 \u0413\u0413\u0446. \u0414\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c \u043f\u043e\u043b\u044c\u043e\u0442\u0443 \u0434\u043e 100 \u043a\u0456\u043b\u043e\u043c\u0435\u0442\u0440\u0456\u0432 (\u043f\u043e\u043a\u0438 \u0449\u043e \u0444\u0456\u043a\u0441\u0443\u044e \u0443\u0434\u0430\u0440\u0438 \u043d\u0430 \u0432\u0456\u0434\u0441\u0442\u0430\u043d\u0456 30\u201340 \u043a\u043c \u0432\u0456\u0434 \u043b\u0456\u043d\u0456\u0457 \u0444\u0440\u043e\u043d\u0442\u0443). \u041a\u0440\u0435\u0439\u0441\u0435\u0440\u0441\u044c\u043a\u0430 \u0448\u0432\u0438\u0434\u043a\u0456\u0441\u0442\u044c \u2014 260 \u043a\u043c/\u0433\u043e\u0434, \u0437 \u0440\u043e\u0437\u0433\u043e\u043d\u0430\u043c\u0438 \u0434\u043e 300 \u043a\u043c/\u0433\u043e\u0434 \u0411\u043e\u0439\u043e\u0432\u0430 \u0447\u0430\u0441\u0442\u0438\u043d\u0430 \u2014 \u043f\u0440\u0438\u0431\u043b\u0438\u0437\u043d\u043e 4\u20135 \u043a\u0433 \u041f\u0440\u043e\u0448\u0443 \u0432\u0441\u0456\u0445 \u0437\u0432\u0435\u0440\u043d\u0443\u0442\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u0444\u043e\u0440\u043c\u0430\u0442 \u0432\u0456\u0434\u0435\u043e", "snippet_en": "\u041d\u0430 \u043f\u0456\u0432\u0434\u043d\u0456 \u043a\u0440\u0430\u0457\u043d\u0438 \u0444\u0456\u043a\u0441\u0443\u0454\u043c\u043e \u043f\u043e\u044f\u0432\u0443 \u0441\u0435\u0440\u0456\u0439\u043d\u043e\u0433\u043e \u043d\u043e\u0432\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u043d\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0456\u044f \u041