u0430 \u0441\u0435\u0440\u0439\u043e\u0437\u043d\u0456 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0438 \u0437 \u043b\u043e\u0433\u0456\u0441\u0442\u0438\u043a\u043e\u044e, \u0456 \u0446\u0435 \u043b\u0438\u0448\u0435 \u043f\u043e\u0447\u0430\u0442\u043e\u043a. \u0415\u043a\u0456\u043f\u0430\u0436\u0456 \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u0411\u041f\u041b\u0410 \u0411\u0411\u043f\u0421 \u00abBLACK SKY\u00bb \u0441\u0438\u0441\u0442\u0435\u043c\u043d\u043e \u043f\u0440\u0430\u0446\u044e\u044e\u0442\u044c \u043d\u0430\u0434 \u0442\u0438\u043c, \u0449\u043e\u0431 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0438 \u0437\u0430\u043b\u0438\u0448\u0430\u043b\u0438\u0441\u044c \u0431\u0435\u0437 \u043f\u0456\u0434\u0432\u043e\u0437\u0443 \u0431\u043e\u0454\u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442\u0443, \u043f\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0442\u0430 \u043f\u0456\u0434\u043a\u0440\u0456\u043f\u043b\u0435\u043d\u043d\u044f. \u041a\u043e\u0436\u0435\u043d \u0443\u0440\u0430\u0436\u0435\u043d\u0438\u0439 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u0438\u0439 \u0437\u0430\u0441\u0456\u0431 \u2014 \u0446\u0435 \u0449\u0435 \u043e\u0434\u0438\u043d \u043a\u0440\u043e\u043a \u0434\u043e \u043f\u043e\u0441\u043b\u0430\u0431\u043b\u0435\u043d\u043d\u044f \u0432\u043e\u0440\u043e\u0433\u0430. BLACK SKY: \u043e\u0447\u0456, \u0449\u043e \u0431\u0430\u0447\u0430\u0442\u044c \u0443\u0441\u0435, \u0456 \u0443\u0434\u0430\u0440, \u0432\u0456\u0434 \u044f\u043a\u043e\u0433\u043e \u043d\u0435 \u0441\u0445\u043e\u0432\u0430\u0442\u0438\u0441\u044c. \ud83d\udcf1Instagram \ud83d\udcf1TikTok \ud83c\uddfa\ud83c\udde6\u041f\u0440\u0438\u0454\u0434\u043d\u0430\u0442\u0438\u0441\u044f \u0434\u043e \u043f\u0456\u0434\u0440\u043e\u0437\u0434\u0456\u043b\u0443", "snippet_en": "\u0423 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0441\u0435\u0440\u0439\u043e\u0437\u043d\u0456 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0438 \u0437 \u043b\u043e\u0433\u0456\u0441\u0442\u0438\u043a\u043e\u044e, \u0456 \u0446\u0435 \u043b\u0438\u0448\u0435 \u043f\u043e\u0447\u0430\u0442\u043e\u043a. \u0415\u043a\u0456\u043f\u0430\u0436\u0456 \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u0411\u041f\u041b\u0410 \u0411\u0411\u043f\u0421 \u00abBLACK SKY\u00bb \u0441\u0438\u0441\u0442\u0435\u043c\u043d\u043e \u043f\u0440\u0430\u0446\u044e\u044e\u0442\u044c \u043d\u0430\u0434 \u0442\u0438\u043c, \u0449\u043e\u0431 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0438 \u0437\u0430\u043b\u0438\u0448\u0430\u043b\u0438\u0441\u044c \u0431\u0435\u0437 \u043f\u0456\u0434\u0432\u043e\u0437\u0443 \u0431\u043e\u0454\u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442\u0443, \u043f\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0442\u0430 \u043f\u0456\u0434\u043a\u0440\u0456\u043f\u043b\u0435\u043d\u043d\u044f. \u041a\u043e\u0436\u0435\u043d \u0443\u0440\u0430\u0436\u0435\u043d\u0438\u0439 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u0438\u0439 \u0437\u0430\u0441\u0456\u0431 \u2014 \u0446\u0435 \u0449\u0435 \u043e\u0434\u0438\u043d \u043a\u0440\u043e\u043a \u0434\u043e \u043f\u043e\u0441\u043b\u0430\u0431\u043b\u0435\u043d\u043d\u044f \u0432\u043e\u0440\u043e\u0433\u0430. BLACK SKY: \u043e\u0447\u0456, \u0449\u043e \u0431\u0430\u0447\u0430\u0442\u044c \u0443\u0441\u0435, \u0456 \u0443\u0434\u0430\u0440, \u0432\u0456\u0434 \u044f\u043a\u043e\u0433\u043e \u043d\u0435 \u0441\u0445\u043e\u0432\u0430\u0442\u0438\u0441\u044c. \ud83d\udcf1Instagram \ud83d\udcf1TikTok \ud83c\uddfa\ud83c\udde6\u041f\u0440\u0438\u0454\u0434\u043d\u0430\u0442\u0438\u0441\u044f \u0434\u043e \u043f\u0456\u0434\u0440\u043e\u0437\u0434\u0456\u043b\u0443", "link": "https://t.me/VictoryDrones2023/27538", "pubDate": "2026-06-26T06:17:26+00:00"}, {"channel": "VictoryDrones2023", "snippet": "\u041f\u043e\u043a\u0438 \u0432\u043e\u0440\u043e\u0433 \u043d\u0430\u043c\u0430\u0433\u0430\u0454\u0442\u044c\u0441\u044f \u0434\u0456\u0441\u0442\u0430\u0442\u0438\u0441\u044f \u0441\u0432\u043e\u0457\u0445 \u0446\u0456\u043b\u0435\u0439, \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0438 FPV-\u043f\u0435\u0440\u0435\u0445\u043e\u043f\u043b\u044e\u0432\u0430\u0447\u0456\u0432 \u0448\u0442\u0443\u0440\u043c\u043e\u0432\u043e\u0433\u043e \u043f\u043e\u043b\u043a\u0443 \u00ab\u0421\u0430\u0444\u0430\u0440\u0456\u00bb \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u00ab\u041b\u044e\u0442\u044c\u00bb \u0440\u043e\u0431\u043b\u044f\u0442\u044c \u0441\u0432\u043e\u044e \u0441\u043f\u0440\u0430\u0432\u0443. \u041d\u0430 \u0446\u0438\u0445 \u043a\u0430\u0434\u0440\u0430\u0445 \u2014 \u0447\u0435\u0440\u0433\u043e\u0432\u0430 \u0441\u0435\u0440\u0456\u044f \u0437\u0431\u0438\u0442\u0442\u0456\u0432 \u0432\u043e\u0440\u043e\u0436\u0438\u0445 \u00ab\u041c\u043e\u043b\u043d\u0456\u0439\u00bb. \u0414\u043b\u044f \u043a\u043e\u0433\u043e\u0441\u044c \u0446\u0435 \u043a\u0456\u043b\u044c\u043a\u0430 \u0441\u0435\u043a\u0443\u043d\u0434 \u0432\u0456\u0434\u0435\u043e, \u0430 \u0434\u043b\u044f \u0445\u043b\u043e\u043f\u0446\u0456\u0432 \u2014 \u0449\u043e\u0434\u0435\u043d\u043d\u0430 \u0440\u043e\u0431\u043e\u0442\u0430, \u044f\u043a\u0430 \u0434\u043e\u043f\u043e\u043c\u0430\u0433\u0430\u0454 \u0437\u0431\u0435\u0440\u0435\u0433\u0442\u0438 \u0436\u0438\u0442\u0442\u044f. \u0429\u0435 \u043a\u0456\u043b\u044c\u043a\u0430 \u0432\u043e\u0440\u043e\u0436\u0438\u0445 \u0411\u043f\u041b\u0410 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043b\u0438 \u0441\u0432\u0456\u0439 \u043f\u043e\u043b\u0456\u0442 \u0437\u043d\u0430\u0447\u043d\u043e \u0440\u0430\u043d\u0456\u0448\u0435, \u043d\u0456\u0436 \u043f\u043b\u0430\u043d\u0443\u0432\u0430\u0432 \u0432\u043e\u0440\u043e\u0433. \u041f\u0440\u0430\u0446\u044e\u0454\u043c\u043e&#33; \ud83d\udee1 \u0410\u041d\u041a\u0415\u0422\u0410 | Instag", "snippet_en": "\u041f\u043e\u043a\u0438 \u0432\u043e\u0440\u043e\u0433 \u043d\u0430\u043c\u0430\u0433\u0430\u0454\u0442\u044c\u0441\u044f \u0434\u0456\u0441\u0442\u0430\u0442\u0