a\u0438\u0445 \u0411\u043f\u041b\u0410 \u0442\u0430 \u0435\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0456\u0457 \u0456\u043d\u043e\u0437\u0435\u043c\u043d\u0438\u0445 \u0433\u0440\u043e\u043c\u0430\u0434\u044f\u043d \u0443 \u0432\u0456\u0439\u043d\u0456 \u043f\u0440\u043e\u0442\u0438 \u0423\u043a\u0440\u0430\u0457\u043d\u0438. \u25b6\ufe0f \u0414\u043e \u0441\u0430\u043d\u043a\u0446\u0456\u0439\u043d\u043e\u0433\u043e \u043f\u0435\u0440\u0435\u043b\u0456\u043a\u0443 \u0432\u043d\u0435\u0441\u0435\u043d\u043e 35 \u043e\u0441\u0456\u0431 \u0442\u0430 \u043e\u0440\u0433\u0430\u043d\u0456\u0437\u0430\u0446\u0456\u0439, \u044f\u043a\u0456 \u0437\u0430\u0431\u0435\u0437\u043f\u0435\u0447\u0443\u044e\u0442\u044c \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043d\u043d\u044f \u0434\u043e \u0440\u0444 \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u0456\u0432 \u0434\u043b\u044f \u0411\u043f\u041b\u0410 \u0442\u0430 \u0456\u043d\u0448\u0438\u0445 \u043a\u0440\u0438\u0442\u0438\u0447\u043d\u043e \u0432\u0430\u0436\u043b\u0438\u0432", "snippet_en": "1\ufe0f\u20e32\ufe0f\u20e33\ufe0f\u20e34\ufe0f\u20e35\ufe0f\u20e3\u041d\u043e\u0432\u0456 \u0441\u0430\u043d\u043a\u0446\u0456\u0457 \u0412\u0435\u043b\u0438\u043a\u043e\u0457 \u0411\u0440\u0438\u0442\u0430\u043d\u0456\u0457 \u043f\u0440\u043e\u0442\u0438 \u0440\u043e\u0441\u0456\u0457 \u0449\u0435 \u0431\u0456\u043b\u044c\u0448\u0435 \u043f\u043e\u0441\u043b\u0430\u0431\u043b\u044f\u0442\u044c \u0430\u0433\u0440\u0435\u0441\u043e\u0440\u0456\u0432 \u0423\u0440\u044f\u0434 \u0412\u0435\u043b\u0438\u043a\u043e\u0457 \u0411\u0440\u0438\u0442\u0430\u043d\u0456\u0457 \u0437\u0430\u043f\u0440\u043e\u0432\u0430\u0434\u0438\u0432 \u043d\u043e\u0432\u0456 \u043e\u0431\u043c\u0435\u0436\u0435\u043d\u043d\u044f \u043f\u0440\u043e\u0442\u0438 \u043e\u0441\u0456\u0431 \u0442\u0430 \u043e\u0440\u0433\u0430\u043d\u0456\u0437\u0430\u0446\u0456\u0439, \u043f\u0440\u0438\u0447\u0435\u0442\u043d\u0438\u0445 \u0434\u043e \u0432\u043