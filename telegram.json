2\u0430 \u0457\u0457 \u043e\u0446\u0456\u043d\u043a\u0430. \u0422\u043e\u0431\u0442\u043e \u0446\u0435 \u0434\u0456\u0439\u0441\u043d\u043e 14 \u044f\u0440\u0434\u043e\u0432 \u0432\u0442\u0440\u0430\u0442 \u0432\u043e\u0440\u043e\u0433\u0430. \u0426\u0438\u0444\u0440\u0430 \u0432\u0440\u0430\u0436\u0430\u0454. https://t.me/lasars_group/134", "snippet_en": "\u0412\u0456\u0442\u0430\u044e \u0443\u0441\u044e \u043a\u043e\u043c\u0430\u043d\u0434\u0443 \u041b\u0430\u0437\u0430\u0440 \u0413\u0440\u0443\u043f\u043f \u0442\u0430 \u043e\u0441\u043e\u0431\u0438\u0441\u0442\u043e Pavlo Yelizarov \u0423 \u0447\u043e\u043c\u0443 \u043f\u043e\u043b\u044f\u0433\u0430\u0454 \u0432\u0456\u0434\u043c\u0456\u043d\u043d\u0456\u0441\u0442\u044c \u043e\u0446\u0456\u043d\u043a\u0438 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432 \u0440\u043e\u0431\u043e\u0442\u0438 \u0411\u041f\u041b\u0410 \u0432\u0456\u0434 \u0456\u043d\u0448\u0438\u0445 \u043d\u0430\u043f\u0440\u044f\u043c\u043a\u0456\u0432. \u041a\u043e\u0436\u043d\u0435 \u0443\u0440\u0430\u0436\u0435\u043d\u043d\u044f \u0442\u0430 \u0441\u0442\u0443\u043f\u0456\u043d\u044c \u0437\u043d\u0438\u0449\u0435\u043d\u043d\u044f \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0436\u0443\u044e\u0442\u044c\u0441\u044f \u0432\u0456\u0434\u0435\u043e\u0434\u043e\u043a\u0430\u0437\u0430\u043c\u0438, \u043f\u0456\u0441\u043b\u044f \u0447\u043e\u0433\u043e \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u0442\u044c\u0441\u044f \u043d\u0435\u0437\u0430\u043b\u0435\u0436\u043d\u0430 \u0456\u0434\u0435\u043d\u0442\u0438\u0444\u0456\u043a\u0430\u0446\u0456\u044f \u0443\u0440\u0430\u0436\u0435\u043d\u043e\u0457 \u0442\u0435\u0445\u043d\u0456\u043a\u0438 \u0442\u0430 \u0457\u0457 \u043e\u0446\u0456\u043d\u043a\u0430. \u0422\u043e\u0431\u0442\u043e \u0446\u0435 \u0434\u0456\u0439\u0441\u043d\u043e 14 \u044f\u0440\u0434\u043e\u0432 \u0432\u0442\u0440\u0430\u0442 \u0432\u043e\u0440\u043e\u0433\u0430. \u0426\u0438\u0444\u0440\u0430 \u0432\u0440\u0430\u0436\u0430\u0454. https://t.me/lasars_group/134", "link": "https://t.me/serhii_flash/7346", "pubDate": "2026-04-30T09:25:48+00:00"}, {"channel": "serhii_flash", "snippet": "\u0422\u0430\u043a, \u0443 \u043d\u0430\u0441 \u0432\u0436\u0435 \u0432\u0438\u043f\u0440\u043e\u0431\u0443\u0432\u0430\u043d\u0456 \u0456 \u0441\u043a\u043e\u0440\u043e \u043d\u0430\u0434\u0456\u0439\u0434\u0443\u0442\u044c \u043d\u0430 \u0444\u0440\u043e\u043d\u0442 \u043d\u043e\u0432\u0456 \u0442\u0438\u043f\u0438 FPV. \u041f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0443 \u0431\u0443\u0434\u0435 \u0431\u043e\u043b\u044f\u0447\u0435. \u0422\u0430\u043a, \u043c\u0438 \u043d\u0430\u0440\u0435\u0448\u0442\u0456 \u0447\u0435\u0440\u0435\u0437 \u043c\u0456\u0441\u044f\u0446\u044c- \u0434\u0440\u0443\u0433\u0438\u0439 \u0437\u0430\u043a\u0440\u0438\u0454\u043c\u043e \u0437\u043e\u043d\u0443 100-150 \u043a\u0456\u043b\u043e\u043c\u0435\u0442\u0440\u0456\u0432 \u0432\u0456\u0434 \u043a\u043e\u0440\u0434\u043e\u043d\u0456\u0432 \u0443\u0434\u0430\u0440\u043d\u0438\u043c\u0438 \u0411\u041f\u041b\u0410 \u0431\u043b\u0438\u0437\u044c\u043a\u043e\u0457 \u0434\u0456\u0457. \u0422\u0430\u043c \u0443\u0441\u0456 \u00ab\u043d\u0430\u0439\u0441\u043c\u0430\u0447\u043d\u0456\u0448\u0456\u00bb \u0446\u0456\u043b\u0456. \u0422\u0430\u043a, \u0434\u0430\u043b\u0435\u043a\u0438\u0445 \u0443\u0434\u0430\u0440\u0456\u0432 \u0411\u041f\u041b\u0410 \u0431\u0443\u0434\u0435 \u0434\u0435\u0434\u0430\u043b\u0456 \u0431\u0456\u043b\u044c\u0448\u0435. \u0422\u0430\u043a, \u0431\u0443\u0434\u0443\u0442 \u0449\u0435 \u043f\u043e\u0434\u0430\u0440\u0443\u043d\u043a\u0438. \u041d\u0430\u0448\u0430 \u043d\u043e\u0432\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u041c\u041e \u043f\u0440\u0430\u0446\u044e\u0454 \u043d\u0430\u0434 \u0456\u043d\u043e\u0432\u0430\u0446\u0456\u044f\u043c\u0438 \u0442\u0430 \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043d\u043d\u044f\u043c, \u0430 \u043d\u0430\u0448\u0456 \u043a\u0440\u0443\u0442\u0456 \u043a\u043e\u043b\u0435\u0433\u0438 \u0456\u0437 \u0417\u0421\u0423 \u0437\u043d\u0430\u044e\u0442\u044c, \u0449\u043e \u0437", "snippet_en": "\u0422\u0430\u043a, \u0443 \u043d\u0430\u0441 \u0432\u0436\u0435 \u0432\u0438\u043f\u0440\u043e\u0431\u0443\u0432\u0430\u043d\u0456 \u0456 \u0441\u043a\u043e\u0440\u043e \u043d\u0430\u0434\u0456\u0439\u0434\u0443\u0442\u044c \u043d\u0430 \u0444\u0440\u043e\u043d\u0442 \u043d\u043e\u0432\u0456 \u0442\u0438\u043f\u0438 FPV. \u041f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0443 \u0431\u0443\u0434\u0435 \u0431\u043e\u043b\u044f\u0447\u0435. \u0422\u0430\u043a, \u043c\u0438 \u043d\u0430\u0440\u0435\u0448\u0442\u0456 \u0447\u0435\u0440\u0435\u0437 \u043c\u0456\u0441\u044f\u0446\u044c- \u0434\u0440\u0443\u0433\u0438\u0439 \u0437\u0430\u043a\u0440\u0438\u0454\u043c\u043e \u0437\u043e\u043d\u0443 100-150 \u043a\u0456\u043b\u043e\u043c\u0435\u0442\u0440\u0456\u0432 \u0432\u0456\u0434 \u043a\u043e\u0440\u0434\u043e\u043d\u0456\u0432 \u0443\u0434\u0430\u0440\u043d\u0438\u043c\u0438 \u0411\u041f\u041b\u0410 \u0431\u043b\u0438\u0437\u044c\u043a\u043e\u0457 \u0434\u0456\u0457. \u0422\u0430\u043c \u0443\u0441\u0456 \u00ab\u043d\u0430\u0439\u0441\u043c\u0430\u0447\u043d\u0456\u0448\u0456\u00bb \u0446\u0456\u043b\u0456. \u0422\u0430\u043a, \u0434\u0430\u043b\u0435\u043a\u0438\u0445 \u0443\u0434\u0430\u0440\u0456\u0432 \u0411\u041f\u041b\u0410 \u0431\u0443\u0434\u0435 \u0434\u0435\u0434\u0430\u043b\u0456 \u0431\u0456\u043b\u044c\u0448\u0435. \u0422\u0430\u043a, \u0431\u0443\u0434\u0443\u0442 \u0449\u0435 \u043f\u043e\u0434\u0430\u0440\u0443\u043d\u043a\u0438. \u041d\u0430\u0448\u0430 \u043d\u043e\u0432\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u041c\u041e \u043f\u0440\u0430\u0446\u044e\u0454 \u043d\u0430\u0434 \u0456\u043d\u043e\u0432\u0430\u0446\u0456\u044f\u043c\u0438 \u0442\u0430 \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043d\u043d\u044f\u043c, \u0430 \u043d\u0430\u0448\u0456 \u043a\u0440\u0443\u0442\u0456 \u043a\u043e\u043b\u0435\u0433\u0438 \u0456\u0437 \u0417\u0421\u0423 \u0437\u043d\u0430\u044e\u0442\u044c, \u0449\u043e \u0437", "link": "https://t.me/serhii_flash/7340", "pubDate": "2026-04-29T20:31:42+00:00"}, {"channel": "combat_ftg2", "snippet": "Russian soldiers attacked byUkrainian FPV drone", "snippet_en": "Russian soldiers attacked byUkrainian FPV drone", "link": "https://t.me/combat_ftg2/3564", "pubDate": "2026-04-28T11:16:51+00:00"}, {"channel": "lost_armour", "snippet": "\u041e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u0430\u044f \u043a\u0430\u0440\u0443\u0441\u0435\u043b\u044c \u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u0432\u0438\u0434\u0435\u043e \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0438\u044f 155-\u043c\u043c \u0421\u0410\u0423 M109 \u0412\u0421\u0423 \u043d\u0430 \u0417\u0430\u043f\u043e\u0440\u043e\u0436\u0441\u043a\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438 \u0441\u0435\u0440\u0438\u0435\u0439 \u0443\u0434\u0430\u0440\u043e\u0432 \u043e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u044b\u0445 FPV-\u0434\u0440\u043e\u043d\u043e\u0432 \"\u041a\u0412\u041d\" \u0438 \"\u041f\u0440\u043e\u0432\u043e\u0434\". \u0414\u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u0434\u0430\u0436\u0435 \u044d\u043a\u0438\u043f\u0430\u0436\u0443, \u0447\u0442\u043e \u0440\u0435\u0434\u043a\u043e\u0441\u0442\u044c. \u0422\u043e\u0442 \u0441\u043b\u0443\u0447\u0430\u0439, \u043a\u043e\u0433\u0434\u0430 \u043b\u044e\u0431\u043e\u0439 \u0440\u0430\u0441\u0445\u043e\u0434 \u0434\u0440\u043e\u043d\u043e\u0432 \u043e\u043f\u0440\u0430\u0432\u0434\u0430\u043d, \u0435\u0441\u043b\u0438 \u0446\u0435\u043b\u044c \u0432 \u0438\u0442\u043e\u0433\u0435 \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0430. \u041e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u0449\u0438\u043a\u0438 \"\u0411\u0430\u0440\u0441 8\" - \u043a\u0440\u0430\u0441\u0430\u0432\u0446\u044b&#33; \u0418\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0432\u0438\u0434\u0435\u043e: \"\u0420\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0432\u043e\u0435\u043d\u043d\u0430\u044f \u0440\u0430\u0437\u0432\u0435\u0434\u043a\u0430\" \ud83d\udd39 \u041c\u044b \u0432 \u041c\u0410\u0425", "snippet_en": "\u041e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u0430\u044f \u043a\u0430\u0440\u0443\u0441\u0435\u043b\u044c \u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u0432\u0438\u0434\u0435\u043e \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0438\u044f 155-\u043c\u043c \u0421\u0410\u0423 M109 \u0412\u0421\u0423 \u043d\u0430 \u0417\u0430\u043f\u043e\u0440\u043e\u0436\u0441\u043a\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438 \u0441\u0435\u0440\u0438\u0435\u0439 \u0443\u0434\u0430\u0440\u043e\u0432 \u043e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u044b\u0445 FPV-\u0434\u0440\u043e\u043d\u043e\u0432 \"\u041a\u0412\u041d\" \u0438 \"\u041f\u0440\u043e\u0432\u043e\u0434\". \u0414\u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u0434\u0430\u0436\u0435 \u044d\u043a\u0438\u043f\u0430\u0436\u0443, \u0447\u0442\u043e \u0440\u0435\u0434\u043a\u043e\u0441\u0442\u044c. \u0422\u043e\u0442 \u0441\u043b\u0443\u0447\u0430\u0439, \u043a\u043e\u0433\u0434\u0430 \u043b\u044e\u0431\u043e\u0439 \u0440\u0430\u0441\u0445\u043e\u0434 \u0434\u0440\u043e\u043d\u043e\u0432 \u043e\u043f\u0440\u0430\u0432\u0434\u0430\u043d, \u0435\u0441\u043b\u0438 \u0446\u0435\u043b\u044c \u0432 \u0438\u0442\u043e\u0433\u0435 \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0430. \u041e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u0449\u0438\u043a\u0438 \"\u0411\u0430\u0440\u0441 8\" - \u043a\u0440\u0430\u0441\u0430\u0432\u0446\u044b&#33; \u0418\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0432\u0438\u0434\u0435\u043e: \"\u0420\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0432\u043e\u0435\u043d\u043d\u0430\u044f \u0440\u0430\u0437\u0432\u0435\u0434\u043a\u0430\" \ud83d\udd39 \u041c\u044b \u0432 \u041c\u0410\u0425", "link": "https://t.me/s/lost_armour", "pubDate": ""}], "updated": "3 May 2026, 16:38 UTC", "count": 10}