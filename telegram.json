{"posts": [{"channel": "VictoryDrones2023", "snippet": "\u0422\u0440\u0438\u043c\u0430\u044e \u043d\u0430 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0456 \u043f\u0438\u0442\u0430\u043d\u043d\u044f \u0440\u043e\u0442\u0430\u0446\u0456\u0439 \u043d\u0430\u0448\u0438\u0445 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u043e\u0441\u043b\u0443\u0436\u0431\u043e\u0432\u0446\u0456\u0432 \u043d\u0430 \u043f\u0435\u0440\u0435\u0434\u043d\u044c\u043e\u043c\u0443 \u043a\u0440\u0430\u0457. \u0422\u0430\u043a, \u0437\u0430 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430\u043c\u0438 \u0440\u043e\u0431\u043e\u0442\u0438 \u0433\u0440\u0443\u043f \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044e \u043d\u0430\u0440\u0430\u0437\u0456 \u043c\u0430\u0454\u043c\u043e \u0456\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0456\u044e \u043f\u0440\u043e 72% \u0440\u043e\u0442\u0430\u0446\u0456\u0439, \u044f\u043a\u0456 \u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u0456 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u043d\u043e \u0434\u043e \u043d\u0430\u043a\u0430\u0437\u0443 \u043f\u0440\u043e \u0437\u0430\u0431\u0435\u0437\u043f\u0435\u0447\u0435\u043d\u043d\u044f \u043f\u0435\u0440\u0435\u0431\u0443\u0432\u0430\u043d\u043d\u044f \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u043e\u0441\u043b\u0443\u0436\u0431\u043e\u0432\u0446\u0456\u0432 \u043d\u0430 \u043f\u043e\u0437\u0438\u0446\u0456\u044f\u0445 \u0442\u0435\u0440\u043c\u0456\u043d\u043e\u043c \u043d\u0435 \u0431\u0456\u043b\u044c\u0448 \u044f\u043a \u0434\u0432\u0430 \u043c\u0456\u0441\u044f\u0446\u0456. \u0412\u043e\u0434\u043d\u043e\u0447\u0430\u0441 \u0454 \u0431\u0440\u0438\u0433\u0430\u0434\u0438, \u044f\u043a\u0456 \u043d\u0435 \u0441\u043f\u0440\u043e\u043c\u043e\u0433\u043b\u0438\u0441\u044f \u0437\u0434\u0456\u0439\u0441\u043d\u0438\u0442\u0438 \u0442\u0430\u043a\u0456 \u0437\u043c\u0456\u043d\u0438. \u0406 \u0454 \u043f\u043e \u0417\u0431\u0440\u043e\u0439\u043d\u0438\u0445 \u0421\u0438\u043b\u0430\u044