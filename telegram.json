443\u0434\u0443\u0442\u044c \u043f\u043e\u0432\u043d\u0456\u0441\u0442\u044e \u0430\u0432\u0442\u043e\u043d\u043e\u043c\u043d\u0456. \u0420\u0430\u043d\u0456\u0448\u0435 \u0442\u0430\u043a\u0456 \u0440\u0456\u0448\u0435\u043d\u043d\u044f \u043c\u0438 \u0444\u0456\u043a\u0441\u0443\u0432\u0430\u043b\u0438 \u043b\u0438\u0448\u0435 \u043d\u0430 \u0411\u041f\u041b\u0410 V2. \u042f \u043d\u0435\u043e\u0434\u043d\u043e\u0440\u0430\u0437\u043e\u0432\u043e \u043f\u0438\u0441\u0430\u0432, \u0449\u043e \u0446\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u043d\u0430 \u0431\u0430\u0437\u0456 V2U \u043d\u0430\u0432\u0447\u0430\u0454 \u043d\u0435\u0439\u0440\u043e\u043d\u043d\u0443 \u043c\u0435\u0440\u0435\u0436\u0443. \u0421\u044c\u043e\u0433\u043e\u0434\u043d\u0456 \u043c\u0438 \u0432\u0438\u044f\u0432\u0438\u043b\u0438 \u0442\u0430\u043a\u0435 \u0440\u0456\u0448\u0435\u043d\u043d\u044f \u043d\u0430 \u00ab\u041c\u043e\u043b\u043d\u0456\u0457\u00bb. \u0426\u0435 \u043f\u043e\u0433\u0430\u043d\u0438\u0439 \u0437\u043d\u0430\u043a. \u042f \u0437\u043d\u043e\u0432\u0443 \u0437\u0432\u0435\u0440\u0442\u0430\u044e\u0441\u044f \u0434\u043e ", "snippet_en": "\u0420\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u0438\u0439 \u0411\u041f\u041b\u0410 \u00ab\u041c\u043e\u043b\u043d\u0456\u044f\u00bb \u0431\u0435\u0437 \u0436\u043e\u0434\u043d\u043e\u0457 \u0430\u043d\u0442\u0435\u043d\u0438 \u0443\u043f\u0440\u0430\u0432\u043b\u0456\u043d\u043d\u044f \u0430\u0442\u0430\u043a\u0443\u0432\u0430\u0432 \u043d\u0430\u0448 \u043e\u0431\u2019\u0454\u043a\u0442. \u0423 \u0411\u041f\u041b\u0410 \u0431\u0443\u043b\u0430 \u043b\u0438\u0448\u0435 \u043a\u0430\u043c\u0435\u0440\u0430 \u0442\u0430 \u043a\u043e\u043c\u043f\u2019\u044e\u0442\u0435\u0440. \u041e\u0441\u044c \u0434\u043e \u0447\u043e\u0433\u043e \u0432\u0441\u0435 \u0439\u0434\u0435. \u041d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u044f, \u043f\u043e\u0448\u0443\u043a \u0446\u0456\u043b\u0456 \u0442\u0430 \u0430\u0442\u0430\u043a\u0430 \u0431\u0443\u0434\u0443\u0442\u044c \u043f\u043e\u0432\u043d\u0456\u0441\u0442\u044e \u0430\u0432\u0442\u043e\u043d\u043e\u043c\u043d\u0456. \u0420\u0430\u043d\u0456\u0448\u0435 \u0442\u0430\u043a\u0456 \u0440\u0456\u0448\u0435\u043d\u043d\u044f \u043c\u0438 \u0444\u0456\u043a\u0441\u0443\u0432\u0430\u043b\u0438 \u043b\u0438\u0448\u0435 \u043d\u0430 \u0411\u041f\u041b\u0410 V2. \u042f \u043d\u0435\u043e\u0434\u043d\u043e\u0440\u0430\u0437\u043e\u0432\u043e \u043f\u0438\u0441\u0430\u0432, \u0449\u043e \u0446\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u043d\u0430 \u0431\u0430\u0437\u0456 V2U \u043d\u0430\u0432\u0447\u0430\u0454 \u043d\u0435\u0439\u0440\u043e\u043d\u043d\u0443 \u043c\u0435\u0440\u0435\u0436\u0443. \u0421\u044c\u043e\u0433\u043e\u0434\u043d\u0456 \u043c\u0438 \u0432\u0438\u044f\u0432\u0438\u043b\u0438 \u0442\u0430\u043a\u0435 \u0440\u0456\u0448\u0435\u043d\u043d\u044f \u043d\u0430 \u00ab\u041c\u043e\u043b\u043d\u0456\u0457\u00bb. \u0426\u0435 \u043f\u043e\u0433\u0430\u043d\u0438\u0439 \u0437\u043d\u0430\u043a. \u042f \u0437\u043d\u043e\u0432\u0443 \u0437\u0432\u0435\u0440\u0442\u0430\u044e\u0441\u044f \u0434\u043e ", "link": "https://t.me/serhii_flash/7531", "pubDate": "2026-07-01T09:05:17+00:00"}, {"channel": "combat_ftg2", "snippet": "Russian soldier survives direct FPV drone hit", "snippet_en": "Russian soldier survives direct FPV drone hit", "link": "https://t.me/combat_ftg2/3624", "pubDate": "2026-06-29T20:19:33+00:00"}, {"channel": "serhii_flash", "snippet": "\u0413\u0430\u0434\u0430\u044e, \u0432\u0441\u0456 \u0432\u0436\u0435 \u0437\u0440\u043e\u0437\u0443\u043c\u0456\u043b\u0438, \u0449\u043e \u043a\u0435\u0440\u0456\u0432\u043d\u0438\u0446\u0442\u0432\u043e \u0420\u0424 \u0433\u043e\u0442\u043e\u0432\u0435 \u0432\u0435\u0441\u0442\u0438 \u0446\u044e \u0432\u0456\u0439\u043d\u0443 \u0432 \u043d\u0438\u043d\u0456\u0448\u043d\u044c\u043e\u043c\u0443 \u0444\u043e\u0440\u043c\u0430\u0442\u0456 \u0434\u0443\u0436\u0435 \u0434\u043e\u0432\u0433\u043e. \u0417\u043d\u0430\u0439\u0442\u0438 \u0449\u043e\u043c\u0456\u0441\u044f\u0446\u044f 30 \u0442\u0438\u0441\u044f\u0447 \u043b\u044e\u0434\u0435\u0439 \u0434\u043b\u044f \u0432\u0456\u0434\u043f\u0440\u0430\u0432\u043a\u0438 \u043d\u0430 \u0441\u043c\u0435\u0440\u0442\u044c, \u0449\u043e\u0431 \u0443\u0442\u0440\u0438\u043c\u0430\u0442\u0438 \u0444\u0440\u043e\u043d\u0442\u0438, \u2014 \u043d\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430. \u042f \u0442\u0430\u043a\u043e\u0436 \u0437\u043d\u0430\u044e \u0457\u0445\u043d\u0456 \u043f\u043e\u0442\u043e\u0447\u043d\u0456 \u043c\u043e\u0436\u043b\u0438\u0432\u043e\u0441\u0442\u0456 \u0442\u0430 \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u0438 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u0430 \u0411\u041f\u041b\u0410 \u0439 \u0440\u0430\u043a\u0435\u0442. \u0412\u043e\u043d\u0438 \u0430\u0442\u0430\u043a\u0443\u0432\u0430\u0442\u0438\u043c\u0443\u0442\u044c \u043d\u0430\u0441 \u043d\u0438\u043c\u0438 \u0440\u043e\u043a\u0430\u043c\u0438 \u0437\u0430 \u043f\u0456\u0434\u0442\u0440\u0438\u043c\u043a\u0438 \u041a\u0438\u0442\u0430\u044e. \u0406 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0438 \u0437 \u043f\u0430\u043b\u0438\u0432\u043e\u043c \u043d\u0430 \u0410\u0417\u0421 \u0432\u043e\u0436\u0434\u0456\u0432 \u043c\u0430\u043b\u043e \u0445\u0432\u0438\u043b\u044e\u044e\u0442\u044c. \u0420\u0435\u0430\u043b\u044c\u043d\u0430 \u043c\u043e\u0436\u043b\u0438\u0432\u0456\u0441\u0442\u044c \u043f\u0440\u0438\u0441\u043a\u043e\u0440\u0438\u0442\u0438", "snippet_en": "\u0413\u0430\u0434\u0430\u044e, \u0432\u0441\u0456 \u0432\u0436\u0435 \u0437\u0440\u043e\u0437\u0443\u043c\u0456\u043b\u0438, \u0449\u043e \u043a\u0435\u0440\u0456\u0432\u043d\u0438\u0446\u0442\u0432\u043e \u0420\u0424 \u0433\u043e\u0442\u043e\u0432\u0435 \u0432\u0435\u0441\u0442\u0438 \u0446\u044e \u0432\u0456\u0439\u043d\u0443 \u0432 \u043d\u0438\u043d\u0456\u0448\u043d\u044c\u043e\u043c\u0443 \u0444\u043e\u0440\u043c\u0430\u0442\u0456 \u0434\u0443\u0436\u0435 \u0434\u043e\u0432\u0433\u043e. \u0417\u043d\u0430\u0439\u0442\u0438 \u0449\u043e\u043c\u0456\u0441\u044f\u0446\u044f 30 \u0442\u0438\u0441\u044f\u0447 \u043b\u044e\u0434\u0435\u0439 \u0434\u043b\u044f \u0432\u0456\u0434\u043f\u0440\u0430\u0432\u043a\u0438 \u043d\u0430 \u0441\u043c\u0435\u0440\u0442\u044c, \u0449\u043e\u0431 \u0443\u0442\u0440\u0438\u043c\u0430\u0442\u0438 \u0444\u0440\u043e\u043d\u0442\u0438, \u2014 \u043d\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430. \u042f \u0442\u0430\u043a\u043e\u0436 \u0437\u043d\u0430\u044e \u0457\u0445\u043d\u0456 \u043f\u043e\u0442\u043e\u0447\u043d\u0456 \u043c\u043e\u0436\u043b\u0438\u0432\u043e\u0441\u0442\u0456 \u0442\u0430 \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u0438 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u0430 \u0411\u041f\u041b\u0410 \u0439 \u0440\u0430\u043a\u0435\u0442. \u0412\u043e\u043d\u0438 \u0430\u0442\u0430\u043a\u0443\u0432\u0430\u0442\u0438\u043c\u0443\u0442\u044c \u043d\u0430\u0441 \u043d\u0438\u043c\u0438 \u0440\u043e\u043a\u0430\u043c\u0438 \u0437\u0430 \u043f\u0456\u0434\u0442\u0440\u0438\u043c\u043a\u0438 \u041a\u0438\u0442\u0430\u044e. \u0406 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0438 \u0437 \u043f\u0430\u043b\u0438\u0432\u043e\u043c \u043d\u0430 \u0410\u0417\u0421 \u0432\u043e\u0436\u0434\u0456\u0432 \u043c\u0430\u043b\u043e \u0445\u0432\u0438\u043b\u044e\u044e\u0442\u044c. \u0420\u0435\u0430\u043b\u044c\u043d\u0430 \u043c\u043e\u0436\u043b\u0438\u0432\u0456\u0441\u0442\u044c \u043f\u0440\u0438\u0441\u043a\u043e\u0440\u0438\u0442\u0438", "link": "https://t.me/serhii_flash/7523", "pubDate": "2026-06-27T11:32:59+00:00"}, {"channel": "serhii_flash", "snippet": "\u041f\u0430\u043c\u2019\u044f\u0442\u0430\u0454\u0442\u0435, \u044f \u0440\u043e\u0437\u043f\u043e\u0432\u0456\u0434\u0430\u0432 \u0432\u0430\u043c \u043f\u0440\u043e \u0434\u0435\u0448\u0435\u0432\u0438\u0439 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0439 \u0411\u041f\u041b\u0410 \u0432\u043e\u0440\u043e\u0433\u0430, \u044f\u043a\u0438\u0439 \u043f\u043e\u0447\u0430\u0432 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438\u0441\u044f \u043d\u0430 \u0444\u0440\u043e\u043d\u0442\u0430\u0445. \u0404 \u0434\u0443\u043c\u043a\u0430, \u0449\u043e \u0446\u0435 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0430 \u0432\u0435\u0440\u0441\u0456\u044f \u0411\u041f\u041b\u0410 \u00ab\u0414\u0435\u043b\u044c\u0442\u0430\u00bb. \u0414\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c 200 \u043a\u043c, \u0442\u0440\u0438\u0432\u0430\u043b\u0456\u0441\u0442\u044c \u043f\u043e\u043b\u044c\u043e\u0442\u0443 50 \u0445\u0432\u0438\u043b\u0438\u043d, \u0448\u0432\u0438\u0434\u043a\u0456\u0441\u0442\u044c \u0434\u043e 280 \u043a\u043c/\u0433\u043e\u0434 \u0410\u043b\u0435 \u043f\u043e\u043a\u0438 \u0449\u043e \u0442\u0440\u043e\u0444\u0435\u0457\u0432 \u043d\u0435\u043c\u0430\u0454, \u0456 \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u0438 \u0446\u0435 \u043d\u0435 \u043c\u043e\u0436\u0443.", "snippet_en": "\u041f\u0430\u043c\u2019\u044f\u0442\u0430\u0454\u0442\u0435, \u044f \u0440\u043e\u0437\u043f\u043e\u0432\u0456\u0434\u0430\u0432 \u0432\u0430\u043c \u043f\u0440\u043e \u0434\u0435\u0448\u0435\u0432\u0438\u0439 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0439 \u0411\u041f\u041b\u0410 \u0432\u043e\u0440\u043e\u0433\u0430, \u044f\u043a\u0438\u0439 \u043f\u043e\u0447\u0430\u0432 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438\u0441\u044f \u043d\u0430 \u0444\u0440\u043e\u043d\u0442\u0430\u0445. \u0404 \u0434\u0443\u043c\u043a\u0430, \u0449\u043e \u0446\u0435 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0430 \u0432\u0435\u0440\u0441\u0456\u044f \u0411\u041f\u041b\u0410 \u00ab\u0414\u0435\u043b\u044c\u0442\u0430\u00bb. \u0414\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c 200 \u043a\u043c, \u0442\u0440\u0438\u0432\u0430\u043b\u0456\u0441\u0442\u044c \u043f\u043e\u043b\u044c\u043e\u0442\u0443 50 \u0445\u0432\u0438\u043b\u0438\u043d, \u0448\u0432\u0438\u0434\u043a\u0456\u0441\u0442\u044c \u0434\u043e 280 \u043a\u043c/\u0433\u043e\u0434 \u0410\u043b\u0435 \u043f\u043e\u043a\u0438 \u0449\u043e \u0442\u0440\u043e\u0444\u0435\u0457\u0432 \u043d\u0435\u043c\u0430\u0454, \u0456 \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u0438 \u0446\u0435 \u043d\u0435 \u043c\u043e\u0436\u0443.", "link": "https://t.me/serhii_flash/7519", "pubDate": "2026-06-26T16:11:21+00:00"}, {"channel": "serhii_flash", "snippet": "\u0418\u0434\u0435\u0442 \u043f\u044f\u0442\u044b\u0439 \u0433\u043e\u0434 \u043d\u0438\u043a\u043e\u043c\u0443 \u043d\u0435 \u043d\u0443\u0436\u043d\u043e\u0439 \u0432\u043e\u0439\u043d\u044b. \u041d\u0438 \u043f\u0440\u043e\u0441\u0442\u043e\u043c\u0443 \u043d\u0430\u0440\u043e\u0434\u0443 \u0423\u043a\u0440\u0430\u0438\u043d\u044b, \u043d\u0438 \u043f\u0440\u043e\u0441\u0442\u043e\u043c\u0443 \u043d\u0430\u0440\u043e\u0434\u0443 \u0420\u043e\u0441\u0441\u0438\u0438. \u0424\u0440\u043e\u043d\u0442\u043e\u0432\u0430\u044f, \u043f\u043e\u0437\u0438\u0446\u0438\u043e\u043d\u043d\u0430\u044f \u0432\u043e\u0439\u043d\u0430 \u0441\u0435\u0439\u0447\u0430\u0441 \u043f\u0435\u0440\u0435\u0448\u043b\u0430 \u0432 \u0444\u043e\u0440\u043c\u0430\u0442 \u0430\u0442\u0430\u043a \u0442\u044b\u043b\u043e\u0432\u044b\u0445 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438 ( \u0438\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430, \u0431\u0438\u0437\u043d\u0435\u0441) \u0440\u0430\u043a\u0435\u0442\u0430\u043c\u0438 \u0438 \u0411\u041f\u041b\u0410. \u041f\u043e\u0431\u0435\u0434\u044b \u0432 \u0442\u0430\u043a\u043e\u043c \u0444\u043e\u0440\u043c\u0430\u0442\u0435 \u043d\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442 \u043d\u0438\u043a\u0442\u043e. \u041d\u0430\u0441 \u043d\u0435 \u0441\u043b\u044b\u0448\u0430\u0442 \u0432\u043e\u0436\u04