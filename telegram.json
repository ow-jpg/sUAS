41b\u044e\u0434\u0438 \u0435\u0432\u0430\u043a\u0443\u0439\u043e\u0432\u0430\u043d\u0456. \u0417\u0430\u0439\u043c\u0430\u043d\u043d\u044f \u043b\u043e\u043a\u0430\u043b\u0456\u0437\u043e\u0432\u0430\u043d\u043e\", - \u0432\u0456\u0434\u0437\u0432\u0456\u0442\u0443\u0432\u0430\u0432 \u0432\u0456\u043d \u0443 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c. \u041a\u0440\u0456\u043c \u0442\u043e\u0433\u043e, \u0437\u0430 \u0439\u043e\u0433\u043e \u0441\u043b\u043e\u0432\u0430\u043c\u0438, \u0432 \u0430\u043a\u0432\u0430\u0442\u043e\u0440\u0456\u0457 \u0422\u0430\u0433\u0430\u043d\u0440\u043e\u0437\u044c\u043a\u043e\u0457 \u0437\u0430\u0442\u043e\u043a\u0438 \"\u0432\u043d\u0430\u0441\u043b\u0456\u0434\u043e\u043a \u0432\u043b\u0443\u0447\u0430\u043d\u043d\u044f \u0443\u043b\u0430\u043c\u043a\u0456\u0432 \u0411\u043f\u041b\u0410\" \u043f\u043e\u0448\u043a\u043e\u0434\u0436\u0435\u043d\u0438\u0439 \u043a\u043e\u043c\u0435\u0440\u0446\u0456\u0439\u043d\u0438\u0439 \u0441\u0443", "snippet_en": "\ud83e\udde8\u0410\u0442\u0430\u043a\u0430 \u043d\u0430 \u0422\u0430\u0433\u0430\u043d\u0440\u043e\u0433: \u043f\u043e\u0436\u0435\u0436\u0456 \u043d\u0430 \u0441\u043a\u043b\u0430\u0434\u0430\u0445 \u0456 \u043f\u043e\u0448\u043a\u043e\u0434\u0436\u0435\u043d\u0435 \u0441\u0443\u0434\u043d\u043e \u0410\u0442\u0430\u043a\u0443 \u0434\u0440\u043e\u043d\u0456\u0432 \u0442\u0430 \u0440\u0430\u043a\u0435\u0442 \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0432 \u0433\u0443\u0431\u0435\u0440\u043d\u0430\u0442\u043e\u0440 \u043e\u0431\u043b\u0430\u0441\u0442\u0456. \"\u041f\u043e\u0441\u0442\u0440\u0430\u0436\u0434\u0430\u043b\u0430 \u043a\u043e\u043c\u0435\u0440\u0446\u0456\u0439\u043d\u0430 \u0456\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430. \u0412\u0438\u043d\u0438\u043a\u043b\u0430 \u043f\u043e\u0436\u0435\u0436\u0430 \u043d\u0430 \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0457 \u0441\u043a\u043b\u0430\u0434\u0456\u0432 \u043b\u043e