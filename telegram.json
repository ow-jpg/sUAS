0 \u041f\u043e\u043a\u0440\u043e\u0432\u0441\u044c\u043a\u043e\u043c\u0443 \u043d\u0430\u043f\u0440\u044f\u043c\u043a\u0443, \u043c\u0430\u0439\u0441\u0442\u0435\u0440\u043d\u044f \u0434\u0440\u043e\u043d\u0456\u0432 \u043f\u0440\u0430\u0446\u044e\u0454 \u0431\u0435\u0437 \u0437\u0443\u043f\u0438\u043d\u0443. \u0420\u0435\u043c\u043e\u043d\u0442, \u043f\u0435\u0440\u0435\u043f\u0440\u043e\u0448\u0438\u0432\u043a\u0430, \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0442\u0430 \u043f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0411\u043f\u041b\u0410 \u0434\u043e \u0431\u043e\u0439\u043e\u0432\u043e\u0433\u043e \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u0432\u0430\u043d\u043d\u044f \u2014 \u0432\u0456\u0434 \u0432\u0456\u0434\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044f \u0442\u0435\u0445\u043d\u0456\u043a\u0438 \u0434\u043e \u0441\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u0432\u043b\u0430\u0441\u043d\u0438\u0445 \u0440\u0456\u0448\u0435\u043d\u044c: \u0434\u043e\u0434\u0430\u0442\u043a\u043e\u0432\u0456 \u0431\u0430\u0442\u0430\u0440\u0435\u0457, \u043c\u043e\u0434\u0435\u0440\u043d\u0456\u0437\u0430\u0446\u0456\u044f, 3D-\u0434\u0440\u0443\u043a \u0456 \u043f\u043e\u0432\u043d\u0438\u0439 \u0446\u0438\u043a\u043b \u043f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438.", "link": "https://t.me/VictoryDrones2023/26491", "pubDate": "2026-04-09T17:24:34+00:00"}, {"channel": "VictoryDrones2023", "snippet": "Game Over \u0434\u043b\u044f \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432&#33; \ud83c\udfae\ud83d\udca5 \u041f\u043e\u043a\u0438 \u0432\u043e\u0440\u043e\u0433 \u043c\u0430\u043b\u044e\u0454 \u043f\u043b\u0430\u043d\u0438 \u00ab\u043d\u0430\u0441\u0442\u0443\u043f\u0456\u0432\u00bb, \u043f\u0456\u043b\u043e\u0442\u0438 \u0431\u0430\u0442\u0430\u043b\u044c\u0439\u043e\u043d\u0443 \u0431\u0435\u0437\u043f\u0456\u043b\u043e\u0442\u043d\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043c \u00ab\u041a\u0410\u0422\u0420\u0410\u041d\u00bb 35 \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u043c\u043e\u0440\u0441\u044c\u043a\u043e\u0457 \u043f\u0456\u0445\u043e\u0442\u0438 \u043c\u0430\u043b\u044e\u044e\u0442\u044c \u0445\u0440\u0435\u0441\u0442\u0438\u043a\u0438 \u043d\u0430 \u043a\u0430\u0440\u0442\u0456 \u0457\u0445\u043d\u0456\u0445 \u0432\u0442\u0440\u0430\u0442. \u0414\u043b\u044f \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0430 \u043d\u0435\u043c\u0430\u0454 \u00ab\u0431\u0435\u0437\u043f\u0435\u0447\u043d\u043e\u0457 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0456\u0457\u00bb. \u041d\u0430 \u0432\u0456\u0434\u0435\u043e \u2014 \u0447\u0435\u0440\u0433\u043e\u0432\u0430 \u043f\u043e\u0440\u0446\u0456\u044f \u043c\u0430\u0439\u0441\u0442\u0435\u0440-\u043a\u043b\u0430\u0441\u0443 \u0432\u0456\u0434 \u043d\u0430\u0448\u0438\u0445 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0456\u0432 \u0411\u041f\u041b\u0410. \u0420\u0435\u043a\u0440\u0443\u0442\u0438\u043d\u0433 | +38095530565 \ud83c\uddfa\ud83c\udde635 \u0431\u0440\u0438\u0433\u0430\u0434\u0430 \u043c\u043e\u0440\u0441\u044c\u043a\u043e\u0457 \u043f\u0456\u0445\u043e\u0442\u0438 \u2693\u041c\u043e\u0440\u0441\u044c\u043a\u0430 \u043f\u0456\u0445\u043e\u0442\u0430 \u0423\u043a\u0440\u0430\u0457\u043d\u0438", "snippet_en": "Game Over \u0434\u043b\u044f \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432&#33; \ud83c\udfae\ud83d\udca5 \u041f\u043e\u043a\u0438 \u0432\u043e\u0440\u043e\u0433 \u043c\u0430\u043b\u044e\u0454 \u043f\u043b\u0430\u043d\u0438 \u00ab\u043d\u0430\u0441\u0442\u0443\u043f\u0456\u0432\u00bb, \u043f\u0456\u043b\u043e\u0442\u0438 \u0431\u0430\u0442\u0430\u043b\u044c\u0439\u043e\u043d\u0443 \u0431\u0435\u0437\u043f\u0456\u043b\u043e\u0442\u043d\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043c \u00ab\u041a\u0410\u0422\u0420\u0410\u041d\u00bb 35 \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u043c\u043e\u0440\u0441\u044c\u043a\u043e\u0457 \u043f\u0456\u0445\u043e\u0442\u0438 \u043c\u0430\u043b\u044e\u04