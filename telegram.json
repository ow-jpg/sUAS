\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u043e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u043e \u0441\u0432\u044b\u0448\u0435 28 000 \u044d\u043f\u0438\u0437\u043e\u0434\u043e\u0432 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0446\u0435\u043b\u0435\u0439 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0438 \u0434\u0438\u043d\u0430\u043c\u0438\u043a\u0430* \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u043d\u044b\u0445 \u0446\u0435\u043b\u0435\u0439 \u043f\u043e \u0442\u0438\u043f\u0430\u043c: (*\u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0442\u0441\u0435\u0447\u043a\u0438 \u0432 27 000 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u043d\u044b\u0445 \u0446\u0435\u043b\u0435\u0439) 37,5% (+0,2%) - \u0411\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0435 \u0441\u0438\u0441\u0442\u0435\u043c\u044b (\u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043d\u044b\u0435 \u0438 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u044b\u0435 \u0411\u041f\u041b\u0410, \u041d\u0420\u0422\u041a) 16,1% (-0,2%) - \u0421\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u0441\u0432\u044f\u0437\u0438 \u0438 \u043d\u0430\u0431\u043b\u044e\u0434\u0435\u043d\u0438\u044f 17,7% (+0,5%) - \u041d\u0430\u0437\u0435\u043c\u043d\u044b\u0435 \u0437\u0430\u0449\u0438\u0449\u0435\u043d\u043d\u044b\u0435 \u0446\u0435\u043b\u0438 (\u041f\u0412\u0414, \u043f\u043e\u043b\u0435\u0432\u044b\u0435 \u0443\u043a\u0440\u0435\u043f\u043b\u0435\u043d\u0438\u044f) 11,2% (-0,2%", "snippet_en": "\u041e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u043c \u043a\u0430\u043d\u0430\u043b\u043e\u043c \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u043e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u043e \u0441\u0432\u044b\u0448\u0435 28 000 \u044d\u043f\u0438\u0437\u043e\u0434\u043e\u0432 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0446\u0435\u043b\u0435\u0439 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0438 \u0434\u0438\u043d\u0430\u043c\u0438\u043a\u0430* \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u043d\u044b\u0445 \u0446\u0435\u043b\u0435\u0439 \u043f\u043e \u0442\u0438\u043f\u0430\u043c: (*\u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0442\u0441\u0435\u0447\u043a\u0438 \u0432 27 000 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u043d\u044b\u0445 \u0446\u0435\u043b\u0435\u0439) 37,5% (+0,2%) - \u0411\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0435 \u0441\u0438\u0441\u0442\u0435\u043c\u044b (\u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043d\u044b\u0435 \u0438 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u044b\u0435 \u0411\u041f\u041b\u0410, \u041d\u0420\u0422\u041a) 16,1% (-0,2%) - \u0421\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u0441\u0432\u044f\u0437\u0438 \u0438 \u043d\u0430\u0431\u043b\u044e\u0434\u0435\u043d\u0438\u044f 17,7% (+0,5%) - \u041d\u0430\u0437\u0435\u043c\u043d\u044b\u0435 \u0437\u0430\u0449\u0438\u0449\u0435\u043d\u043d\u044b\u0435 \u0446\u0435\u043b\u0438 (\u041f\u0412\u0414, \u043f\u043e\u043b\u0435\u0432\u044b\u0435 \u0443\u043a\u0440\u0435\u043f\u043b\u0435\u043d\u0438\u044f) 11,2% (-0,2%", "link": "https://t.me/lost_armour/9485", "pubDate": "2026-05-23T15:05:59+00:00"}, {"channel": "wartranslated", "snippet": "Ukraine's 34th Brigade hit a Russian drone operator post in Oleshky with an FPV swarm, killing 15 occupiers. The strike caught troops mid-resupply. The building burned down, some died from shrapnel, others suffocated inside.", "snippet_en": "Ukraine's 34th Brigade hit a Russian drone operator post in Oleshky with an FPV swarm, killing 15 occupiers. The strike caught troops mid-resupply. The building burned down, some died from shrapnel, others suffocated inside.", "l