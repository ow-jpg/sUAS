43d\u044f \u0434\u043e \u043c\u043e\u043c\u0435\u043d\u0442\u0443 \u0430\u0442\u0430\u043a\u0438. \u0412\u043e\u0440\u043e\u0433 \u0440\u043e\u0431\u0438\u0442\u044c \u0446\u0435 \u043d\u0430\u0432\u043c\u0438\u0441\u043d\u043e, \u0449\u043e\u0431 \u043c\u0438 \u043d\u0435 \u043c\u043e\u0433\u043b\u0438 \u0456\u0434\u0435\u043d\u0442\u0438\u0444\u0456\u043a\u0443\u0432\u0430\u0442\u0438 \u0442\u0438\u043f \u0411\u041f\u041b\u0410, \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0442\u0438 \u0437\u0430\u0433\u0440\u043e\u0437\u0443 \u0442\u0430 \u0437\u0440\u0435\u0430\u0433\u0443\u0432\u0430\u0442\u0438 \u043d\u0430 \u043d\u0435\u0457. \u041f\u043e\u043a\u0438 \u0449\u043e \u043d\u0435 \u0437\u0440\u043e\u0437\u0443\u043c\u0456\u043b\u043e, \u044f\u043a\u0438\u0439 \u0442\u0438\u043f \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 \u043f\u0440\u0438 \u0446\u044c\u043e\u043c\u0443 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454 \u00ab\u041b\u0430\u043d\u0446\u0435\u0442\u00bb. \u0406\u043d\u0435\u0440\u0446\u0456\u0439\u043d\u0443 \u0441\u0438\u0441\u0442\u0435\u043c\u0443, \u043c\u0430\u044f\u043a\u0438 \u0447\u0438 \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0432\u0430\u043d\u043d\u044f \u043c\u0456\u0441\u0446\u0435\u0432\u043e\u0441\u0442\u0456 \u0437\u0430 \u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f\u043c.", "snippet_en": "\u0423\u0432\u0430\u0433\u0430. \u041d\u0430 \u0440\u0456\u0437\u043d\u0438\u0445 \u0444\u0440\u043e\u043d\u0442\u0430\u0445 \u0444\u0456\u043a\u0441\u0443\u0454\u043c\u043e, \u0449\u043e \u00ab\u041b\u0430\u043d\u0446\u0435\u0442\u0438\u00bb \u043f\u0440\u0430\u0446\u044e\u044e\u0442\u044c \u0443 \u0440\u0435\u0436\u0438\u043c\u0456 \u043f\u043e\u0432\u043d\u043e\u0433\u043e \u0440\u0430\u0434\u0456\u043e\u043c\u043e\u0432\u0447\u0430\u043d\u043d\u044f \u0434\u043e \u043c\u043e\u043c\u0435\u043d\u0442\u0443 \u0430\u0442\u0430\u043a\u0438. \u0412\u043e\u0440\u043e\u0433 \u0440\u043e\u0431\u0438\u0442\u044c \u0446\u0435 \u043d\u0430\u0432\u043c\u0438\u0441\u043d\u043e, \u0449\u043e\u0431 \u043c\u0438 \u043d\u0435 \u043c\u043e\u0433\u043b\u0438 \u0456\u0434\u0435\u043d\u0442\u0438\u0444\u0456\u043a\u0443\u0432\u0430\u0442\u0438 \u0442\u0438\u043f \u0411\u041f\u041b\u0410, \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0442\u0438 \u0437\u0430\u0433\u0440\u043e\u0437\u0443 \u0442\u0430 \u0437\u0440\u0435\u0430\u0433\u0443\u0432\u0430\u0442\u0438 \u043d\u0430 \u043d\u0435\u0457. \u041f\u043e\u043a\u0438 \u0449\u043e \u043d\u0435 \u0437\u0440\u043e\u0437\u0443\u043c\u0456\u043b\u043e, \u044f\u043a\u0438\u0439 \u0442\u0438\u043f \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 \u043f\u0440\u0438 \u0446\u044c\u043e\u043c\u0443 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454 \u00ab\u041b\u0430\u043d\u0446\u0435\u0442\u00bb. \u0406\u043d\u0435\u0440\u0446\u0456\u0439\u043d\u0443 \u0441\u0438\u0441\u0442\u0435\u043c\u0443, \u043c\u0430\u044f\u043a\u0438 \u0447\u0438 \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0432\u0430\u043d\u043d\u044f \u043c\u0456\u0441\u0446\u0435\u0432\u043e\u0441\u0442\u0456 \u0437\u0430 \u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f\u043c.", "link": "https://t.me/serhii_flash/7412", "pubDate": "2026-05-17T16:08:58+00:00"}, {"channel": "serhii_flash", "snippet": "\u041d\u0438 \u043e\u0434\u043d\u043e \u041f\u0412\u041e \u0432 \u043c\u0438\u0440\u0435 \u043d\u0435 \u043c\u043e\u0436\u0435\u0442 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0438\u0435 100% \u0446\u0435\u043b\u0435\u0439, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u043d\u0430\u0448\u0438 \u0411\u041f\u041b\u0410 \u0438 \u0434\u0430\u043b\u0435\u0435 \u0431\u0443\u0434\u0443\u0442 \u0434\u043e\u043b\u0435\u0442\u0430\u0442\u044c \u0434\u043e \u0446\u0435\u043b\u0435\u0439 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435 \u0438 \u043e\u0431\u043b\u0430\u0441\u0442\u0438. \u0416\u0438\u0442\u0435\u043b\u0438 \u041c\u043e\u0441\u043a\u0432\u044b \u0432 \u044d\u0442\u0443 \u043d\u043e\u0447\u044c \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u0438, \u043a\u0430\u043a \u0436\u0438\u0432\u0443\u0442 \u043d\u0430\u0448\u0438 \u0433\u043e\u0440\u043e\u0434\u0430 \u0432\u0441\u0435 \u0433\u043e\u0434\u044b \u0432\u043e\u0439\u043d\u044b \u0438 \u043a\u0430\u043a\u043e\u0439 \u0443\u0436\u0430\u0441 \u0432\u043e\u0439\u043d\u0430 \u043f\u0440\u0438\u043d\u0435\u0441\u043b\u0430 \u0432 \u043d\u0430\u0448\u0438 \u043c\u0438\u0440\u043d\u044b\u0435 \u0434\u043e\u043c\u0430. \u0413\u043b\u0430\u0432\u043d\u043e\u0435 \u043f\u043e\u043c\u043d\u0438\u0442\u044c: \u043d\u0435 \u043c\u044b \u0435\u0435 \u043d\u0430\u0447\u0430\u043b\u0438 \u0438 \u043d\u0435 \u043c\u044b \u043d\u0435 \u0445\u043e\u0442\u0438\u043c \u0435\u0435 \u043e\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u0442\u044c.", "snippet_en": "\u041d\u0438 \u043e\u0434\u043d\u043e \u041f\u0412\u041e \u0432 \u043c\u0438\u0440\u0435 \u043d\u0435 \u043c\u043e\u0436\u0435\u0442 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0435\u043d\u0438\u0435 100% \u0446\u0435\u043b\u0435\u0439, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u043d\u0430\u0448\u0438 \u0411\u041f\u041b\u0410 \u0438 \u0434\u0430\u043b\u0435\u0435 \u0431\u0443\u0434\u0443\u0442 \u0434\u043e\u043b\u0435\u0442\u0430\u0442\u044c \u0434\u043e \u0446\u0435\u043b\u0435\u0439 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435 \u0438 \u043e\u0431\u043b\u0430\u0441\u0442\u0438. \u0416\u0438\u0442\u0435\u043b\u0438 \u041c\u043e\u0441\u043a\u0432\u044b \u0432 \u044d\u0442\u0443 \u043d\u043e\u0447\u044c \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u0438, \u043a\u0430\u043a \u0436\u0438\u0432\u0443\u0442 \u043d\u0430\u0448\u0438 \u0433\u043e\u0440\u043e\u0434\u0430 \u0432\u0441\u0435 \u0433\u043e\u0434\u044b \u0432\u043e\u0439\u043d\u044b \u0438 \u043a\u0430\u043a\u043e\u0439 \u0443\u0436\u0430\u0441 \u0432\u043e\u0439\u043d\u0430 \u043f\u0440\u0438\u043d\u0435\u0441\u043b\u0430 \u0432 \u043d\u0430\u0448\u0438 \u043c\u0438\u0440\u043d\u044b\u0435 \u0434\u043e\u043c\u0430. \u0413\u043b\u0430\u0432\u043d\u043e\u0435 \u043f\u043e\u043c\u043d\u0438\u0442\u044c: \u043d\u0435 \u043c\u044b \u0435\u0435 \u043d\u0430\u0447\u0430\u043b\u0438 \u0438 \u043d\u0435 \u043c\u044b \u043d\u0435 \u0445\u043e\u0442\u0438\u043c \u0435\u0435 \u043e\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u0442\u044c.", "link": "https://t.me/serhii_flash/7411", "pubDate": "2026-05-17T08:52:06+00:00"}, {"channel": "combat_ftg2", "snippet": "A Russian soldier filmed the moment a Ukrainian FPV drone hit a BMP-2 that was carrying Russian infantry during an attempted assault", "snippet_en": "A Russian soldier filmed the moment a Ukrainian FPV drone hit a BMP-2 that was carrying Russian infantry during an attempted assault", "link": "https://t.me/combat_ftg2/3581", "pubDate": "2026-05-13T19:58:31+00:00"}, {"channel": "lost_armour", "snippet": "\"\u0414\u0430 \u0431\u0443\u0434\u0435\u0442 \u0441\u0432\u0435\u0442, \u2014 \u0441\u043a\u0430\u0437\u0430\u043b \u043f\u0438\u043b\u043e\u0442 \u0438 \u043f\u0440\u043e\u0434\u044b\u0440\u044f\u0432\u0438\u043b \u0442\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0442\u043e\u0440\" \u041e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u044b\u0439 FPV-\u0434\u0440\u043e\u043d \"\u041a\u0412\u041d\" \u043d\u0430\u043d\u043e\u0441\u0438\u0442 \u0443\u0434\u0430\u0440 \u043f\u043e \u0430\u0432\u0442\u043e\u0442\u0440\u0430\u043d\u0441\u0444\u043e\u0440\u043c\u0430\u0442\u043e\u0440\u0443 330/110/10 \u043a\u0412 \u0432\u043d\u0443\u0442\u0440\u0438 \u043f\u043e\u0441\u043f\u0435\u0448\u043d\u043e \u0441\u043e\u043e\u0440\u0443\u0436\u0430\u0435\u043c\u043e\u0433\u043e \u0441\u0430\u0440\u0