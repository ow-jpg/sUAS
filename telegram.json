u043e \u0440\u0430\u0437\u0443 \u0440\u043e\u0441\u0456\u044f \u0437\u0430\u0432\u0434\u0430\u0432\u0430\u043b\u0430 \u0443\u0434\u0430\u0440\u0456\u0432 \u043f\u043e \u043f\u0456\u0434\u043f\u0440\u0438\u0454\u043c\u0441\u0442\u0432\u0430\u0445 \u041a\u0438\u0454\u0432\u0430 (\u0432\u0456\u0434\u043e\u043c\u0438\u0445 \u0449\u0435 \u0437 \u0447\u0430\u0441\u0456\u0432 \u0421\u0420\u0421\u0420). \u041a\u0443\u0434\u0438 \u0441\u0430\u043c\u0435 \u0432\u043b\u0443\u0447\u0438\u043b\u0438 \u0440\u0430\u043a\u0435\u0442\u0438, \u044f \u043d\u0435 \u043c\u043e\u0436\u0443 \u0432\u0430\u043c \u0441\u043a\u0430\u0437\u0430\u0442\u0438 (\u0445\u043e\u0447\u0430 \u0432\u043e\u043d\u0438 \u0439 \u0441\u0430\u043c\u0456 \u043f\u043e\u0431\u0430\u0447\u0430\u0442\u044c \u0443\u0441\u0435 \u0437\u0456 \u0441\u0432\u043e\u0457\u0445 \u0440\u043e\u0437\u0432\u0456\u0434\u0443\u0432\u0430\u043b\u044c\u043d\u0438\u0445 \u0441\u0443\u043f\u0443\u0442\u043d\u0438\u043a\u0456\u0432). \u0429\u043e \u043f\u043e\u0442\u0440\u0456\u0431\u043d\u043e \u0440\u043e\u0437\u0443\u043c\u0456\u0442\u0438. 1. \u042f\u043a\u0449\u043e \u043f\u0456\u0434\u043f\u0440\u0438\u0454\u043c\u0441\u0442\u0432\u043e \u0434\u0456\u0439\u0441\u043d\u043e \u0437\u0430\u0439\u043c\u0430\u0454\u0442\u044c\u0441\u044f \u0447\u0438\u043c\u043e\u0441\u044c \u043a\u0440\u0438\u0442\u0438\u0447\u043d\u043e \u0432\u0430\u0436\u043b\u0438\u0432\u0438\u043c \u0456 \u0432\u0456\u0439\u0441\u044c\u043a\u043e\u0432\u0438\u043c, \u0446\u0435 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u043e \u0431\u0443\u0434\u0435 \u043f\u0456\u0434 \u0437\u0435\u043c\u043b\u0435\u044e. \u0410\u0442\u0430\u043a\u0443\u0432\u0430\u0442\u0438 \u0439\u043e\u0433\u043e \u043c\u0430\u0440\u043d\u043e. \u0412", "snippet_en": "\u041f\u0440\u043e\u0430\u043d\u0430\u043b\u0456\u0437\u0443\u0432\u0430\u0432 \u0431\u0430\u043b\u0456\u0441\u0442\u0438\u0447\u043d\u0456 \u0432\u043b\u0443\u0447\u0430\u043d\u043d\u044f \u0446\u0456\u0454