u0431\u0440\u043e\u0432\u043e\u043b\u044c\u0446\u044b \u043f\u0440\u043e\u0435\u043a\u0442\u0438\u0440\u0443\u044e\u0442 \u0438 \u0438\u0437\u0433\u043e\u0442\u0430\u0432\u043b\u0438\u0432\u0430\u044e\u0442 \u0444\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043d\u043e\u0432\u044b\u0435 \u0438\u0437\u0434\u0435\u043b\u0438\u044f. \u041d\u0435\u0434\u0430\u0432\u043d\u043e \u0431\u043e\u0439\u0446\u044b \u0441\u043e\u0437\u0434\u0430\u043b\u0438 \u0442\u0435\u043f\u043b\u043e\u0432\u0438\u0437\u0438\u043e\u043d\u043d\u044b\u0435 \u043e\u0447\u043a\u0438 \u0438 \u0434\u0440\u043e\u043d-\u0440\u0435\u0442\u0440\u0430\u043d\u0441\u043b\u044f\u0442\u043e\u0440. \u041a\u0430\u043a \u0437\u0430\u044f\u0432\u0438\u043b \u043a\u043e\u043c\u0430\u043d\u0434\u0438\u0440 \u00ab\u042f\u043a\u0438\u043c\u0430\u00bb \u0441 \u043f\u043e\u0437\u044b\u0432\u043d\u044b\u043c \u0422\u0430\u0433\u0430\u043d\u043a\u0430, \u0432 \u0422\u042d\u0427 \u0438\u043c\u0435\u0435\u0442\u0441\u044f \u0432\u0441\u0451 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0435 \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0434\u043b\u044f \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u043e-\u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433", "snippet_en": "\u0413\u0422\u0420\u041a \u00ab\u041a\u0443\u0440\u0441\u043a\u00bb \u043f\u043e\u043a\u0430\u0437\u0430\u043b \u0440\u0430\u0431\u043e\u0442\u0443 \u0442\u0435\u0445\u043d\u0438\u043a\u043e-\u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u043e\u043d\u043d\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 (\u0422\u042d\u0427) \u043e\u0442\u0440\u044f\u0434\u0430 \u00ab\u042f\u043a\u0438\u043c\u00bb \u0412 \u0422\u042d\u0427 \u0441\u043b\u0443\u0436\u0430\u0442 \u0431\u043e\u0439\u0446\u044b \u0441 \u043d\u0430\u0432\u044b\u043a\u0430\u043c\u0438 \u0440\u0435\u043c\u043e\u043d\u0442\u0430 \u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c. \u0422\u0430\u043a\u0436\u0435 \u0434\u043e\u0431\u0440\u043e\u0432\u043e\u043b\u044c\u0446\u044b \u043f\u0440\u043e\u0435\u043a\u0442\u0438\u0440\u0443\u044e\u0442 \u0438 \u0438\u0437\u0433\u043e\u0442\u0430\u0432\u043b\u0438\u0432\u0430\u044e\u0442 \u0444\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043d\u043e\u0432\u044b\u0435 \u0438\u0437\u0434\u0435\u043b\u0438\u044f. \u041d\u0435\u0434\u0430\u0432\u043d\u043e \u0431\u043e\u0439\u0446\u044b \u0441\u043e\u0437\u0434\u0430\u043b\u0438 \u0442\u0435\u043f\u043b\u043e\u0432\u0438\u0437\u0438\u043e\u043d\u043d\u044b\u0435 \u043e\u0447\u043a\u0438 \u0438 \u0434\u0440\u043e\u043d-\u0440\u0435\u0442\u0440\u0430\u043d\u0441\u043b\u044f\u0442\u043e\u0440. \u041a\u0430\u043a \u0437\u0430\u044f\u0432\u0438\u043b \u043a\u043e\u043c\u0430\u043d\u0434\u0438\u0440 \u00ab\u042f\u043a\u0438\u043c\u0430\u00bb \u0441 \u043f\u043e\u0437\u044b\u0432\u043d\u044b\u043c \u0422\u0430\u0433\u0430\u043d\u043a\u0430, \u0432 \u0422\u042d\u0427 \u0438\u043c\u0435\u0435\u0442\u0441\u044f \u0432\u0441\u0451 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0435 \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0434\u043b\u044f \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u043e-\u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433", "link": "https://t.me/VictoryDrones/56785", "pubDate": "2026-06-02T06:07:12+00:00"}, {"channel": "VictoryDrones", "snippet": "\u26a1\ufe0f\u0417\u0431\u0438\u0442\u043e/\u043f\u043e\u0434\u0430\u0432\u043b\u0435\u043d\u043e 642 \u0446\u0456\u043b\u0456: 40 \u0437 73 \u0440\u0430\u043a\u0435\u0442 \u0422\u0410 602 \u0437 656 \u0411\u041f\u041b\u0410. \u25aa\ufe0f0 \u0437 8 \u043f\u0440\u043e\u0442\u0438\u043a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 3\u041c22 \u00ab\u0426\u0438\u0440\u043a\u043e\u043d\u00bb; \u25aa\ufe0f11 \u0437 33 \u0431\u0430\u043b\u0456\u0441\u0442\u0438\u0447\u043d\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u0406\u0441\u043a\u0430\u043d\u0434\u0435\u0440-\u041c; \u25aa\ufe0f26 \u0437 27 \u043a\u0440\u0438\u043b\u0430\u0442\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u0425-101; \u25aa\ufe0f3 \u0437 5 \u043a\u0440\u0438\u043b\u0430\u0442\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u00ab\u041a\u0430\u043b\u0456\u0431\u0440\u00bb; \u25aa\ufe0f602 \u0437 656 \u0443\u0434\u0430\u0440\u043d\u0438\u0445 \u0411\u043f\u041b\u0410. \u041e\u0441\u043d\u043e\u0432\u043d\u0438\u0439 \u043d\u0430\u043f\u0440\u044f\u043c\u043e\u043a \u0443\u0434\u0430\u0440\u0443 \u2013 \u041a\u0438\u0457\u0432. \u0422\u0430\u043a\u043e\u0436 \u0430\u0442\u0430\u043a\u043e\u0432\u0430\u043d\u043e \u0414\u043d\u0456\u043f\u0440\u043e, \u0425\u0430\u0440\u043a\u0456\u0432, \u0417\u0430\u043f\u043e\u0440\u0456\u0436\u0436\u044f, \u041f\u043e\u043b\u0442\u0430\u0432\u0449\u0438\u043d\u0443 \u0442\u0430 \u0456\u043d\u0448\u0456 \u0440\u0435\u0433\u0456\u043e\u043d\u0438. @zsuwar", "snippet_en": "\u26a1\ufe0f\u0417\u0431\u0438\u0442\u043e/\u043f\u043e\u0434\u0430\u0432\u043b\u0435\u043d\u043e 642 \u0446\u0456\u043b\u0456: 40 \u0437 73 \u0440\u0430\u043a\u0435\u0442 \u0422\u0410 602 \u0437 656 \u0411\u041f\u041b\u0410. \u25aa\ufe0f0 \u0437 8 \u043f\u0440\u043e\u0442\u0438\u043a\u043e\u0440\u0430\u0431\u0435\u043b\u044c\u043d\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 3\u041c22 \u00ab\u0426\u0438\u0440\u043a\u043e\u043d\u00bb; \u25aa\ufe0f11 \u0437 33 \u0431\u0430\u043b\u0456\u0441\u0442\u0438\u0447\u043d\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u0406\u0441\u043a\u0430\u043d\u0434\u0435\u0440-\u041c; \u25aa\ufe0f26 \u0437 27 \u043a\u0440\u0438\u043b\u0430\u0442\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u0425-101; \u25aa\ufe0f3 \u0437 5 \u043a\u0440\u0438\u043b\u0430\u0442\u0438\u0445 \u0440\u0430\u043a\u0435\u0442 \u00ab\u041a\u0430\u043b\u0456\u0431\u0440\u00bb; \u25aa\ufe0f602 \u0437 656 \u0443