4c\u0442\u0430\u0442\u0435 \u0441\u0442\u043e\u043b\u043a\u043d\u043e\u0432\u0435\u043d\u0438\u044f \u043f\u043b\u0430\u043d\u0435\u0440 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u043e\u043b\u0443\u0447\u0438\u043b \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0438 \u0440\u0443\u0445\u043d\u0443\u043b \u0432 \u043f\u043e\u043b\u0435, \u0441\u0434\u0435\u0442\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u0432 \u043d\u0430 \u0437\u0435\u043c\u043b\u0435. \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430\u2026", "snippet_en": "\u0414\u0440\u043e\u043d-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\" \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u0435\u0442 \u043e\u0447\u0435\u0440\u0435\u0434\u043d\u043e\u0439 \u0443\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442 \u0443\u0434\u0430\u0440\u043d\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423 \u043d\u0430 \u041a\u0440\u0430\u0441\u043d\u043e\u043b\u0438\u043c\u0430\u043d\u0441\u043a\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438. \u0412 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435 \u0441\u0442\u043e\u043b\u043a\u043d\u043e\u0432\u0435\u043d\u0438\u044f \u043f\u043b\u0430\u043d\u0435\u0440 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u043e\u043b\u0443\u0447\u0438\u043b \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0438 \u0440\u0443\u0445\u043d\u0443\u043b \u0432 \u043f\u043e\u043b\u0435, \u0441\u0434\u0435\u0442\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u0432 \u043d\u0430 \u0437\u0435\u043c\u043b\u0435. \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430\u2026", "link": "https://t.me/lost_armour/9202", "pubDate": "2026-05-03T11:37:32+00:00"}, {"channel": "serhii_flash", "snippet": "\u0412\u0447\u043e\u0440\u0430\u0448\u043d\u044f \u0430\u0442\u0430\u043a\u0430 \u0411\u041f\u041b\u0410 \u043d\u0430 \u041a\u0438\u0457\u0432\u0441\u044c\u043a\u0443 \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u0432\u0456\u0434\u0440\u0456\u0437\u043d\u044f\u043b\u0430\u0441\u044f \u0432\u0456\u0434 \u0437\u0432\u0438\u0447\u0430\u0439\u043d\u0438\u0445. \u0423 \u043a\u0456\u043b\u044c\u043a\u043e\u0445 \u0440\u0430\u0439\u043e\u043d\u0430\u0445 \u043b\u044e\u0434\u0438 \u0437\u0432\u0435\u0440\u043d\u0443\u043b\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u043d\u0435 \u0442\u0438\u043f\u043e\u0432\u0438\u0439 \u0432\u0438\u0433\u043b\u044f\u0434 \u0411\u041f\u041b\u0410. \u041f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a, \u043f\u0456\u0441\u043b\u044f \u0442\u0440\u0438\u0432\u0430\u043b\u043e\u0457 \u043f\u0435\u0440\u0435\u0440\u0432\u0438 \u0432 \u043a\u0456\u043b\u044c\u043a\u0430 \u043c\u0456\u0441\u044f\u0446\u0456\u0432, \u043c\u0430\u0441\u043e\u0432\u043e \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u0432\u0430\u0432 \u0411\u041f\u041b\u0410 \u0456\u043c\u0456\u0442\u0430\u0442\u043e\u0440\u0438 \u00ab\u041f\u0430\u0440\u043e\u0434\u0456\u044f\u00bb. \u0421\u0430\u043c\u0435 \u0439\u043e\u0433\u043e \u0439 \u0431\u0430\u0447\u0438\u043b\u0438 \u043c\u0435\u0448\u043a\u0430\u043d\u0446\u0456 \u043a\u0440\u0430\u0457\u043d\u0438. \u0417\u0430\u0432\u0434\u0430\u043d\u043d\u044f \u0442\u0430\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u2014 \u0432\u0456\u0434\u0432\u043e\u043b\u0456\u043a\u0430\u0442\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430\u0448\u043e\u0457 \u041f\u041f\u041e, \u0442\u043e\u043c\u0443 \u0434\u0435\u0441\u044f\u0442\u043a\u0438 \u0442\u0430\u043a\u0438\u0445 \u0411\u041f\u041b\u0410 \u043a\u0440\u0443\u0436\u043b\u044f\u043b\u0438 \u043d\u0430\u0434 \u043d\u0430\u0448\u043e\u044e \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0454\u044e. \u0412\u0438\u0433\u043b\u044f\u0434\u0430\u0454 \u0446\u0435, \u044f\u043a \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u043e \u043d\u0430 ", "snippet_en": "\u0412\u0447\u043e\u0440\u0430\u0448\u043d\u044f \u0430\u0442\u0430\u043a\u0430 \u0411\u041f\u041b\u0410 \u043d\u0430 \u041a\u0438\u0457\u0432\u0441\u044c\u043a\u0443 \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u0432\u0456\u0434\u0440\u0456\u0437\u043d\u044f\u043b\u0430\u0441\u044f \u0432\u0456\u0434 \u0437\u0432\u0438\u0447\u0430\u0439\u043d\u0438\u0445. \u0423 \u043a\u0456\u043b\u044c\u043a\u043e\u0445 \u0440\u0430\u0439\u043e\u043d\u0430\u0445 \u043b\u044e\u0434\u0438 \u0437\u0432\u0435\u0440\u043d\u0443\u043b\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u043d\u0435 \u0442\u0438\u043f\u043e\u0432\u0438\u0439 \u0432\u0438\u0433\u043b\u044f\u0434 \u0411\u041f\u041b\u0410. \u041f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a, \u043f\u0456\u0441\u043b\u044f \u0442\u0440\u0438\u0432\u0430\u043b\u043e\u0457 \u043f\u0435\u0440\u0435\u0440\u0432\u0438 \u0432 \u043a\u0456\u043b\u044c\u043a\u0430 \u043c\u0456\u0441\u044f\u0446\u0456\u0432, \u043c\u0430\u0441\u043e\u0432\u043e \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u0432\u0430\u0432 \u0411\u041f\u041b\u0410 \u0456\u043c\u0456\u0442\u0430\u0442\u043e\u0440\u0438 \u00ab\u041f\u0430\u0440\u043e\u0434\u0456\u044f\u00bb. \u0421\u0430\u043c\u0435 \u0439\u043e\u0433\u043e \u0439 \u0431\u0430\u0447\u0438\u043b\u0438 \u043c\u0435\u0448\u043a\u0430\u043d\u0446\u0456 \u043a\u0440\u0430\u0457\u043d\u0438. \u0417\u0430\u0432\u0434\u0430\u043d\u043d\u044f \u0442\u0430\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u2014 \u0432\u0456\u0434\u0432\u043e\u043b\u0456\u043a\u0430\u0442\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430\u0448\u043e\u0457 \u041f\u041f\u041e, \u0442\u043e\u043c\u0443 \u0434\u0435\u0441\u044f\u0442\u043a\u0438 \u0442\u0430\u043a\u0438\u0445 \u0411\u041f\u041b\u0410 \u043a\u0440\u0443\u0436\u043b\u044f\u043b\u0438 \u043d\u0430\u0434 \u043d\u0430\u0448\u043e\u044e \u0442\u0435\u0440\u0438\u0442\u043e\u0440\u0456\u0454\u044e. \u0412\u0438\u0433\u043b\u044f\u0434\u0430\u0454 \u0446\u0435, \u044f\u043a \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u043e \u043d\u0430 ", "link": "https://t.me/serhii_flash/7351", "pubDate": "2026-05-03T08:58:22+00:00"}, {"channel": "lost_armour", "snippet": "\ud83d\udd34 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0434\u0435\u043d\u044c \u0437\u0430 \u0434\u043d\u0435\u043c&#33; \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0437\u0430 2 \u043c\u0430\u044f 2026 \u0433\u043e\u0434\u0430 \u2022 \u0414\u043e\u043d\u0431\u0430\u0441\u0441 \u2022 \u041a\u0440\u0430\u0441\u043d\u043e\u043b\u0438\u043c\u0430\u043d\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0411\u0435\u043b\u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0421\u0443\u043c\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u0434\u043d\u0435\u0432\u043d\u044b\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u043e\u0432 FPV-\u041f\u0412\u041e \u043f\u043e \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423 \u2022 \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043d\u043e\u0447\u043d\u044b\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u043e\u0432 FPV-\u041f\u0412\u041e \u043f\u043e \u0411\u041f\u041b\u0410 \u0412\u0421\u0423 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u043e \u0446\u0435\u043b\u0435\u0439: 172 \ud83d\udd34 Rutube \ud83d\udc4a \u0421\u0442\u0430\u0442\u0438\u0441