3e\u043c\u0430\u043d\u0434\u0438\u0440 \u0433\u0440\u0443\u043f\u043f\u044b \u0443\u0434\u0430\u0440\u043d\u044b\u0445 \u0411\u043f\u041b\u0410 \u0426\u0435\u043d\u0442\u0440\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb, \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0438\u0432\u0448\u0438\u0439 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441\u043e \u0441\u0432\u043e\u0438\u043c \u043e\u0442\u0440\u044f\u0434\u043e\u043c \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0442\u0430\u043d\u043a\u043e\u0432, \u043e\u0434\u043d\u0438\u043c \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0431\u044b\u043b \u043c\u0435\u0434\u0438\u0439\u043d\u044b\u0439 \u0442\u0430\u043d\u043a \u0412\u0421\u0423, \u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u043e \u0441\u0432\u043e\u0435\u0439 \u0431\u043e\u0435\u0432\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u0435. \ud83d\udd34 \u0420\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb \ud83d\udd34 Rutube \ud83d\udc4a \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u0430\u00bb \u043d\u0430 Lostarmour \ud83d\udd34 \u0412\u0441\u0442\u0443\u043f\u0438\u0442\u044c \u0432 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb: +79856759127 - \u041f\u0443\u043d\u043a\u0442 \u043e\u0442\u0431\u043e\u0440\u0430 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb \u041f\u0440\u043e\u043c\u043e 1 | \u041f\u0440\u043e\u043c\u043e 2 \ud83d\udd34\u041c\u044b \u0432 MAX", "snippet_en": "\u0414\u043e\u043d\u0431\u0430\u0441\u0441 \u041a\u043e\u043c\u0430\u043d\u0434\u0438\u0440 \u0433\u0440\u0443\u043f\u043f\u044b \u0443\u0434\u0430\u0440\u043d\u044b\u0445 \u0411\u043f\u041b\u0410 \u0426\u0435\u043d\u0442\u0440\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb, \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0438\u0432\u0448\u0438\u0439 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441\u043e \u0441\u0432\u043e\u0438\u043c \u043e\u0442\u0440\u044f\u0434\u043e\u043c \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0442\u0430\u043d\u043a\u043e\u0432, \u043e\u0434\u043d\u0438\u043c \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0431\u044b\u043b \u043c\u0435\u0434\u0438\u0439\u043d\u044b\u0439 \u0442\u0430\u043d\u043a \u0412\u0421\u0423, \u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u043e \u0441\u0432\u043e\u0435\u0439 \u0431\u043e\u0435\u0432\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u0435. \ud83d\udd34 \u0420\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb \ud83d\udd34 Rutube \ud83d\udc4a \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u0430\u00bb \u043d\u0430 Lostarmour \ud83d\udd34 \u0412\u0441\u0442\u0443\u043f\u0438\u0442\u044c \u0432 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb: +79856759127 - \u041f\u0443\u043d\u043a\u0442 \u043e\u0442\u0431\u043e\u0440\u0430 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \u00ab\u0420\u0443\u0431\u0438\u043a\u043e\u043d\u00bb \u041f\u0440\u043e\u043c\u043e 1 | \u041f\u0440\u043e\u043c\u043e 2 \ud83d\udd34\u041c\u044b \u0432 MAX", "link": "https://t.me/lost_armour/9663", "pubDate": "2026-06-04T07:48:10+00:00"}, {"channel": "VictoryDrones", "snippet": "\u0417\u0430 \u0441\u044a\u0435\u043c\u043a\u0443 \u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f \u0431\u0435\u043d\u0437\u043e\u0432\u043e\u0445\u043e\u0432, \u0438\u0445 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u044b, \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \"\u043a\u0443\u0434\u0430 \u0435\u0434\u0435\u0442|\u043f\u0440\u0438\u0435\u0445\u0430\u043b\" - \u0441\u0440\u043e\u043a. \u0412 \u041a\u0440\u044b\u043c\u0443 \u0438\u0434\u0443\u0442 \u043f\u043e\u0438\u0441\u043a \u0438 \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044f \u0442\u0435\u0445, \u043a\u0442\u043e \u0441\u043d\u0438\u043c\u0430\u043b \u0438 \u0432\u044b\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u043b \u0444\u043e\u0442\u043e \u0438 \u0432\u0438\u0434\u0435\u043e, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0441 \u043a\u043e\u043b\u043e\u043d\u043d\u0430\u043c\u0438 \u0431\u0435\u043d\u0437\u043e\u0432\u043e\u0437\u043e\u0432. \u041a\u0430\u043a \u0441\u043e\u043e\u0431\u0449\u0438\u043b\u0438 \u0440\u0435\u0434\u0430\u043a\u0446\u0438\u0438 \"@Krimski\" \u0432\u044b\u0441\u043e\u043a\u043e\u043f\u043e\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043d\u044b\u0435 \u0441\u0438\u043b\u043e\u0432\u0438\u043a\u0438, \u0442\u0430\u043a\u0438\u043c \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430\u043c \u043a\u0430\u043a \u043c\u0438\u043d\u0438\u043c\u0443\u043c \u0431\u0443\u0434\u0435\u0442 \u0432\u043c\u0435\u043d\u0435\u043d\u0430 \u0441\u0442\u0430\u0442\u044c\u044f 281.1 \u0423\u041a \u0420\u0424 \"\u0421\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0434\u0438\u0432\u0435\u0440\u0441\u0438\u043e\u043d\u043d\u043e\u0439 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438\", \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u043f\u0440\u0435\u0434\u0443\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442 \u0441\u0440\u043e\u043a \u043e\u0442 1", "snippet_en": "\u0417\u0430 \u0441\u044a\u0435\u043c\u043a\u0443 \u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f \u0431\u0435\u043d\u0437\u043e\u0432\u043e\u0445\u043e\u0432, \u0438\u0445 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u044b, \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \"\u043a\u0443\u0434\u0430 \u0435\u0434\u0435\u0442|\u043f\u0440\u0438\u0435\u0445\u0430\u043b\" - \u0441\u0440\u043e\u043a. \u0412 \u041a\u0440\u044b