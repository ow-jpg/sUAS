43e 10 \u043a\u0433 \u0431\u043e\u0435\u0432\u043e\u0439 \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0438, \u0442\u043e \u0434\u043b\u044f Lightning 13 \u0443\u0436\u0435 \u0433\u043e\u0432\u043e\u0440\u044f\u0442", "snippet_en": "\u041c\u043e\u043b\u043d\u0438\u044f-2 \u043f\u043e\u0434 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435\u043c Lightning 13. \u0421\u043e\u0433\u043b\u0430\u0441\u043d\u043e \u0437\u0430\u044f\u0432\u043b\u0435\u043d\u043d\u044b\u043c \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0430\u043c, \u0411\u041f\u041b\u0410 \u0438\u043c\u0435\u0435\u0442 \u0434\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0434\u043e 50 \u043a\u043c, \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u043e\u043a\u043e\u043b\u043e 120 \u043a\u043c/\u0447 \u0438 \u0431\u043e\u0435\u0432\u0443\u044e \u0447\u0430\u0441\u0442\u044c \u043c\u0430\u0441\u0441\u043e\u0439 13 \u043a\u0433. \u0413\u043b\u0430\u0432\u043d\u043e\u0435 \u043e\u0442\u043b\u0438\u0447\u0438\u0435 \u043e\u0442 \"\u041c\u043e\u043b\u043d\u0438\u0438-2\" - \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u043d\u044b\u0439 \u043a\u043e\u0440\u043f\u0443\u0441 \u0438 \u0447\u0435\u0442\u044b\u0440\u0435 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043b\u044f \u0432\u043c\u0435\u0441\u0442\u043e \u0434\u0432\u0443\u0445. \u042d\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u0438\u043b\u043e \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0442\u044c \u043f\u043e\u043b\u0435\u0437\u043d\u0443\u044e \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0443 \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u043d\u0430 30%. \u0415\u0441\u043b\u0438 \u0434\u043b\u044f \"\u041c\u043e\u043b\u043d\u0438\u0438-2\" \u043e\u0431\u044b\u0447\u043d\u043e \u0437\u0430\u044f\u0432\u043b\u044f\u043b\u0438 \u0434\u043e 10 \u043a\u0433 \u0431\u043e\u0435\u0432\u043e\u0439 \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0438, \u0442\u043e \u0434\u043b\u044f Lightning 13 \u0443\u0436\u0435 \u0433\u043e\u0432\u043e\u0440\u044f\u0442", "link": "https://t.me/VictoryDrones/57937", "pubDate": "2026-06-18T21:49:48+00:00"}, {"channel": "VictoryDrones", "snippet": "\u0421\u0442\u0430\u044f \u043c\u0438\u043d\u0438\u043c\u0443\u043c \u0438\u0437 6 \u0443\u043a\u0440\u0430\u0438\u043d\u0441\u043a\u0438\u0445 \"\u0433\u0435\u0440\u0430\u043d\u0435\u043f\u043e\u0434\u043e\u0431\u043d\u044b\u0445\" \u0434\u0440\u043e\u043d\u043e\u0432-\u043a\u0430\u043c\u0438\u043a\u0430\u0434\u0437\u0435 \"\u0421i\u0447\u0435\u043d\u044c\" (\"\u042f\u043d\u0432\u0430\u0440\u044c\") \u043e\u0434\u0438\u043d \u0437\u0430 \u043e\u0434\u043d\u0438\u043c \u043f\u0440\u043e\u043b\u0435\u0442\u0430\u0435\u0442 \u0432 \u0441\u0442\u043e\u0440\u043e\u043d\u0443 \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0433\u043e \u041d\u041f\u0417 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0433\u043e \u043d\u0430\u043b\u0435\u0442\u0430. \u0412\u043f\u0435\u0440\u0432\u044b\u0435 \u0434\u0430\u043d\u043d\u044b\u0439 \u0434\u0440\u043e\u043d \u0431\u044b\u043b \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d \u0432 \u0430\u043f\u0440\u0435\u043b\u0435 2026 \u0433\u043e\u0434\u0430. \u0417\u0430\u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f, \u0447\u0442\u043e \"\u0421\u0438\u0447\u0435\u043d\u044c\" \u043d\u0435\u0441\u0435\u0442 \u0411\u0427 \u043c\u0430\u0441\u0441\u043e\u0439 40 \u043a\u0433 \u043d\u0430 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0434\u043e 1400 \u043a\u043c \u0441 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0439 \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c\u044e \u043f\u043e\u043b\u0435\u0442\u0430 \u0434\u043e 200 \u043a\u043c/\u0447. \u041a\u0430\u043a \u0438 \u0433\u043e\u0432\u043e\u0440\u0438\u043b\u043e\u0441\u044c \u0440\u0430\u043d\u0435\u0435 - \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u043f\u0440\u0438\u043c\u0435\u043d\u0438\u043b \u043f\u043e \u041c\u043e\u0441\u043a\u0432\u0435 \u0435\u0434\u0432\u0430 \u043b\u0438 \u043d\u0435 \u0432\u0441", "snippet_en": "\u0421\u0442\u0430\u044f \u043c\u0438\u043d\u0438\u043c\u0443\u043c \u0438\u0437 6 \u0443\u043a\u0440\u0430\u0438\u043d\u0441\u043a\u0438\u0445 \"\u0433\u0435\u0440\u0430\u043d\u0435\u043f\u043e\u0434\u043e\u0431\u043d\u044b\u0445\" \u0434\u0440\u043e\u043d\u043e\u0432-\u043a\u0430\u043c\u0438\u043a\u0430\u0434\u0437\u0435 \"\u0421i\u0447\u0435\u043d\u044c\" (\"\u042f\u043d\u0432\u0430\u0440\u044c\") \u043e\u0434\u0438\u043d \u0437\u0430 \u043e\u0434\u043d\u0438\u043c \u043f\u0440\u043e\u043b\u0435\u0442\u0430\u0435\u0442 \u0432 \u0441\u0442\u043e\u0440\u043e\u043d\u0443 \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0433\u043e \u041d\u041f\u0417 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0433\u043e \u043d\u0430\u043b\u0435\u0442\u0430. \u0412\u043f\u0435\u0440\u0432\u044b\u0435 \u0434\u0430\u043d\u043d\u044b\u0439 \u0434\u0440\u043e\u043d \u0431\u044b\u043b \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d \u0432 \u0430\u043f\u0440\u0435\u043b\u0435 2026 \u0433\u043e\u0434\u0430. \u0417\u0430\u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f, \u0447\u0442\u043e \"\u0421\u0438\u0447\u0435\u043d\u044c\" \u043d\u0435\u0441\u0435\u0442 \u0411\u0427 \u043c\u0430\u0441\u0441\u043e\u0439 40 \u043a\u0433 \u043d\u0430 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0434\u043e 1400 \u043a\u043c \u0441 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0439 \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c\u044e \u043f\u043e\u043b\u0435\u0442\u0430 \u0434\u043e 200 \u043a\u043c/\u0447. \u041a\u0430\u043a \u0438 \u0433\u043e\u0432\u043e\u0440\u0438\u043b\u043e\u0441\u044c \u0440\u0430\u043d\u0435\u0435 - \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u043f\u0440\u0438\u043c\u0435\u043d\u0438\u043b \u043f\u043e \u041c\u043e\u0441\u043a\u0432\u0435 \u0435\u0434\u0432\u0430 \u043b\u0438 \u043d\u0435 \u0432\u0441", "link": "https://t.me/VictoryDrones/57933", "pubDate": "2026-06-18T21:49:47+00:00"}, {"channel": "VictoryDrones", "snippet": "\u0421\u0412\u0423 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430, \u043c\u0435\u043b\u043a\u043e\u0441\u0435\u0440\u0438\u0439\u043d\u0430\u044f \u043e\u0441\u043a\u043e\u043b\u043e\u0447\u043d\u0430\u044f \u043c\u0438\u043d\u0430 \u0441 \u0433\u043e\u0442\u043e\u0432\u044b\u043c\u0438 \u043f\u043e\u0440\u0430\u0436\u0430\u044e\u0449\u0438\u043c\u0438 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u0430\u043c\u0438, \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u0442\u0441\u044f \u0434\u043b\u044f \u043c\u0438\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0441 \u0411\u043f\u041b\u0410, \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0442\u0441\u044f \u0441 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u043e\u0439 \u043c\u0430\u0441\u043a\u0438\u0440\u043e\u0432\u043a\u043e\u0439 \u043f\u043e\u0434 \u0443\u0441\u043b\u043e\u0432\u0438\u044f \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f. \u041a\u043e\u0440\u043f\u0443\u0441 \u043d\u0430\u043f\u0435\u0447\u0430\u0442\u0430\u043d \u043d\u0430 3\u0434 \u043f\u0440\u0438\u043d\u0442\u0435\u0440\u0435. \u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0437\u0430\u0440\u044f\u0434 - \u043f\u043b\u0430\u0441\u0442\u0438\u0447\u043d\u043e\u0435 \u0412\u0412, \u043d\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u0438 \u043b\u0438\u0442\u044b\u0445 \u0437\u0430\u0440\u044f\u0434\u043e\u0432. \u0414\u0430\u0442\u0447\u0438\u043a \u0446\u0435\u043b\u0438 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u043c\u0430\u0433\u043d\u0438\u0442\u043e\u043c\u0435\u0442\u0440\u0430-\u0430\u043a\u0441\u0435\u043b\u0435\u0440\u043e\u043c\u0435\u0442\u0440\u0430 - \u0434\u0436\u043e\u043d\u0438\u043a, \u0432\u0435\u0440\u0441\u0438\u044f \u0441 \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c \u0434\u0430\u043b\u044c\u043d\u0435\u0433\u043e \u0432\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u044f 10 \u043c\u0438\u043d\u0443\u0442 \u0441\u0430\u043c\u043e\u043b\u0438\u043a\u0432\u0438\u0434\u0430\u0446\u0438\u0435", "snippet_en": "\u0421\u0412\u0423 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430, \u043c\u0435\u043b\u043a\u043e\u0441\u0435\u0440\u0438\u0439\u043d\u0430\u044f \u043e\u0441\u043a\u043e\u043b\u043e\u0447\u043d\u0430\u044f \u043c\u0438\u043d\u0430 \u0441 \u0433\u043e\u0442\u043e\u0432\u044b\u043c\u0438 \u043f\u043e\u0440\u0430\u0436\u0430\u044e\u0449\u0438\u043c\u0438 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u0430\u043c\u0438, \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u0442\u0441\u044f \u0434\u043b\u044f \u043c\u0438\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0441 \u0411\u043f\u041b\u0410, \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0442\u0441\u044f \u0441 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u043e\u0439 \u043c\u0430\u0441\u043a\u0438\u0440\u043e\u0432\u043a\u043e\u0439 \u043f\u043e\u0434 \u0443\u0441\u043b\u043e\u0432\u0438\u044f \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f. \u041a\u043e\u0440\u043f\u0443\u0441 \u043d\u0430\u043f\u0435\u0447\u0430\u0442\u0430\u043d \u043d\u0430 3\u0434 \u043f\u0440\u0438\u043d\u0442\u0435\u0440\u0435. \u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0437\u0430\u0440\u044f\u0434 - \u043f\u043b\u0430\u0441\u0442\u0438\u0447\u043d\u043e\u0435 \u0412\u0412, \u043d\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u0438 \u043b\u0438\u0442\u044b\u0445 \u0437\u0430\u0440\u044f\u0434\u043e\u0432. \u0414\u0430\u0442\u0447\u0438\u043a \u0446\u0435\u043b\u0438 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u043c\u0430\u0433\u043d\u0438\u0442\u043e\u043c\u0435\u0442\u0440\u0430-\u0430\u043a\u0441\u0435\u043b\u0435\u0440\u043e\u043c\u0435\u0442\u0440\u0430 - \u0434\u0436\u043e\u043d\u0438\u043a, \u0432\u0435\u0440\u0441\u0438\u044f \u0441 \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c \u0434\u0430\u043b\u044c\u043d\u0435\u0433\u043e \u0432\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u044f 10 \u043c\u0438\u043d\u0443\u0442 \u0441\u0430\u043c\u043e\u043b\u0438\u043a\u0432\u0438\u0434\u0430\u0446\u0438\u0435", "link": "https://t.me/VictoryDrones/57921", "pubDate": "2026-06-18T21:47:35+00:00"}, {"channel": "VictoryDrones", "snippet": "\u0412 \u0445\u043e\u0434\u0435 \u0430\u0442\u0430\u043a\u0438 \u0411\u041f\u041b\u0410 \u0432 \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0438\u0441\u044c \u0443\u043a\u0440\u0430\u0438\u043d\u0441\u043a\u0438\u0435 \u0434\u0440\u043e\u043d\u044b-\u043a\u0430\u043c\u0438\u043a\u0430\u0434\u0437\u0435 \"\u041b\u044e\u0442\u044b\u0439\" \u0438 \"FP-1\" \u0421\u0435\u0433\u043e\u0434\u043d\u044f \u0431\u044b\u043b\u0430 \u043e\u0434\u043d\u0430 \u0438\u0437 \u0441\u0430\u043c\u044b\u0445 \u043c\u0430\u0441\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0442\u0435\u0440\u0440\u043e\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0430\u0442\u0430\u043a \u041a\u0438\u0435\u0432\u0430. \u041d\u0430 \u043f\u043e\u0434\u043b\u0451\u0442\u0435 \u043a \u041c\u043e\u0441\u043a\u0432\u0435 \u0431\u044b\u043b\u043e \u0441\u0431\u0438\u0442\u043e \u0431\u043e\u043b\u0435\u0435 200 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u0438\u0445 \u0411\u041f\u041b\u0410. \u0427\u0442\u043e \u043a\u0430\u0441\u0430\u0435\u0442\u0441\u044f \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u0438\u043a\u043e\u0432, \u0442\u043e \u043e\u043d\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u044b \u043f\u0440\u0435\u043e\u0434\u043e\u043b\u0435\u0432\u0430\u0442\u044c \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u044e \u0432 1500 \u043a\u043c. \u0412 \u0445\u043e\u0434\u0435 \u043c\u0430\u0441\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u0430 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u0441\u043c\u043e\u0433 \u043f\u0435\u0440\u0435\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u0447\u0430\u0441\u0442\u044c \u0441\u0438\u0441\u0442\u0435\u043c \u041f\u0412\u041e, \u0437\u0430 \u0441\u0447\u0435\u0442 \u0447\u0435\u0433\u043e \u0431\u044b\u043b \u043e\u0431\u0440\u0430\u0437\u043e\u0432", "snippet_en": "\u0412 \u0445\u043e\u0434\u0435 \u0430\u0442\u0430\u043a\u0438 \u0411\u041f\u041b\u0410 \u0432 \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0438\u0441\u044c \u0443\u043a\u0440\u0430\u0438\u043d\u0441\u043a\u0438\u0435 \u0434\u0440\u043e\u043d\u044b-\u043a\u0430\u043c\u0438\u043a\u0430\u0434\u0437\u0435 \"\u041b\u044e\u0442\u044b\u0439\" \u0438 \"FP-1\" \u0421\u0435\u0433\u043e\u0434\u043d\u044f \u0431\u044b\u043b\u0430 \u043e\u0434\u043d\u0430 \u0438\u0437 \u0441\u0430\u043c\u044b\u0445 \u043c\u0430\u0441\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0442\u0435\u0440\u0440\u043e\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0430\u0442\u0430\u043a \u041a\u0438\u0435\u0432\u0430. \u041d\u0430 \u043f\u043e\u0434\u043b\u0451\u0442\u0435 \u043a \u041c\u043e\u0441\u043a\u0432\u0435 \u0431\u044b\u043b\u043e \u0441\u0431\u0438\u0442\u043e \u0431\u043e\u043b\u0435\u0435 200 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u0438\u0445 \u0411\u041f\u041b\u0410. \u0427\u0442\u043e \u043a\u0430\u0441\u0430\u0435\u0442\u0441\u044f \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u0438\u043a\u043e\u0432, \u0442\u043e \u043e\u043d\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u044b \u043f\u0440\u0435\u043e\u0434\u043e\u043b\u0435\u0432\u0430\u0442\u044c \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u044e \u0432 1500 \u043a\u043c. \u0412 \u0445\u043e\u0434\u0435 \u043c\u0430\u0441\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u0430 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u0441\u043c\u043e\u0433 \u043f\u0435\u0440\u0435\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u0447\u0430\u0441\u0442\u044c \u0441\u0438\u0441\u0442\u0435\u043c \u041f\u0412\u041e, \u0437\u0430 \u0441\u0447\u0435\u0442 \u0447\u0435\u0433\u043e \u0431\u044b\u043b \u043e\u0431\u0440\u0430\u0437\u043e\u0432", "link": "https://t.me/VictoryDrones/57920", "pubDate": "2026-06-18T21:47:32+00:00"}, {"channel": "OSINTdefender", "snippet": "#Ukraine #Russia Rostec has unveiled an updated Molniya-class FPV, designated as the \"Lightning 13.\" The primary distinction from the Molniya-2 is an enlarged airframe and the utilization of four electric motors rather than two. This modification has facilitated an increase in payload capacity. Subscribe to @OSINTdefender Chat room", "snippet_en": "#Ukraine #Russia Rostec has unveiled an updated Molniya-class FPV, designated as the \"Lightning 13.\" The primary distinction from the Molniya-2 is an enlarged airframe and the utilization of four electric motors rather than two. This modification has facilitated an increase in payload capacity. Subscribe to @OSINTdefender Chat room", "link": "https://t.me/OSINTdefender/19269", "pubDate": "2026-06-18T18:01:19+00:00"}, {"channel": "VictoryDrones2023", "snippet": "\u2757\ufe0f\u043c\u043e\u0441\u043a\u0432\u0430 \u0431\u0456\u043b\u044c\u0448\u0435 \u043d\u0435 \u0432\u0456\u0434\u0447\u0443\u0432\u0430\u0454 \u0441\u0435\u0431\u0435 \u0432 \u0431\u0435\u0437\u043f\u0435\u0446\u0456: \u0430\u043d\u0430\u043b\u0456\u0442\u0438\u043a\u0438 Times of Ukraine \u0440\u043e\u0437\u0431\u0438\u0440\u0430\u044e\u0442\u044c, \u043f\u0440\u043e \u0449\u043e \u0441\u0432\u0456\u0434\u0447\u0438\u0442\u044c \u043f\u0440\u043e\u0440\u0438\u0432 3-\u0445 \u043a\u0456\u043b\u0435\u0446\u044c \u041f\u041f\u041e \u0441\u0442\u043e\u043b\u0438\u0446\u0456 \u0440\u0444. \u2b55\ufe0f\u0429\u0435 \u0440\u0456\u043a \u0442\u043e\u043c\u0443 \u0443\u0434\u0430\u0440\u0438 \u043f\u043e \u0433\u043e\u043b\u043e\u0432\u043d\u043e\u043c\u0443 \u043c\u0456\u0441\u0442\u0443 \u0440\u043e\u0441\u0456\u0457 \u0441\u043f\u0440\u0438\u0439\u043c\u0430\u043b\u0438\u0441\u044f \u044f\u043a \u043c\u0440\u0456\u0457. \u0421\u044c\u043e\u0433\u043e\u0434\u043d\u0456 \u2014 \u0443\u0436\u0435 2-\u0433\u0430 \u0430\u0442\u0430\u043a\u0430 \u0437\u0430 3 \u0434\u043d\u0456: \u0414\u043b\u044f \u043f\u0435\u0440\u0435\u0441\u0456\u0447\u043d\u043e\u0433\u043e \u0440\u043e\u0441\u0456\u044f\u043d\u0438\u043d\u0430 \u0432\u0456\u0439\u043d\u0430 \u0434\u0435\u0441\u044f\u0442\u0438\u043b\u0456\u0442\u0442\u044f\u043c\u0438 \u0431\u0443\u043b\u0430 \u0442\u0435\u043b\u0435\u0432\u0456\u0437\u043e\u0440\u043e\u043c. \u0412\u043e\u043d\u0430 \u0456\u0441\u043d\u0443\u0432\u0430\u043b\u0430 \u0434\u0435\u0441\u044c \u0434\u0430\u043b\u0435\u043a\u043e \u2014 \u0443 \u0421\u0438\u0440\u0456\u0457, \u0427\u0435\u0447\u043d\u0456, \u0413\u0440\u0443\u0437\u0456\u0457 \u0447\u0438 \u0423\u043a\u0440\u0430\u0457\u043d\u0456. \u043a\u0440\u0435\u043c\u043b\u044c \u0431\u0443\u0434\u0443\u0432\u0430\u0432 \u043c\u043e\u0434\u0435\u043b\u044c, \u0434\u0435 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044f \u043f\u0456", "snippet_en": "\u2757\ufe0f\u043c\u043e\u0441\u043a\u0432\u0430 \u0431\u0456\u043b\u044c\u0448\u0435 \u043d\u0435 \u0432\u0456\u0434\u0447\u0443\u0432\u0430\u0454 \u0441\u0435\u0431\u0435 \u0432 \u0431\u0435\u0437\u043f\u0435\u0446\u0456: \u0430\u043d\u0430\u043b\u0456\u0442\u0438\u043a\u0438 Times of Ukraine \u0440\u043e\u0437\u0431\u0438\u0440\u0430\u044e\u0442\u044c, \u043f\u0440\u043e \u0449\u043e \u0441\u0432\u0456\u0434\u0447\u0438\u0442\u044c \u043f\u0440\u043e\u0440\u0438\u0432 3-\u0445 \u043a\u0456\u043b\u0435\u0446\u044c \u041f\u041f\u041e \u0441\u0442\u043e\u043b\u0438\u0446\u0456 \u0440\u0444. \u2b55\ufe0f\u0429\u0435 \u0440\u0456\u043a \u0442\u043e\u043c\u0443 \u0443\u0434\u0430\u0440\u0438 \u043f\u043e \u0433\u043e\u043b\u043e\u0432\u043d\u043e\u043c\u0443 \u043c\u0456\u0441\u0442\u0443 \u0440\u043e\u0441\u0456\u0457 \u0441\u043f\u0440\u0438\u0439\u043c\u0430\u043b\u0438\u0441\u044f \u044f\u043a \u043c\u0440\u0456\u0457. \u0421\u044c\u043e\u0433\u043e\u0434\u043d\u0456 \u2014 \u0443\u0436\u0435 2-\u0433\u0430 \u0430\u0442\u0430\u043a\u0430 \u0437\u0430 3 \u0434\u043d\u0456: \u0414\u043b\u044f \u043f\u0435\u0440\u0435\u0441\u0456\u0447\u043d\u043e\u0433\u043e \u0440\u043e\u0441\u0456\u044f\u043d\u0438\u043d\u0430 \u0432\u0456\u0439\u043d\u0430 \u0434\u0435\u0441\u044f\u0442\u0438\u043b\u0456\u0442\u0442\u044f\u043c\u0438 \u0431\u0443\u043b\u0430 \u0442\u0435\u043b\u0435\u0432\u0456\u0437\u043e\u0440\u043e\u043c. \u0412\u043e\u043d\u0430 \u0456\u0441\u043d\u0443\u0432\u0430\u043b\u0430 \u0434\u0435\u0441\u044c \u0434\u0430\u043b\u0435\u043a\u043e \u2014 \u0443 \u0421\u0438\u0440\u0456\u0457, \u0427\u0435\u0447\u043d\u0456, \u0413\u0440\u0443\u0437\u0456\u0457 \u0447\u0438 \u0423\u043a\u0440\u0430\u0457\u043d\u0456. \u043a\u0440\u0435\u043c\u043b\u044c \u0431\u0443\u0434\u0443\u0432\u0430\u0432 \u043c\u043e\u0434\u0435\u043b\u044c, \u0434\u0435 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044f \u043f\u0456", "link": "https://t.me/VictoryDrones2023/27395", "pubDate": "2026-06-18T17:06:36+00:00"}, {"channel": "lost_armour", "snippet": "\ud83d\udd34 \u041c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043d\u0430\u044f \u0432\u043e\u0439\u043d\u0430 \u0411\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0435 \u0431\u0430\u0442\u0430\u043b\u0438\u0438 \u0432 \u043d\u0435\u0431\u0435 \u0421\u0412\u041e \u0441\u0442\u0430\u043d\u043e\u0432\u044f\u0442\u0441\u044f \u0432\u0441\u0435 \u0438\u043d\u0442\u0435\u043d\u0441\u0438\u0432\u043d\u0435\u0435. \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u044b \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u043f\u043e\u0440\u0430\u0437\u0438\u043b\u0438 \u0443\u0436\u0435 \u0441\u0432\u044b\u0448\u0435 8000 \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043e\u0432 \u0412\u0421\u0423, \u0438\u0437 \u043d\u0438\u0445 \u0431\u043e\u043b\u0435\u0435 1000 - \u0442\u043e\u043b\u044c\u043a\u043e \u0441 \u043d\u0430\u0447\u0430\u043b\u0430 \u0438\u044e\u043d\u044f 2026 \u0433\u043e\u0434\u0430. \u0420\u0430\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u043f\u043e \u0442\u0438\u043f\u0430\u043c \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u043d\u044b\u0445 \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043e\u0432 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430: \u2022 76,6% - \u0422\u044f\u0436\u0435\u043b\u044b\u0435 \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u044b (\u0442.\u043d. \"\u0411\u0430\u0431\u0430-\u042f\u0433\u0430\") \u2022 15,6% - \u041b\u0435\u0433\u043a\u0438\u0435 \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u044b (Mavic, Matrice, Autel \u0438 \u043f\u0440.) \u2022 6,2% - FPV-\u0434\u0440\u043e\u043d\u044b \u043f\u0440\u043e", "snippet_en": "\ud83d\udd34 \u041c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u043f\u0442\u0435\u0440\u043d\u0430\u044f \u0432\u043e\u0439\u043d\u0430 \u0411\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0435 \u0431\u0430\u0442\u0430\u043b\u0438\u0438 \u0432 \u043d\u0435\u0431\u0435 \u0421\u0412\u041e \u0441\u0442\u0430\u043d\u043e\u0432\u044f\u0442\u0441\u044f \u0432\u0441\u0435 \u0438\u043d\u0442\u0435\u043d\u0441\u0438\u0432\u043d\u0435\u0435. \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u044b \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u043f\u043e\u0440\u0430\u0437\u0438\u043b\u0438 \u0443\u0436\u0435 \u0441\