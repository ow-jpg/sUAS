0441\u0435\u0440\u0435\u0434\u0436\u0435\u043d\u043d\u044f \u043e\u0441\u043e\u0431\u043e\u0432\u043e\u0433\u043e \u0441\u043a\u043b\u0430\u0434\u0443 \u0442\u0430 \u043e\u0431\u2019\u0454\u043a\u0442\u0430\u0445 \u043c\u0430\u0442\u0435\u0440\u0456\u0430\u043b\u044c\u043d\u043e-\u0442\u0435\u0445\u043d\u0456\u0447\u043d\u043e\u0433\u043e \u0437\u0430\u0431\u0435\u0437\u043f\u0435\u0447\u0435\u043d\u043d\u044f \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 5 \u0442\u0440\u0430\u0432\u043d\u044f \u0423 \u041b\u0443\u0433\u0430\u043d\u0441\u044c\u043a\u0456\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0456 \u043f\u0456\u043b\u043e\u0442\u0438 9 \u0431\u0430\u0442\u0430\u043b\u044c\u0439\u043e\u043d\u0443 \u00ab\u041a\u0430\u0439\u0440\u043e\u0441\u00bb 414-\u0457 \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u00ab\u041f\u0442\u0430\u0445\u0438 \u041c\u0430\u0434\u044f\u0440\u0430\u00bb \u0443\u0440\u0430\u0437\u0438\u043b\u0438 \u043f\u0443\u043d\u043a\u0442 \u0434\u0438\u0441\u043b\u043e\u043a\u0430\u0446\u0456\u0457 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430, \u0430 \u0441\u0430\u043c\u0435 \u043d\u0430\u0432\u0447\u0430\u043b\u044c\u043d\u0438\u0439 \u0446\u0435\u043d\u0442\u0440 \u043f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0456\u0432 \u0411\u043f\u041b\u0410. \u041e\u043f\u0435\u0440\u0430\u0446\u0456\u044e \u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u043e \u0441\u043f\u0456\u043b\u044c\u043d\u043e \u0437 \u0426\u0421\u041e \u00ab\u0410\u00bb \u0421\u0411\u0423. \u0412\u043e\u0434\u043d\u043e\u0447\u0430\u0441 413-\u0439 \u043f\u043e\u043b\u043a \u00ab\u0420\u0435\u0439\u0434\u00bb \u0443\u0440\u0430\u0437\u0438\u0432 \u0441\u043a\u043b\u0430\u0434\u0438 \u043c\u0430\u0442\u0435\u0440\u0456\u0430\u043b", "link": "https://t.me/VictoryDrones2023/26806", "pubDate": "2026-05-07T06:03:41+00:00"}, {"channel": "VictoryDrones2023", "snippet": "\ud83c\uddfa\ud83c\udde6 \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0438 \u0411\u043f\u041b\u0410 1-\u0457 \u043e\u043a\u0440\u0435\u043c\u043e\u0457 \u0432\u0430\u0436\u043a\u043e\u0457 \u043c\u0435\u0445\u0430\u043d\u0456\u0437\u043e\u0432\u0430\u043d\u043e\u0457 \u0421\u0456\u0432\u0435\u0440\u0441\u044c\u043a\u043e\u0457 \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0432\u043e\u0440\u043e\u0436\u043e\u0433\u043e \u0448\u0442\u0443\u0440\u043c\u0443 \u043d\u0430 \u0421\u0443\u043c\u0449\u0438\u043d\u0456 \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u043e \u0432\u0438\u044f\u0432\u0438\u043b\u0438 \u0433\u0440\u0443\u043f\u0443 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0431\u0456\u043b\u044f \u0443\u043a\u0440\u0430\u0457\u043d\u0441\u044c\u043a\u0438\u0445 \u043f\u043e\u0437\u0438\u0446\u0456\u0439 \u0456 \u043f\u0435\u0440\u0435\u0434\u0430\u043b\u0438 \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u0438. \u0417\u0430\u0432\u0434\u044f\u043a\u0438 \u0448\u0432\u0438\u0434\u043a\u0456\u0439 \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0446\u0456\u0457 \u043c\u0456\u0436 \u0440\u043e\u0437\u0432\u0456\u0434\u043d\u0438\u043a\u0430\u043c\u0438, FPV-\u043f\u0456\u043b\u043e\u0442\u0430\u043c\u0438 \u0442\u0430 \u0435\u043a\u0456\u043f\u0430\u0436\u0435\u043c \u0431\u043e\u043c\u0431\u0435\u0440\u0430, \u043f\u043e \u0432\u043e\u0440\u043e\u0433\u0443 \u0431\u0443\u043b\u043e \u0437\u0430\u0432\u0434\u0430\u043d\u043e \u0442\u043e\u0447\u043d\u0438\u0445 \u0443\u0434\u0430\u0440\u0456\u0432 \u0437 \u043f\u043e\u0432\u0456\u0442\u0440\u044f. \u0423 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456 \u0448\u0442\u0443\u0440\u043c \u0437\u0456\u0440\u0432\u0430\u043d\u043e, \u0437\u043d\u0438\u0449\u0435\u043d\u043e \u0442\u0430 \u043f\u043e\u0440\u0430\u043d\u0435\u043d\u043e \u043f\u043e\u043d\u0430\u0434 20 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432 \u0442\u043e\u0436 \u0432\u043e\u0440\u043e\u0433 \u043d\u0435 \u0437\u043c\u0456", "snippet_en": "\ud83c\uddfa\ud83c\udde6 \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0438 \u0411\u043f\u041b\u0410 1-\u0457 \u043e\u043a\u0440\u0435\u043c\u043e\u0457 \u0432\u0430\u0436\u043a\u043e\u0457 \u043c\u0435\u0445\u0430\u043d\u0456\u0437\u043e\u0432\u0430\u043d\u043e\u0457 \u0421\u0456\u0432\u0435\u0440\u0441\u044c\u043a\u043e\u0457 \u0431\u0440\u0438\u0433\u0430\u0434\u0438 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0432\u043e\u0440\u043e\u0436\u043e\u0433\u043e \u0448\u0442\u0443\u0440\u043c\u0443 \u043d\u0430 \u0421\u0443\u043c\u0449\u0438\u043d\u0456 \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u043e \u0432\u0438\u044f\u0432\u0438\u043b\u0438 \u0433\u0440\u0443\u043f\u0443 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0431\u0456\u043b\u044f \u0443\u043a\u0440\u0430\u0457\u043d\u0441\u044c\u043a\u0438\u0445 \u043f\u043e\u0437\u0438\u0446\u0456\u0439 \u0456 \u043f\u0435\u0440\u0435\u0434\u0430\u043b\u0438 \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u0438. \u0417\u0430\u0432\u0434\u044f\u043a\u0438 \u0448\u0432\u0438\u0434\u043a\u0456\u0439 \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0446\u0456\u0457 \u043c\u0456\u0436 \u0440\u043e\u0437\u0432\u0456\u0434\u043d\u0438\u043a\u0430\u043c\u0438, FPV-\u043f\u0456\u043b\u043e\u0442\u0430\u043c\u0438 \u0442\u0430 \u0435\u043a\u0456\u043f\u0430\u0436\u0435\u043c \u0431\u043e\u043c\u0431\u0435\u0440\u0430, \u043f\u043e \u0432\u043e\u0440\u043e\u0433\u0443 \u0431\u0443\u043b\u043e \u0437\u0430\u0432\u0434\u0430\u043d\u043e \u0442\u043e\u0447\u043d\u0438\u0445 \u0443\u0434\u0430\u0440\u0456\u0432 \u0437 \u043f\u043e\u0432\u0456\u0442\u0440\u044f. \u0423 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456 \u0448\u0442\u0443\u0440\u043c \u0437\u0456\u0440\u0432\u0430\u043d\u043e, \u0437\u043d\u0438\u0449\u0435\u043d\u043e \u0442\u0430 \u043f\u043e\u0440\u0430\u043d\u0435\u043d\u043e \u043f\u043e\u043d\u0430\u0434 20 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432 \u0442\u043e\u0436 \u0432\u043e\u0440\u043e\u0433 \u043d\u0435 \u0437\u043c\u0456", "link": "https://t.me/VictoryDrones2023/26804", "pubDate": "2026-05-07T03:19:17+00:00"}, {"channel": "lost_armour", "snippet": "\u042d\u043f\u0438\u0437\u043e\u0434\u044b \u0431\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0434\u0440\u043e\u043d\u043e\u0432-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\", \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u044e\u0449\u0438\u0445 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442 \u0443\u0434\u0430\u0440\u043d\u044b\u0445 \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423. \u0418\u0441\u0442\u043e\u0447\u043d\u0438\u043a: @pomogaemZVO \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \"\u0415\u043b\u043e\u043a\": https://lostarmour.info/tags/elka \ud83d\udd39 \u041c\u044b \u0432 MAX", "snippet_en": "\u042d\u043f\u0438\u0437\u043e\u0434\u044b \u0431\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0434\u0440\u043e\u043d\u043e\u0432-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\", \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u044e\u0449\u0438\u0445 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442 \u0443\u0434\u0430\u0440\u043d\u044b\u0445 \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423. \u0418\u0441\u0442\u043e\u0447\u043d\u0438\u043a: @pomogaemZVO \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \"\u0415\u043b\u043e\u043a\": https://lostarmour.info/tags/elka \ud83d\udd39 \u041c\u044b \u0432 MAX", "link": "https://t.me/lost_armour/9250", "pubDate": "2026-05-06T17:25:18+00:00"}, {"channel": "serhii_flash", "snippet": "\u041e\u0441\u043a\u0456\u043b\u044c\u043a\u0438 \u044f \u0432\u0436\u0435 \u0437\u0430\u0447\u0435\u043f\u0438\u0432 \u0442\u0435\u043c\u0443 \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440\u0456\u0432 FPV, \u0442\u043e \u0441\u043a\u0430\u0436\u0443, \u0449\u043e \u044f, \u043c\u0430\u0431\u0443\u0442\u044c, \u043f\u0440\u043e\u0442\u0435\u0441\u0442\u0443\u0432\u0430\u0432 \u0443\u0441\u0435, \u0449\u043e \u0454 \u043d\u0430 \u0440\u0438\u043d\u043a\u0443, \u0442\u0430 \u0432\u0430\u0436\u0430\u044e, \u0449\u043e \u0456\u0434\u0435\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0438\u0440\u043e\u0431\u0443 \u043d\u0435 \u0456\u0441\u043d\u0443\u0454. \u0423 \u043a\u043e\u0436\u043d\u043e\u0433\u043e \u0454 \u0441\u0432\u043e\u0457 \u043d\u044e\u0430\u043d\u0441\u0438. \u0422\u043e\u043c\u0443 \u043d\u0430 \u0444\u0440\u043e\u043d\u0442\u0430 \u044f \u0432\u0438\u0440\u0443\u0448\u0430\u044e, \u043c\u0430\u044e\u0447\u0438 \u043f\u0440\u0438 \u0441\u043e\u0431\u0456 \u043a\u0456\u043b\u044c\u043a\u0430 \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440\u0456\u0432. \u0412\u043e\u043d\u0438 \u043a\u043e\u043c\u043f\u0435\u043d\u0441\u0443\u044e\u0442\u044c \u043d\u0435\u0434\u043e\u043b\u0456\u043a\u0438 \u043e\u0434\u0438\u043d \u043e\u0434\u043d\u043e\u0433\u043e. \u042f \u0442\u0435\u0441\u0442\u0443\u044e \u0437\u0440\u0430\u0437\u043a\u0438, \u0434\u0430\u044e \u043f\u043e\u0440\u0430\u0434\u0438 \u0449\u043e\u0434\u043e \u043d\u0435\u0434\u043e\u043b\u0456\u043a\u0456\u0432 \u0442\u0430 \u0441\u043f\u043e\u0441\u043e\u0431\u0456\u0432 \u0457\u0445 \u0443\u0441\u0443\u043d\u0435\u043d\u043d\u044f. \u0425\u0442\u043e\u0441\u044c \u0456\u0437 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u043a\u0456\u0432 \u0441\u043b\u0443\u0445\u0430\u0454, \u0445\u0442\u043e\u0441\u044c \u043d\u0456. \u041f\u0440\u0438 \u0446\u044c\u043e\u043c\u0443 \u044f \u043d\u0456\u043a\u043e\u043b\u0438 \u043d\u0435 \u0431\u0443\u0434\u0443 \u043f\u0438", "snippet_en": "\u041e\u0441\u043a\u0456\u043b\u044c\u043a\u0438 \u044f \u0432\u0436\u0435 \u0437\u0430\u0447\u0435\u043f\u0438\u0432 \u0442\u0435\u043c\u0443 \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440\u0456\u0432 FPV, \u0442\u043e \u0441\u043a\u0430\u0436\u0443, \u0449\u043e \u044f, \u043c\u0430\u0431\u0443\u0442\u044c, \u043f\u0440\u043e\u0442\u0435\u0441\u0442\u0443\u0432\u0430\u0432 \u0443\u0441\u0435, \u0449\u043e \u0454 \u043d\u0430 \u0440\u0438\u043d\u043a\u0443, \u0442\u0430 \u0432\u0430\u0436\u0430\u044e, \u0449\u043e \u0456\u0434\u0435\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0438\u0440\u043e\u0431\u0443 \u043d\u0435 \u0456\u0441\u043d\u0443\u0454. \u0423 \u043a\u043e\u0436\u043d\u043e\u0433\u043e \u0454 \u0441\u0432\u043e\u0457 \u043d\u044e\u0430\u043d\u0441\u0438. \u0422\u043e\u043c\u0443 \u043d\u0430 \u0444\u0440\u043e\u043d\u0442\u0430 \u044f \u0432\u0438\u0440\u0443\u0448\u0430\u044e, \u043c\u0430\u044e\u0447\u0438 \u043f\u0440\u0438 \u0441\u043e\u0431\u0456 \u043a\u0456\u043b\u044c\u043a\u0430 \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440\u0456\u0432. \u0412\u043e\u043d\u0438 \u043a\u043e\u043c\u043f\u0435\u043d\u0441\u0443\u044e\u0442\u044c \u043d\u0435\u0434\u043e\u043b\u0456\u043a\u0438 \u043e\u0434\u0438\u043d \u043e\u0434\u043d\u043e\u0433\u043e. \u042f \u0442\u0435\u0441\u0442\u0443\u044e \u0437\u0440\u0430\u0437\u043a\u0438, \u0434\u0430\u044e \u043f\u043e\u0440\u0430\u0434\u0438 \u0449\u043e\u0434\u043e \u043d\u0435\u0434\u043e\u043b\u0456\u043a\u0456\u0432 \u0442\u0430 \u0441\u043f\u043e\u0441\u043e\u0431\u0456\u0432 \u0457\u0445 \u0443\u0441\u0443\u043d\u0435\u043d\u043d\u044f. \u0425\u0442\u043e\u0441\u044c \u0456\u0437 \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u043a\u0456\u0432 \u0441\u043b\u0443\u0445\u0430\u0454, \u0445\u0442\u043e\u0441\u044c \u043d\u0456. \u041f\u0440\u0438 \u0446\u044c\u043e\u043c\u0443 \u044f \u043d\u0456\u043a\u043e\u043b\u0438 \u043d\u