u0441\u043d\u043e \u043d\u0435\u0434\u043e\u0440\u043e\u0433\u043e\u0433\u043e \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u044e, \u044f\u043a\u0438\u0439 \u043c\u0456\u0433 \u0431\u0438 \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0432\u0430\u0442\u0438 \u0441\u0438\u0433\u043d\u0430\u0442\u0443\u0440\u0438 \u0411\u041f\u041b\u0410. \u041f\u0440\u0438 \u0446\u044c\u043e\u043c\u0443 \u043c\u0430\u0439\u0436\u0435 \u043a\u043e\u0436\u0435\u043d \u0441\u043e\u043b\u0434\u0430\u0442 \u0420\u0424 \u043c\u0430\u0432 \u0456\u0437 \u0441\u043e\u0431\u043e\u044e \u043a\u0438\u0442\u0430\u0439\u0441\u044c\u043a\u0438\u0439 \u0434\u0435\u0442\u0435\u043a\u0442\u043e\u0440 \u00ab\u0411\u0443\u043b\u0430\u0442\u00bb, \u044f\u043a\u0438\u0439 \u0440\u043e\u0437\u0440\u0456\u0437\u043d\u044f\u0454 \u0442\u0438\u043f\u0438 \u0434\u0440\u043e\u043d\u0456\u0432. \u0412\u0447\u043e\u0440\u0430 \u043c\u0435\u043d\u0456 \u0434\u0430\u043b\u0438 \u043d\u0430 \u0442\u0435\u0441\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u043f\u0435\u0440\u0448\u0438\u0439 \u043d\u0430\u0448 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439, \u044f\u043a\u0438\u0439 \u0432\u043c\u0456\u0454 \u0446\u0435 \u0440\u043e\u0431\u0438\u0442\u0438. \u041f\u043e\u043a\u0438 \u0449\u043e \u0434\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c \u043d\u0435 \u0442\u0435\u0441\u0442\u0443\u0432\u0430\u0432, \u0430\u043b\u0435 \u0441\u0438\u0433\u043d\u0430\u0442\u0443\u0440\u0438 \u0440\u043e\u0437\u043f\u0456\u0437\u043d\u0430\u0454 \u0434\u043e\u0431\u0440\u0435. \u041d\u0430\u0432\u0456\u0442\u044c \u041c\u0415\u0428. \u0412\u043c\u0456\u0454 \u043a\u0435\u0440\u0443\u0432\u0430\u0442\u0438 ", "snippet_en": "\u041f\u0440\u043e\u0442\u044f\u0433\u043e\u043c \u0443\u0441\u0456\u0445 \u0440\u043e\u043a\u0456\u0432 \u0432\u0456\u0439\u043d\u0438 \u0443 \u043d\u0430\u0441 \u043d\u0435 \u0431\u0443\u043b\u043e \u043f\u043e\u0440\u0442\u0430\u0442\u0438\u0432\u043d\u043e\u0433\u043e, \u0441\u0435\u0440\u0456\u0439\u043d