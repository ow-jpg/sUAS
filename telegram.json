38 \u043f\u0430\u0440\u0430 \u043f\u0438\u043a\u0430\u043f\u043e\u0432. #\u0410\u0444\u0440\u0438\u043a\u0430 \u0412\u043e\u0435\u043d\u043d\u044b\u0439 \u041e\u0441\u0432\u0435\u0434\u043e\u043c\u0438\u0442\u0435\u043b\u044c", "snippet_en": "\u0423\u0434\u0430\u0440\u044b FPV-\u0434\u0440\u043e\u043d\u043e\u0432 \u0431\u043e\u0435\u0432\u0438\u043a\u043e\u0432 FLA \u043f\u043e \"\u0410\u0444\u0440\u0438\u043a\u0430\u043d\u0441\u043a\u043e\u043c\u0443 \u043a\u043e\u0440\u043f\u0443\u0441\u0443\" \u0438 \u0412\u0421 \u041c\u0430\u043b\u0438 \u043d\u0430 \u0431\u0430\u0437\u0435 \u0432 \u041a\u0438\u0434\u0430\u043b\u0435 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0431\u043e\u0435\u0432\u044b\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0432 \u0441\u0443\u0431\u0431\u043e\u0442\u0443. \u0410\u0442\u0430\u043a\u043e\u0432\u0430\u043d\u044b \u0431\u044b\u043b\u0438 \u0431\u0440\u043e\u043d\u0435\u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044c VP11 \u0438 \u043f\u0430\u0440\u0430 \u043f\u0438\u043a\u0430\u043f\u043e\u0432. #\u0410\u0444\u0440\u0438\u043a\u0430 \u0412\u043e\u0435\u043d\u043d\u044b\u0439 \u041e\u0441\u0432\u0435\u0434\u043e\u043c\u0438\u0442\u0435\u043b\u044c", "link": "https://t.me/VictoryDrones/55021", "pubDate": "2026-04-27T19:42:44+00:00"}, {"channel": "serhii_flash", "snippet": "\u042f \u0434\u043e\u0431\u0440\u0435 \u043f\u0430\u043c\u2019\u044f\u0442\u0430\u044e, \u044f\u043a \u043c\u0430\u0441\u043e\u0432\u043e \u0443\u0432\u0456\u0439\u0448\u043b\u0438 \u0443 \u0432\u0456\u0439\u043d\u0443 \u0411\u041f\u041b\u0410. \u041d\u0435\u0432\u0434\u043e\u0432\u0437\u0456 \u0437\u2019\u044f\u0432\u0438\u043b\u0438\u0441\u044f \u0443\u0434\u0430\u0440\u043d\u0456 \u043a\u0430\u0442\u0435\u0440\u0438. \u0406, \u0437\u0432\u0456\u0441\u043d\u043e, \u043d\u0430\u0437\u0435\u043c\u043d\u0456 \u0440\u043e\u0431\u043e\u0442\u0438. \u0412\u0456\u0439\u043d\u0430 \u0411\u041f\u041b\u0410 \u0440\u043e\u0437\u043f\u043e\u0447\u0430\u043b\u0430\u0441\u044f \u0443 \u0442\u0440\u044c\u043e\u0445 \u0441\u0442\u0438\u0445\u0456\u044f\u0445. \u0412 \u0423\u043a\u0440\u0430\u0457\u043d\u0456 \u0448\u0432\u0438\u0434\u043a\u043e \u0437'\u044f\u0432\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u0434\u0435\u0441\u044f\u0442\u043a\u0438 \u043a\u043e\u043c\u0430\u043d\u0434 \u0440\u043e\u0437\u0440\u043e\u0431\u043d\u0438\u043a\u0456\u0432 \u043d\u0430\u0439\u0440\u0456\u0437\u043d\u043e\u043c\u0430\u043d\u0456\u0442\u043d\u0456\u0448\u0438\u0445 \u043c\u043e\u0434\u0435\u043b\u0435\u0439. \u0412 \u043e\u0434\u0438\u043d \u043c\u043e\u043c\u0435\u043d\u0442 \u044f \u043d\u0430\u0440\u0430\u0445\u0443\u0432\u0430\u0432 \u0457\u0445 \u043f\u043e\u043d\u0430\u0434 50. \u0423 \u043a\u0440\u0430\u0457\u043d\u0456 \u0441\u043f\u043e\u0441\u0442\u0435\u0440\u0456\u0433\u0430\u0454\u0442\u044c\u0441\u044f \u0441\u043f\u0440\u0430\u0432\u0436\u043d\u0456\u0439 \u0431\u0443\u043c \u041d\u0420\u041a. 15 \u041d\u0420\u041a \u043e\u0442\u0440\u0438\u043c\u0443\u044e\u0442\u044c \u0441\u0435\u0440\u0442\u0438\u0444\u0456\u043a\u0430\u0442 \u041d\u0410\u0422\u041e \u0423 \u0431\u0430\u0433\u0430\u0442\u044c\u043e\u0445 \u0456\u043d\u0442\u0435\u0440\u0432'\u044e \u044f \u043d\u0430\u0437\u0438\u0432\u0430\u044e 2024-2025 \u0440\u043e\u043a\u0438 \u0440\u043e\u043a\u0430", "snippet_en": "\u042f \u0434\u043e\u0431\u0440\u0435 \u043f\u0430\u043c\u2019\u044f\u0442\u0430\u044e, \u044f\u043a \u043c\u0430\u0441\u043e\u0432\u043e \u0443\u0432\u0456\u0439\u0448\u043b\u0438 \u0443 \u0432\u0456\u0439\u043d\u0443 \u0411\u041f\u041b\u0410. \u041d\u0435\u0432\u0434\u043e\u0432\u0437\u0456 \u0437\u2019\u044f\u0432\u0438\u043b\u0438\u0441\u044f \u0443\u0434\u0430\u0440\u043d\u0456 \u043a\u0430\u0442\u0435\u0440\u0438. \u0406, \u0437\u0432\u0456\u0441\u043d\u043e, \u043d\u0430\u0437\u0435\u043c\u043d\u0456 \u0440\u043e\u0431\u043e\u0442\u0438. \u0412\u0456\u0439\u043d\u0430 \u0411\u041f\u041b\u0410 \u0440\u043e\u0437\u043f\u043e\u0447\u0430\u043b