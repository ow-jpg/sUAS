u0448\u0430\u044e\u0449\u0438\u0439 \u044d\u0442\u0430\u043f \u0434\u0435\u043e\u043a\u043a\u0443\u043f\u0430\u0446\u0438\u0438 \u041a\u0443\u0440\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438, \u043e\u0441\u0432\u043e\u0431\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u041a\u0440\u0430\u0441\u043d\u043e\u0430\u0440\u043c\u0435\u0439\u0441\u043a\u0430), \u0442\u043e \u0441 \u043d\u0430\u0447\u0430\u043b\u0430 2026-\u0433\u043e \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u0435\u0442\u0441\u044f \u044f\u0440\u043a\u043e \u0432\u044b\u0440\u0430\u0436\u0435\u043d\u043d\u0430\u044f \u0442\u0435\u043d\u0434\u0435\u043d\u0446\u0438\u044f \u043a \u0440\u043e\u0441\u0442\u0443", "snippet_en": "\ud83d\udd34 \u0427\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0438\u0439 \u0444\u0430\u043a\u0442\u043e\u0440 \u041e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u044b \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u043d\u0430\u043d\u0435\u0441\u043b\u0438 \u0441\u0432\u044b\u0448\u0435 1500 \u0443\u0434\u0430\u0440\u043e\u0432 \u043f\u043e \u043f\u0435\u0445\u043e\u0442\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0432\u043d\u0435 \u0443\u043a\u0440\u044b\u0442\u0438\u0439, \u0431\u043e\u043b\u0435\u0435 80% \u0438\u0437 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u043e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u044b \u0437\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0435 \u043f\u043e\u043b\u0433\u043e\u0434\u0430. \u0415\u0441\u043b\u0438 \u0432 2025-\u043c \u0433\u043e\u0434\u0443 \u0432\u0441\u043f\u043b\u0435\u0441\u043a\u0438 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0439 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u0439 \u043f\u0435\u0445\u043e\u0442\u044b \u0431\u044b\u043b\u0438 \u0441\u0432\u044f\u0437\u0430\u043d\u044b \u0441 \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u044b\u043c\u0438 \u043a\u0440\u0438\u0437\u0438\u0441\u0430\u043c\u0438 (\u0437\u0430\u0432\u0435\u0440\u0448\u0430\u044e\u0449\u0438\u0439 \u044d\u0442\u0430\u043f \u0434\u0435\u043e\u043a\u043a\u0443\u043f\u0430\u0446\u0438\u0438 \u041a\u0443\u0440\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438, \u043e\u0441\u0432\u043e\u0431\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u041a\u0440\u0430\u0441\u043d\u043e\u0430\u0440\u043c\u0435\u0439\u0441\u043a\u0430), \u0442\u043e \u0441 \u043d\u0430\u0447\u0430\u043b\u0430 2026-\u0433\u043e \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u0435\u0442\u0441\u044f \u044f\u0440\u043a\u043e \u0432\u044b\u0440\u0430\u0436\u0435\u043d\u043d\u0430\u044f \u0442\u0435\u043d\u0434\u0435\u043d\u0446\u0438\u044f \u043a \u0440\u043e\u0441\u0442\u0443", "link": "https://t.me/lost_armour/8773", "pubDate": "2026-03-31T16:16:01+00:00"}, {"channel": "lost_armour", "snippet": "\ud83d\udd34 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0434\u0435\u043d\u044c \u0437\u0430 \u0434\u043d\u0435\u043c&#33; \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0437\u0430 31 \u043c\u0430\u0440\u0442\u0430 2026 \u0433\u043e\u0434\u0430 \u2022 \u0414\u043e\u043d\u0431\u0430\u0441\u0441 \u2022 \u041a\u0440\u0430\u0441\u043d\u043e\u043b\u0438\u043c\u0430\u043d\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0421\u0443\u043c\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0436\u0438\u0432\u043e\u0439 \u0441\u0438\u043b\u044b \u0412\u0421\u0423 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0412\u0421\u0423 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d