43a\u043e\u043d\" \u0434\u0435\u043d\u044c \u0437\u0430 \u0434\u043d\u0435\u043c&#33; \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0426\u0435\u043d\u0442\u0440\u0430 \"\u0420\u0443\u0431\u0438\u043a\u043e\u043d\" \u0437\u0430 20 \u0438\u044e\u043d\u044f 2026 \u0433\u043e\u0434\u0430 \u2022 \u0414\u043e\u043d\u0431\u0430\u0441\u0441 \u2022 \u0411\u0435\u043b\u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u041a\u0440\u0430\u0441\u043d\u043e\u043b\u0438\u043c\u0430\u043d\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u0421\u0443\u043c\u0441\u043a\u043e\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u2022 \u041f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u043b\u0438\u0447\u043d\u043e\u0433\u043e \u0441\u043e\u0441\u0442\u0430\u0432\u0430 \u0412\u0421\u0423 \u2022 \u0414\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u043e\u043d\u043d\u043e\u0435 \u043c\u0438\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u043b\u043e\u0433\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u043e\u0432 \u0412\u0421\u0423 \u2022 \u0421\u0431\u0440\u043e\u0441\u044b \u043f\u043e \u0446\u0435\u043b\u044f\u043c \u0412\u0421\u0423 \u2022 \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u0434\u043d\u0435\u0432\u043d\u044b\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u043e\u0432 FPV-\u041f\u0412\u041e \u043f\u043e \u0411\u041f\u041b\u0410 \u0412\u0421\u0423 \u2022 \u0411\u043e\u0435\u0432\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u0440\u0430\u0441\u0447\u0435\u0442\u043e\u0432 FPV-\u041f\u0412\u041e \u043f\u043e \u0434\u0430\u043b\u044c\u043d\u043e\u0431\u043e\u0439\u043d\u044b\u043c \u0411\u041f\u041b\u0410 \u0412", "link": "https://t.me/lost_armour/9951", "pubDate": "2026-06-20T12:52:35+00:00"}, {"channel": "lost_armour", "snippet": "\u041c\u0438\u0444\u044b \u043e \"\u0401\u043b\u043a\u0435\" \u041c\u0438\u0444 1. \"\u0401\u043b\u043a\u0430\" \u043d\u0435 \u043c\u043e\u0436\u0435\u0442 \u043d\u0435\u0441\u0442\u0438 \u0431\u043e\u0435\u0432\u0443\u044e \u0447\u0430\u0441\u0442\u044c (\u0411\u0427). \u0424\u0430\u043a\u0442. \"\u0401\u043b\u043a\u0430\" \u043c\u043e\u0436\u0435\u0442 \u043d\u0435\u0441\u0442\u0438 \u0431\u043e\u0435\u0432\u0443\u044e \u0447\u0430\u0441\u0442\u044c (\u043e\u0434\u0438\u043d \u0438\u0437 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u0432 \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0411\u0427 - \u043d\u0430 \u0444\u043e\u0442\u043e). \u041d\u0435\u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0411\u0427 \"\u0401\u043b\u043e\u043a\" \u0438\u0437 \u0447\u0438\u0441\u043b\u0430 \u043f\u0435\u0440\u0432\u044b\u0445 \u043f\u0430\u0440\u0442\u0438\u0439 \u0443\u0436\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u043b\u0438\u0441\u044c \u0432 \u0437\u043e\u043d\u0435 \u0421\u0412\u041e. \u041f\u043e \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430\u043c \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0430 \u0431\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0431\u044b\u043b \u0441\u0434\u0435\u043b\u0430\u043d \u0432\u044b\u0432\u043e\u0434, \u0447\u0442\u043e \"\u0415\u043b\u043a\u0430\" \u0432 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u0435 (\u0431\u0435\u0437 \u0411\u0427) \u043e\u0431\u043b\u0430\u0434\u0430\u0435\u0442 \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435\u0439 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c\u044e, \u0447\u0435\u043c \u0432", "snippet_en": "\u041c\u0438\u0444\u044b \u043e \"\u0401\u043b\u043a\u0435\" \u041c\u0438\u0444 1. \"\u0401\u043b\u043a\u0430\" \u043d\u0435 \u043c\u043e\u0436\u0435\u0442 \u043d\u0435\u0441\u0442\u0438 \u0431\u043e\u0435\u0432\u0443\u044e \u0447\u0430\u0441\u0442\u044c (\u0411\u0427). \u0424\u0430\u043a\u0442. \"\u0401\u043b\u043a\u0430\" \u043c\u043e\u0436\u0435\u0442 \u043d\u0435\u0441\u0442\u0438 \u0431\u043e\u0435\u0432\u0443\u044e \u0447\u0430\u0441\u0442\u044c (\u043e\u0434\u0438\u043d \u0438\u0437 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u0432 \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0411\u0427 - \u043d\u0430 \u0444\u043e\u0442\u043e). \u041d\u0435\u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0411\u0427 \"\u0401\u043b\u043e\u043a\" \u0438\u0437 \u0447\u0438\u0441\u043b\u0430 \u043f\u0435\u0440\u0432\u044b\u0445 \u043f\u0430\u0440\u0442\u0438\u0439 \u0443\u0436\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u043b\u0438\u0441\u044c \u0432 \u0437\u043e\u043d\u0435 \u0421\u0412\u041e. \u041f\u043e \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430\u043c \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0430 \u0431\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0431\u044b\u043b \u0441\u0434\u0435\u043b\u0430\u043d \u0432\u044b\u0432\u043e\u0434, \u0447\u0442\u043e \"\u0415\u043b\u043a\u0430\" \u0432 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u0435 (\u0431\u0435\u0437 \u0411\u0427) \u043e\u0431\u043b\u0430\u0434\u0430\u0435\u0442 \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435\u0439 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c\u044e, \u0447\u0435\u043c \u0432", "link": "https://t.me/lost_armour/9936", "pubDate": "2026-06-19T18:27:04+00:00"}, {"channel": "combat_ftg2", "snippet": "The Russians managed to destroy an entire bridge using ordinary FPV drones. Enemy drone operators used 43 FPV drones to destroy the concrete supports of a bridge over the Nitrius River in the Kharkiv region.", "snippet_en": "The Russians managed to destroy an entire bridge using ordinary FPV drones. Enemy drone operators used 43 FPV drones to destroy the concrete supports of a bridge over the Nitrius River in the Kharkiv region.", "link": "https://t.me/combat_ftg2/3611", "pubDate": "2026-06-17T06:40:20+00:00"}, {"channel": "serhii_flash", "snippet": "\u041d\u0430 \u043f\u0456\u0432\u0434\u043d\u0456 \u043a\u0440\u0430\u0457\u043d\u0438 \u0444\u0456\u043a\u0441\u0443\u0454\u043c\u043e \u043f\u043e\u044f\u0432\u0443 \u0441\u0435\u0440\u0456\u0439\u043d\u043e\u0433\u043e \u043d\u043e\u0432\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u043d\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0456\u044f \u0411\u041f\u041b\u0410 \u2014 \u0434\u0435\u0448\u0435\u0432\u0438\u0439 \u043f\u0440\u0438\u043c\u0438\u0442\u0438\u0432\u043d\u044b\u0439 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0439 \u0434\u0440\u043e\u043d. \u0410\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0435 \u0432\u0456\u0434\u0435\u043e \u043d\u0430 \u0447\u0430\u0441\u0442\u043e\u0442\u0456 3,3 \u0413\u0413\u0446. \u0414\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c \u043f\u043e\u043b\u044c\u043e\u0442\u0443 \u0434\u043e 100 \u043a\u0456\u043b\u043e\u043c\u0435\u0442\u0440\u0456\u0432 (\u043f\u043e\u043a\u0438 \u0449\u043e \u0444\u0456\u043a\u0441\u0443\u044e \u0443\u0434\u0430\u0440\u0438 \u043d\u0430 \u0432\u0456\u0434\u0441\u0442\u0430\u043d\u0456 30\u201340 \u043a\u043c \u0432\u0456\u0434 \u043b\u0456\u043d\u0456\u0457 \u0444\u0440\u043e\u043d\u0442\u0443). \u041a\u0440\u0435\u0439\u0441\u0435\u0440\u0441\u044c\u043a\u0430 \u0448\u0432\u0438\u0434\u043a\u0456\u0441\u0442\u044c \u2014 260 \u043a\u043c/\u0433\u043e\u0434, \u0437 \u0440\u043e\u0437\u0433\u043e\u043d\u0430\u043c\u0438 \u0434\u043e 300 \u043a\u043c/\u0433\u043e\u0434 \u0411\u043e\u0439\u043e\u0432\u0430 \u0447\u0430\u0441\u0442\u0438\u043d\u0430 \u2014 \u043f\u0440\u0438\u0431\u043b\u0438\u0437\u043d\u043e 4\u20135 \u043a\u0433 \u041f\u0440\u043e\u0448\u0443 \u0432\u0441\u0456\u0445 \u0437\u0432\u0435\u0440\u043d\u0443\u0442\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u0444\u043e\u0440\u043c\u0430\u0442 \u0432\u0456\u0434\u0435\u043e", "snippet_en": "\u041d\u0430 \u043f\u0456\u0432\u0434\u043d\u0456 \u043a\u0440\u0430\u0457\u043d\u0438 \u0444\u0456\u043a\u0441\u0443\u0454\u043c\u043e \u043f\u043e\u044f\u0432\u0443 \u0441\u0435\u0440\u0456\u0439\u043d\u043e\u0433\u043e \u043d\u043e\u0432\u043e\u0433\u043e \u0443\u0434\u0430\u0440\u043d\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430. \u041a\u043e\u043d\u0446\u0435\u043f\u0446\u0456\u044f \u0411\u041f\u041b\u0410 \u2014 \u0434\u0435\u0448\u0435\u0432\u0438\u0439 \u043f\u0440\u0438\u043c\u0438\u0442\u0438\u0432\u043d\u044b\u0439 \u0440\u0435\u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0439 \u0434\u0440\u043e\u043d. \u0410\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0435 \u0432\u0456\u0434\u0435\u043e \u043d\u0430 \u0447\u0430\u0441\u0442\u043e\u0442\u0456 3,3 \u0413\u0413\u0446. \u0414\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c \u043f\u043e\u043b\u044c\u043e\u0442\u0443 \u0434\u043e 100 \u043a\u0456\u043b\u043e\u043c\u0435\u0442\u0440\u0456\u0432 (\u043f\u043e\u043a\u0438 \u0449\u043e \u0444\u0456\u043a\u0441\u0443\u044e \u0443\u0434\u0430\u0440\u0438 \u043d\u0430 \u0432\u0456\u0434\u0441\u0442\u0430\u043d\u0456 30\u201340 \u043a\u043c \u0432\u0456\u0434 \u043b\u0456\u043d\u0456\u0457 \u0444\u0440\u043e\u043d\u0442\u0443). \u041a\u0440\u0435\u0439\u0441\u0435\u0440\u0441\u044c\u043a\u0430 \u0448\u0432\u0438\u0434\u043a\u0456\u0441\u0442\u044c \u2014 260 \u043a\u043c/\u0433\u043e\u0434, \u0437 \u0440\u043e\u0437\u0433\u043e\u043d\u0430\u043c\u0438 \u0434\u043e 300 \u043a\u043c/\u0433\u043e\u0434 \u0411\u043e\u0439\u043e\u0432\u0430 \u0447\u0430\u0441\u0442\u0438\u043d\u0430 \u2014 \u043f\u0440\u0438\u0431\u043b\u0438\u0437\u043d\u043e 4\u20135 \u043a\u0433 \u041f\u0440\u043e\u0448\u0443 \u0432\u0441\u0456\u0445 \u0437\u0432\u0435\u0440\u043d\u0443\u0442\u0438 \u0443\u0432\u0430\u0433\u0443 \u043d\u0430 \u0444\u043e\u0440\u043c\u0430\u0442 \u0432\u0456\u0434\u0435\u043e", "link": "https://t.me/serhii_flash/7492", "pubDate": "2026-06-16T16:52:16+00:00"}, {"channel": "combat_ftg2", "snippet": "Ukraine's \"SIGNUM\" continues repelling Russian infantry fr\u03bfm Lyman forests using FPV drone strikes", "snippet_en": "Ukraine's \"SIGNUM\" continues repelling Russian infantry fr\u03bfm Lyman forests using FPV drone strikes", "link": "https://t.me/combat_ftg2/3600", "pubDate": "2026-06-01T16:22:34+00:00"}, {"channel": "combat_ftg2", "snippet": "Russian soldier failed grenade throw, after FPV drone hits", "snippet_en": "Russian soldier failed grenade throw, after FPV drone hits", "link": "https://t.me/combat_ftg2/3597", "pubDate": "2026-05-28T17:22:36+00:00"}, {"channel": "combat_ftg2", "snippet": "Ukrainian UGV dodges russian FPV", "snippet_en": "Ukrainian UGV dodges russian FPV", "link": "https://t.me/combat_ftg2/3596", "pubDate": "2026-05-28T10:01:22+00:00"}, {"channel": "lost_armour", "snippet": "\u041b\u0438\u0447\u043d\u044b\u0439 \u0441\u0447\u0435\u0442 \u0422\u0440\u0443\u0434\u043e\u0432\u044b\u0435 \u0431\u0443\u0434\u043d\u0438 \u043e\u0434\u043d\u043e\u0433\u043e \u0438\u0437 FPV-\u043f\u0438\u043b\u043e\u0442\u043e\u0432 \u0412\u0421 \u0420\u0424 \u043d\u0430 \u0425\u0430\u0440\u044c\u043a\u043e\u0432\u0441\u043a\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u043