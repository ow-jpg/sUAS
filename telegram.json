40\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0434\u043b\u044f \u0437\u0430\u0445\u0438\u0441\u0442\u0443 \u0432\u0456\u0434 \u043d\u0435\u0433\u043e\u0434\u0438 \u0442\u0430 \u043d\u0430\u0448\u0438\u0445 \u0434\u0440\u043e\u043d\u0456\u0432, \u043e\u043f\u0435\u0440\u0430\u0442\u0438\u0432\u043d\u043e \u0432\u0438\u044f\u0432\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u0442\u0430 \u043c\u0435\u0442\u043e\u0434\u0438\u0447\u043d\u043e \u0437\u043d\u0438\u0449\u0443\u044e\u0442\u044c\u0441\u044f \u0443\u0434\u0430\u0440\u043d\u0438\u043c\u0438 \u0411\u043f\u041b\u0410 \u043f\u0456\u0434\u0440\u043e\u0437\u0434\u0456\u043b\u0443 \u00abApachi\u00bb. \u2757\ufe0f\u0414\u0435\u044f\u043a\u0456 ", "snippet_en": "\ud83d\udca3\u0411\u0411\u043f\u0421 \u00abApachi\u00bb \u0432\u0449\u0435\u043d\u0442 \u0440\u043e\u0437\u0431\u0438\u0432\u0430\u044e\u0442\u044c \u043f\u043b\u0430\u043d\u0438 \u043e\u043a\u0443\u043f\u0430\u043d\u0442\u0456\u0432 \u043d\u0430 \u0421\u043b\u043e\u0432\u2019\u044f\u043d\u0441\u044c\u043a\u043e\u043c\u0443 \u043d\u0430\u043f\u0440\u044f\u043c\u043a\u0443 \ud83d\udccd\u041d\u0430 \u0421\u043b\u043e\u0432\u2019\u044f\u043d\u0441\u044c\u043a\u043e\u043c\u0443 \u043d\u0430\u043f\u0440\u044f\u043c\u043a\u0443 \u0440\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u0456 \u043e\u043a\u0443\u043f\u0430\u0446\u0456\u0439\u043d\u0456 \u0432\u0456\u0439\u0441\u044c\u043a\u0430 \u043f\u0440\u043e\u0434\u043e\u0432\u0436\u0443\u044e\u0442\u044c \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0437\u0430\u0441\u0442\u043e\u0441\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0442\u0430\u043a\u0442\u0438\u043a\u0443 \u00ab\u0456\u043d\u0444\u0456\u043b\u044c\u0442\u0440\u0430\u0446\u0456\u0457\u00bb \u043d\u0435\u0432\u0435\u043b\u0438\u043a\u0438\u043c\u0438 \u0433\u0440\u0443\u043f\u0430\u043c\u0438. \u0423\u0441\u0456 \u0443\u043a\u0440\u0438\u0442\u0442\u044f \u0442\u0430 \u0441\u0445\u043e\u0432\u0430\u043d\u043a\u0438, \u044f\u043a\u0456 \u0432\u043