u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u043c\u0443 \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u0438\u043a\u0443, \u0440\u0443\u0445\u043d\u0443\u0432\u0448\u0435\u043c\u0443 \u043d\u0435\u043f\u043e\u0434\u0430\u043b\u0435\u043a\u0443. \u0421\u0442\u0430\u0442\u0438\u0441", "snippet_en": "\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0443\u0434\u0430\u0440 \u041f\u0440\u0438\u043c\u0435\u0447\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u044d\u043f\u0438\u0437\u043e\u0434 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0430 \u0434\u0432\u0443\u043c\u044f \u0434\u0440\u043e\u043d\u0430\u043c\u0438-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\" \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u0433\u043e \u0411\u041f\u041b\u0410 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u043d\u043e\u0433\u043e \u0442\u0438\u043f\u0430 \u0432 \u043e\u0434\u043d\u043e\u043c \u0438\u0437 \u0440\u0435\u0433\u0438\u043e\u043d\u043e\u0432 \u0420\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u043e\u0439 \u0424\u0435\u0434\u0435\u0440\u0430\u0446\u0438\u0438. \u041f\u043e \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0438 \u0441\u0440\u0430\u0437\u0443 \u0434\u0432\u0430 \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0445 \u043e\u0433\u043d\u0435\u0432\u044b\u0445 \u0433\u0440\u0443\u043f\u043f \u0438 \"\u0415\u043b\u043a\u0438\" \u043f\u0440\u0438\u0448\u043b\u0438 \u043a \u0446\u0435\u043b\u0438 \u0441 \u0440\u0430\u0437\u043d\u0438\u0446\u0435\u0439 \u0432 \u0434\u043e\u043b\u0438 \u0441\u0435\u043a\u0443\u043d\u0434\u044b, \u043d\u0430\u043d\u0435\u0441\u044f \u043f\u0440\u0438 \u044d\u0442\u043e\u043c \u043a\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043f\u043e\u0432\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u043c\u0443 \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u0438\u043a\u0443, \u0440\u0443\u0445\u043d\u0443\u0432\u0448\u0435\u043c\u0443 \u043d\u0435\u043f\u043e\u0434\u0430\u043b\u0435\u043a\u0443. \u0421\u0442\u0430\u0442\u0438\u0441", "link": "https://t.me/lost_armour/8804", "pubDate": "2026-04-02T09:23:43+00:00"}, {"channel": "lost_armour", "snippet": "\"\u041f\u0440\u0438\u0448\u0435\u043b, \u0443\u0432\u0438\u0434\u0435\u043b, \u043f\u043e\u0431\u0435\u0434\u0438\u043b\" \u0414\u0440\u043e\u043d-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\" \u044d\u0444\u0444\u0435\u043a\u0442\u043d\u043e \u043f\u043e\u0440\u0430\u0436\u0430\u0435\u0442 \u043e\u0447\u0435\u0440\u0435\u0434\u043d\u043e\u0439 \u0443\u0434\u0430\u0440\u043d\u044b\u0439 \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0441\u043f\u0443\u0441\u0442\u044f \u0432\u0441\u0435\u0433\u043e 5 \u0441\u0435\u043a\u0443\u043d\u0434 \u043f\u043e\u0441\u043b\u0435 \u043f\u0443\u0441\u043a\u0430. \u0412 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0430 \u0434\u0435\u0442\u043e\u043d\u0438\u0440\u0443\u0435\u0442 \u0437\u0430\u0440\u044f\u0434 \u043d\u0430 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u043c \u0434\u0440\u043e\u043d\u0435. \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0439 \"\u0415\u043b\u043e\u043a\": https://lostarmour.info/tags/elka\u2026", "snippet_en": "\"\u041f\u0440\u0438\u0448\u0435\u043b, \u0443\u0432\u0438\u0434\u0435\u043b, \u043f\u043e\u0431\u0435\u0434\u0438\u043b\" \u0414\u0440\u043e\u043d-\u041f\u0412\u041e \"\u0415\u043b\u043a\u0430\" \u044d\u0444\u0444\u0435\u043a\u0442\u043d\u043e \u043f\u043e\u0440\u0430\u0436\u0430\u0435\u0442 \u043e\u0447\u0435\u0440\u0435\u0434\u043d\u043e\u0439 \u0443\u0434\u0430\u0440\u043d\u044b\u0439 \u0411\u041f\u041b\u0410 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430 \u0441\u043f\u0443\u0441\u0442\u044f \u0432\u0441\u0435\u0433\u043e 5 \u0441\u0435\u043a\u0443\u043d\u0434 \u043f\u043e\u0441\u043b\u0435 \u043f\u0443\u0441\u043a\u0430. \u0412 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435 \u043a\u0438\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0430 \u0434\u0435\u0442\u043e\u043d\u0438\u0440\u0443\u0435\u0442 \u0437\u0430\u0440\u044f\u0434 \u043d\u0430 \u0432\u0440\u0430\u0436\u0435\u0441\u043a\u043e\u043c \u0434\u0440\u043e\u043d\u0435. \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0439 \"\u0415\u043b\u043e\u043a\": https://lostarmour.info/tags/elka\u2026", "link": "https://t.me/lost_armour/8803", "pubDate": "2026-04-02T06:02:59+00:00"}, {"channel": "lost_armour", "snippet": "\u041a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043d\u043e\u0435 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0430\u043c\u0435\u0440\u0438\u043a\u0430\u043d\u0441\u043a\u043e\u0433\u043e \u0431\u0440\u043e\u043d\u0435\u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u0435\u0440\u0430 M1126 \"Stryker\" \u0412\u0421\u0423 \u0443\u0434\u0430\u0440\u043d\u044b\u043c\u0438 \u0411\u041f\u041b\u0410 \u0432 \u0414\u043d\u0435\u043f\u0440\u043e\u043f\u0435\u0442\u0440\u043e\u0432\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438. \u0421\u043f\u0435\u0440\u0432\u0430 \u043e\u0442\u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0438 \u043e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u044b\u043c FPV-\u0434\u0440\u043e\u043d\u043e\u043c \"\u041a\u0412\u041d\", \u0437\u0430\u0442\u0435\u043c \u0434\u043e\u0431\u0438\u043b\u0438 \u0443\u0434\u0430\u0440\u043e\u043c \u0431\u0430\u0440\u0440\u0430\u0436\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u0431\u043e\u0435\u043f\u0440\u0438\u043f\u0430\u0441\u0430 \"\u041b\u0430\u043d\u0446\u0435\u0442\". \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \"\u041b\u0430\u043d\u0446\u0435\u0442\u043e\u0432\": https://lostarmour.info/tags/lancet \ud83d\udd39 \u041c\u044b \u0432 \u041c\u0410\u0425", "snippet_en": "\u041a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043d\u043e\u0435 \u043f\u043e\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0430\u043c\u0435\u0440\u0438\u043a\u0430\u043d\u0441\u043a\u043e\u0433\u043e \u0431\u0440\u043e\u043d\u0435\u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u0435\u0440\u0430 M1126 \"Stryker\" \u0412\u0421\u0423 \u0443\u0434\u0430\u0440\u043d\u044b\u043c\u0438 \u0411\u041f\u041b\u0410 \u0432 \u0414\u043d\u0435\u043f\u0440\u043e\u043f\u0435\u0442\u0440\u043e\u0432\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438. \u0421\u043f\u0435\u0440\u0432\u0430 \u043e\u0442\u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0438 \u043e\u043f\u0442\u043e\u0432\u043e\u043b\u043e\u043a\u043e\u043d\u043d\u044b\u043c FPV-\u0434\u0440\u043e\u043d\u043e\u043c \"\u041a\u0412\u041d\", \u0437\u0430\u0442\u0435\u043c \u0434\u043e\u0431\u0438\u043b\u0438 \u0443\u0434\u0430\u0440\u043e\u043c \u0431\u0430\u0440\u0440\u0430\u0436\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u0431\u043e\u0435\u043f\u0440\u0438\u043f\u0430\u0441\u0430 \"\u041b\u0430\u043d\u0446\u0435\u0442\". \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \"\u041b\u0430\u043d\u0446\u0435\u0442\u043e\u0432\": https://lostarmour.info/tags/lancet \ud83d\udd39 \u041c\u044b \u0432 \u041c\u0410\u0425", "link": "https://t.me/lost_armour/8800", "pubDate": "2026-04-01T20:22:13+00:00"}, {"channel": "VictoryDrones2023", "snippet": "\ud83d\udca5 \u0420\u043e\u0441\u0456\u0439\u0441\u044c\u043a\u0456 \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0438 \u0411\u043f\u041b\u0410 \u2013 \u043f\u0440\u0456\u043e\u0440\u0438\u0442\u0435\u0442\u043d\u0430 \u0446\u0456\u043b\u044c \u0443 \u0441\u0438\u0441\u0442\u0435\u043c\u0456 \u0410\u0440\u043c\u0456\u044f \u0434\u0440\u043e\u043d\u0456\u0432 \u0411\u043e\u043d\u0443\u0441. \u0422\u0435\u043f\u0435\u0440 \u0437\u0430 \u043b\u0456\u043a\u0432\u0456\u0434\u0430\u0446\u0456\u044e \u043e\u0434\u043d\u043e\u0433\u043e \u043f\u0456\u043b\u043e\u0442\u0430 \u043d\u0430\u0440\u0430\u0445\u043e\u0432\u0443\u0454\u043c\u043e \u0443 2 \u0440\u0430\u0437\u0438 \u0431\u0456\u043b\u044c\u0448\u0435 \u0431\u0430\u043b\u0456\u0432, \u043d\u0456\u0436 \u0437\u0430 \u0437\u0432\u0438\u0447\u0430\u0439\u043d\u043e\u0433\u043e \u043f\u0456\u0445\u043e\u0442\u0438\u043d\u0446\u044f. \u041e\u0442\u0440\u0438\u043c\u0430\u043d\u0456 \u0454\u0411\u0430\u043b\u0438 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0443\u044e\u0442\u044c\u0441\u044f \u0432 \u043d\u043e\u0432\u0443 \u0442\u0435\u0445\u043d\u0456\u043a\u0443 \u0442\u0430 \u043e\u0437\u0431\u0440\u043e\u0454\u043d\u043d\u044f. \u0422\u043e\u0431\u0442\u043e, \u0432 \u043d\u043e\u0432\u0456 \u0443\u0440\u0430\u0436\u0435\u043d\u043d\u044f. \u0426\u0435 \u0436\u043e\u0440\u0441\u0442\u043e\u043a\u0430 \u043b\u043e\u0433\u0456\u043a\u0430, \u043e\u0434\u043d\u0430\u043a \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u0430: \u0447\u0438\u043c \u043a\u043e\u0440\u043e\u0442\u0448\u0438\u043c \u0431\u0443\u0434\u0435 \u0436\u0438\u0442\u0442\u044f \u0432\u043e\u0440\u043e\u0436\u0438\u0445 \u0434\u0440\u043e\u043d\u0449\u0438\u043a\u0456\u0432, \u0442\u0438\u043c \u0431\u0456\u043b\u044c\u0448\u0435 \u0432\u0440\u044f\u0442\u0443\u0454\u043c\u043e \u0436\u0438\u0442\u0442\u0456\u0432 \u043d\u0430\u0448\u0438\u0445 \u0432\u043e\u044f\u043a\u0456\u0432 \u0456 \u043c\u0438\u0440\u043d\u0438\u0445 \u0436\u0438\u0442\u0435\u043b\u0456\u0432. \u0423\